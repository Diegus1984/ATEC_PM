<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cc="clr-namespace:ATEC.PM.Client.Controls.Costing"
    xmlns:vm="clr-namespace:ATEC.PM.Client.Views.Costing.ViewModels">

    <!--
        Converter usano le key globali da Resources/Converters.xaml:
        HexToBrush, HexToAlphaBrush, BoolToAngle, PctToString,
        MarkupToString, ItemTypeToBadge, BoolToVis
    -->

    <!--
        ═══════════════════════════════════════════════════════════
        Shared Styles
        ═══════════════════════════════════════════════════════════
    -->

    <Style x:Key="CC_ColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F9FAFB" />
        <Setter Property="Foreground" Value="#6B7280" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="6,0" />
    </Style>

    <Style x:Key="CC_Cell" TargetType="DataGridCell">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CC_ChevronPath" TargetType="Path">
        <Setter Property="Width" Value="7" />
        <Setter Property="Height" Value="9" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Data" Value="M 0,0 L 4.5,4.5 L 0,9" />
        <Setter Property="Stroke" Value="#9CA3AF" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        CostSectionControl
        ═══════════════════════════════════════════════════════════
    -->

    <Style TargetType="{x:Type cc:CostSectionControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cc:CostSectionControl}">
                    <Border
                        Margin="0,0,0,2"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1">
                        <StackPanel>
                            <!--  Header row  -->
                            <Grid
                                x:Name="PART_HeaderGrid"
                                Background="#FAFBFC"
                                Cursor="Hand">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <StackPanel
                                    Grid.Column="0"
                                    Margin="12,8,0,8"
                                    Orientation="Horizontal">
                                    <Path Margin="0,0,8,0" Style="{StaticResource CC_ChevronPath}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                        </Path.RenderTransform>
                                    </Path>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="#1A1D26"
                                        Text="{Binding Name}" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#6B7280"
                                    Text="{Binding ResourceCount}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#1A1D26">
                                    <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#4F6EF7">
                                    <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                <Border
                                    Grid.Column="4"
                                    Padding="4,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{Binding TypeColor, Converter={StaticResource HexToAlphaBrush}, ConverterParameter=20}">
                                    <TextBlock
                                        FontSize="9"
                                        FontWeight="Bold"
                                        Foreground="{Binding TypeColor, Converter={StaticResource HexToBrush}}"
                                        Text="{Binding TypeLabel}" />
                                </Border>
                                <!--  Dist % Contingency (offer only)  -->
                                <TextBox
                                    Grid.Column="5"
                                    Width="55"
                                    Height="22"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="#D9770620"
                                    BorderBrush="#D9770640"
                                    BorderThickness="1"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#D97706"
                                    Tag="contingency"
                                    Text="{Binding ContingencyPct, Converter={StaticResource PctToString}, UpdateSourceTrigger=LostFocus}"
                                    Visibility="{Binding IsOfferMode, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}" />
                                <!--  Dist % Margin (offer only)  -->
                                <TextBox
                                    Grid.Column="6"
                                    Width="55"
                                    Height="22"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="#7C3AED20"
                                    BorderBrush="#7C3AED40"
                                    BorderThickness="1"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#7C3AED"
                                    Tag="margin"
                                    Text="{Binding MarginPct, Converter={StaticResource PctToString}, UpdateSourceTrigger=LostFocus}"
                                    Visibility="{Binding IsOfferMode, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                            <!--  Expandable detail  -->
                            <Border Padding="8,4,8,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <!--  Resource DataGrid (unified IN_SEDE + DA_CLIENTE)  -->
                                    <DataGrid
                                        x:Name="PART_ResourceGrid"
                                        AutoGenerateColumns="False"
                                        BorderThickness="0"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False"
                                        CellStyle="{StaticResource CC_Cell}"
                                        ColumnHeaderHeight="28"
                                        ColumnHeaderStyle="{StaticResource CC_ColumnHeader}"
                                        FontSize="12"
                                        GridLinesVisibility="Horizontal"
                                        HeadersVisibility="Column"
                                        HorizontalGridLinesBrush="#F3F4F6"
                                        ItemsSource="{Binding Resources}"
                                        RowHeight="32"
                                        SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="*" Header="RISORSA">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            Padding="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Text="{Binding ResourceName}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox
                                                            BorderThickness="0"
                                                            DisplayMemberPath="FullName"
                                                            FontSize="12" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn
                                                Width="50"
                                                Binding="{Binding WorkDays, StringFormat=F0}"
                                                Header="GG" />
                                            <DataGridTextColumn
                                                Width="55"
                                                Binding="{Binding HoursPerDay, StringFormat=F0}"
                                                Header="ORE/G" />
                                            <DataGridTextColumn
                                                Width="65"
                                                Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}"
                                                Header="TOT ORE"
                                                IsReadOnly="True" />
                                            <DataGridTextColumn
                                                Width="60"
                                                Binding="{Binding HourlyCost, StringFormat=F2}"
                                                Header="€/H"
                                                IsReadOnly="True" />
                                            <DataGridTextColumn
                                                Width="80"
                                                Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                                                Header="TOT €"
                                                IsReadOnly="True" />
                                            <DataGridTextColumn Width="60" Header="K">
                                                <DataGridTextColumn.Binding>
                                                    <Binding
                                                        ConverterCulture="en-US"
                                                        Path="MarkupValue"
                                                        StringFormat="F3" />
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn
                                                Width="80"
                                                Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}"
                                                Header="VENDITA €"
                                                IsReadOnly="True" />
                                            <!--  DA_CLIENTE extra columns  -->
                                            <DataGridTextColumn
                                                Width="50"
                                                Binding="{Binding NumTrips}"
                                                Header="VIAGGI"
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}" />
                                            <DataGridTextColumn
                                                Width="50"
                                                Binding="{Binding KmPerTrip, StringFormat=F0}"
                                                Header="KM"
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}" />
                                            <DataGridTextColumn
                                                Width="50"
                                                Binding="{Binding CostPerKm, StringFormat=F2}"
                                                Header="€/KM"
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}" />
                                            <DataGridTextColumn
                                                Width="55"
                                                Binding="{Binding DailyFood, StringFormat=F0}"
                                                Header="VITTO/G"
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}" />
                                            <DataGridTextColumn
                                                Width="55"
                                                Binding="{Binding DailyHotel, StringFormat=F0}"
                                                Header="HOTEL/G"
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}" />
                                            <DataGridTextColumn
                                                Width="55"
                                                Binding="{Binding AllowanceDays, StringFormat=F0}"
                                                Header="GG IND."
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}" />
                                            <DataGridComboBoxColumn
                                                Width="70"
                                                Header="€/G IND."
                                                SelectedItemBinding="{Binding DailyAllowance, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding DataContext.IsDaCliente, RelativeSource={RelativeSource AncestorType=cc:CostSectionControl}, Converter={StaticResource BoolToVis}}">
                                                <DataGridComboBoxColumn.ElementStyle>
                                                    <Style TargetType="ComboBox">
                                                        <Setter Property="ItemsSource" Value="{x:Static vm:CostResourceVM.AllowanceOptions}" />
                                                        <Setter Property="IsReadOnly" Value="True" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                    </Style>
                                                </DataGridComboBoxColumn.ElementStyle>
                                                <DataGridComboBoxColumn.EditingElementStyle>
                                                    <Style TargetType="ComboBox">
                                                        <Setter Property="ItemsSource" Value="{x:Static vm:CostResourceVM.AllowanceOptions}" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                    </Style>
                                                </DataGridComboBoxColumn.EditingElementStyle>
                                            </DataGridComboBoxColumn>
                                            <!--  Delete button  -->
                                            <DataGridTemplateColumn Width="30" Header="">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button
                                                            Width="20"
                                                            Height="20"
                                                            Background="#EF44441A"
                                                            BorderThickness="0"
                                                            Content="✕"
                                                            Cursor="Hand"
                                                            FontSize="9"
                                                            Foreground="#EF4444"
                                                            Tag="{Binding Id}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!--  DA_CLIENTE subtotals footer  -->
                                    <Border
                                        Margin="0,4,0,0"
                                        Padding="8,6"
                                        Background="#F9FAFB"
                                        BorderBrush="#E4E7EC"
                                        BorderThickness="0,1,0,0"
                                        Visibility="{Binding IsDaCliente, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#1A1D26"
                                                Text="Subtotali" />
                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#1A1D26">
                                                <Run Text="Ore: " /><Run Text="{Binding TotalCostOre, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#1A1D26">
                                                <Run Text="Viaggi: " /><Run Text="{Binding TotalViaggi, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#1A1D26">
                                                <Run Text="Vitto/Alloggio: " /><Run Text="{Binding TotalAlloggio, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                            <TextBlock
                                                Grid.Column="4"
                                                Margin="0,0,8,0"
                                                HorizontalAlignment="Right"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#1A1D26">
                                                <Run Text="Indennità: " /><Run Text="{Binding TotalIndennita, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                        </Grid>
                                    </Border>

                                    <Button
                                        x:Name="PART_AddResourceButton"
                                        Height="26"
                                        Margin="0,4,0,0"
                                        Padding="10,0"
                                        HorizontalAlignment="Left"
                                        Background="#4F6EF7"
                                        BorderThickness="0"
                                        Content="+ Risorsa"
                                        Cursor="Hand"
                                        FontSize="11"
                                        Foreground="White" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        CostGroupControl
        ═══════════════════════════════════════════════════════════
    -->

    <Style TargetType="{x:Type cc:CostGroupControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cc:CostGroupControl}">
                    <StackPanel Margin="0,4,0,0">
                        <!--  Group header  -->
                        <Border
                            x:Name="PART_HeaderBorder"
                            Padding="8,6"
                            Background="{Binding Color, Converter={StaticResource HexToBrush}}"
                            Cursor="Hand">
                            <DockPanel>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Right"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#C8FFFFFF">
                                    <Run Text="Netto " /><Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" />
                                    <Run Text=" €  →  Vendita " /><Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <Path
                                        Width="8"
                                        Height="10"
                                        Margin="4,0,8,0"
                                        VerticalAlignment="Center"
                                        Data="M 0,0 L 5,5 L 0,10"
                                        RenderTransformOrigin="0.5,0.5"
                                        Stroke="#FFFFFF90"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource BoolToAngle}}" />
                                        </Path.RenderTransform>
                                    </Path>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!--  Sections content (collapsible)  -->
                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                            <ItemsControl Margin="16,4,0,0" ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CostSectionVM}">
                                        <cc:CostSectionControl IsOfferMode="{Binding DataContext.IsOfferMode, RelativeSource={RelativeSource AncestorType=cc:CostGroupControl}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button
                                x:Name="PART_AddSectionButton"
                                Height="26"
                                Margin="16,6,0,4"
                                Padding="10,0"
                                HorizontalAlignment="Left"
                                Background="#05966920"
                                BorderThickness="0"
                                Content="+ Aggiungi Sezione"
                                Cursor="Hand"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#059669" />
                        </StackPanel>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        MaterialSectionControl
        ═══════════════════════════════════════════════════════════
    -->

    <Style TargetType="{x:Type cc:MaterialSectionControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cc:MaterialSectionControl}">
                    <Border
                        Margin="0,0,0,2"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1">
                        <StackPanel>
                            <!--  Header  -->
                            <Grid
                                x:Name="PART_HeaderGrid"
                                Background="#FAFBFC"
                                Cursor="Hand">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel
                                    Grid.Column="0"
                                    Margin="12,8,0,8"
                                    Orientation="Horizontal">
                                    <Path Margin="0,0,8,0" Style="{StaticResource CC_ChevronPath}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                        </Path.RenderTransform>
                                    </Path>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="#1A1D26"
                                        Text="{Binding Name}" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#6B7280"
                                    Text="{Binding ItemCount}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#1A1D26">
                                    <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#4F6EF7">
                                    <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                            </Grid>

                            <!--  Detail  -->
                            <Border Padding="8,4,8,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <DataGrid
                                        x:Name="PART_MaterialGrid"
                                        AutoGenerateColumns="False"
                                        BorderThickness="0"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False"
                                        CellStyle="{StaticResource CC_Cell}"
                                        ColumnHeaderHeight="28"
                                        ColumnHeaderStyle="{StaticResource CC_ColumnHeader}"
                                        FontSize="12"
                                        GridLinesVisibility="Horizontal"
                                        HeadersVisibility="Column"
                                        HorizontalGridLinesBrush="#F3F4F6"
                                        ItemsSource="{Binding Items}"
                                        RowHeight="32"
                                        SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Width="*"
                                                Binding="{Binding Description}"
                                                Header="DESCRIZIONE" />
                                            <DataGridTextColumn
                                                Width="60"
                                                Binding="{Binding Quantity, StringFormat=F0}"
                                                Header="QTÀ" />
                                            <DataGridTextColumn
                                                Width="100"
                                                Binding="{Binding UnitCost, StringFormat=N2}"
                                                Header="COSTO UNIT." />
                                            <DataGridTextColumn
                                                Width="100"
                                                Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                                                Header="COSTO TOT."
                                                IsReadOnly="True" />
                                            <DataGridTextColumn Width="70" Header="K">
                                                <DataGridTextColumn.Binding>
                                                    <Binding
                                                        ConverterCulture="en-US"
                                                        Path="MarkupValue"
                                                        StringFormat="F3" />
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn
                                                Width="100"
                                                Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}"
                                                Header="PREZZO VENDITA"
                                                IsReadOnly="True" />
                                            <DataGridTemplateColumn Width="30" Header="">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Text="{Binding ItemType, Converter={StaticResource ItemTypeToBadge}}"
                                                            ToolTip="{Binding ItemType}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="30" Header="">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button
                                                            Width="20"
                                                            Height="20"
                                                            Background="#EF44441A"
                                                            BorderThickness="0"
                                                            Content="✕"
                                                            Cursor="Hand"
                                                            FontSize="9"
                                                            Foreground="#EF4444"
                                                            Tag="{Binding Id}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <Button
                                            x:Name="PART_AddItemButton"
                                            Height="26"
                                            Padding="10,0"
                                            HorizontalAlignment="Left"
                                            Background="#4F6EF7"
                                            BorderThickness="0"
                                            Content="+ Riga"
                                            Cursor="Hand"
                                            FontSize="11"
                                            Foreground="White" />
                                        <Button
                                            x:Name="PART_AddCommissionButton"
                                            Height="26"
                                            Margin="8,0,0,0"
                                            Padding="10,0"
                                            HorizontalAlignment="Left"
                                            Background="#7C3AED"
                                            BorderThickness="0"
                                            Content="+ Provvigione"
                                            Cursor="Hand"
                                            FontSize="11"
                                            Foreground="White" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
