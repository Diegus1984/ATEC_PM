<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════
        Shared Styles
        ═══════════════════════════════════════════════════════════
    -->

    <Style x:Key="CC_ColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F9FAFB" />
        <Setter Property="Foreground" Value="#6B7280" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="6,0" />
    </Style>

    <Style x:Key="CC_Cell" TargetType="DataGridCell">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CC_ChevronPath" TargetType="Path">
        <Setter Property="Width" Value="7" />
        <Setter Property="Height" Value="9" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Data" Value="M 0,0 L 4.5,4.5 L 0,9" />
        <Setter Property="Stroke" Value="#9CA3AF" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>
</ResourceDictionary>
