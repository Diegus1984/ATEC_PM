    <Style x:Key="NavBtn" TargetType="Button">
        <Setter Property="Height" Value="32" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#B0BEC5" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border
                            x:Name="accent"
                            Width="3"
                            HorizontalAlignment="Left"
                            Background="Transparent" />
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter x:Name="cp" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <!--  IsEnabled=False = voce attiva (selezionata)  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="accent" Property="Background" Value="{StaticResource PrimaryBrush}" />
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
