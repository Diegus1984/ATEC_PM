<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════
        ATEC PM — Design System: Colori
        Palette coerente ispirata a Shadcn/Radix UI
        ═══════════════════════════════════════════════════════════════
    -->

    <!--  Primary  -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryHoverColor">#1D4ED8</Color>
    <Color x:Key="PrimaryPressedColor">#1E40AF</Color>
    <Color x:Key="PrimaryLightColor">#EFF6FF</Color>

    <!--  Neutral  -->
    <Color x:Key="Gray50Color">#F9FAFB</Color>
    <Color x:Key="Gray100Color">#F3F4F6</Color>
    <Color x:Key="Gray200Color">#E5E7EB</Color>
    <Color x:Key="Gray300Color">#D1D5DB</Color>
    <Color x:Key="Gray400Color">#9CA3AF</Color>
    <Color x:Key="Gray500Color">#6B7280</Color>
    <Color x:Key="Gray600Color">#4B5563</Color>
    <Color x:Key="Gray700Color">#374151</Color>
    <Color x:Key="Gray800Color">#1F2937</Color>
    <Color x:Key="Gray900Color">#111827</Color>

    <!--  Semantic  -->
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="DangerHoverColor">#B91C1C</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="SuccessHoverColor">#15803D</Color>
    <Color x:Key="WarningColor">#D97706</Color>

    <!--  Brushes  -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="Gray50Brush" Color="{StaticResource Gray50Color}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100Color}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200Color}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300Color}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400Color}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500Color}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600Color}" />
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700Color}" />
    <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800Color}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900Color}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <!--  Alias retrocompatibilità  -->
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryColor}" />


    <!--
        ═══════════════════════════════════════════════════════════════
        ROW ACTION BUTTONS — Pulsanti azione inline nelle righe DataGrid
        Icone compatte 28×28, sfondo tenue, angoli arrotondati
        ═══════════════════════════════════════════════════════════════
    -->
    <Style x:Key="RowEditBtn" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="#4F6EF71A" />
        <Setter Property="Foreground" Value="#4F6EF7" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Content" Value="✏" />
        <Setter Property="ToolTip" Value="Modifica" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#4F6EF733" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#4F6EF74D" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RowDeleteBtn" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="#EF44441A" />
        <Setter Property="Foreground" Value="#EF4444" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Content" Value="✕" />
        <Setter Property="ToolTip" Value="Elimina" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#EF444433" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#EF44444D" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!--
        ═══════════════════════════════════════════════════════════════
        TOOLBAR BORDER — Barra azioni in cima alle pagine lista
        Background bianco, bordo inferiore sottile, padding uniforme
        ═══════════════════════════════════════════════════════════════
    -->
    <Style x:Key="ToolbarBorder" TargetType="Border">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#E4E7EC" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>


    <!--
        ═══════════════════════════════════════════════════════════════
        BOTTONE BASE — FlatBtn (Secondary / Default)
        Sfondo chiaro, bordo sottile, hover con cambio colore reale
        ═══════════════════════════════════════════════════════════════
    -->
    <Style x:Key="FlatBtn" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource Gray700Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Gray300Brush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                Opacity="0.04"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray50Brush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Gray400Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray100Brush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Gray400Brush}" />
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Opacity="0"
                                        ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray50Brush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Gray200Brush}" />
                            <Setter Property="Foreground" Value="{StaticResource Gray400Brush}" />
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Opacity="0"
                                        ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!--
        ═══════════════════════════════════════════════════════════════
        PRIMARY BUTTON — Azione principale (Salva, Importa, Conferma)
        ═══════════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="PrimaryBtn"
        BasedOn="{StaticResource FlatBtn}"
        TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#3B82F6" />
                    <GradientStop Offset="1" Color="{StaticResource PrimaryColor}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="4"
                                Direction="270"
                                Opacity="0.15"
                                ShadowDepth="1"
                                Color="#2563EB" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#2563EB" />
                                        <GradientStop Offset="1" Color="{StaticResource PrimaryHoverColor}" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource PrimaryPressedColor}" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Opacity="0"
                                        ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#93C5FD" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#93C5FD" />
                            <Setter Property="Foreground" Value="#DBEAFE" />
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Opacity="0"
                                        ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!--
        ═══════════════════════════════════════════════════════════════
        DANGER BUTTON — Azione distruttiva (Elimina, Rimuovi)
        ═══════════════════════════════════════════════════════════════
    -->
