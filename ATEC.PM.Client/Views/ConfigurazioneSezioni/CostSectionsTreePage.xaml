<Page
    x:Class="ATEC.PM.Client.Views.CostSectionsTreePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <Page.Resources>
        <Style x:Key="DragBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Page.Resources>

    <DockPanel>

        <!--  TOOLBAR  -->
        <Border Style="{StaticResource ToolbarBorder}" DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center" FontSize="16" FontWeight="Bold"
                        Foreground="#1A1D26" Text="Sezioni Costo — Configurazione" />
                    <TextBlock
                        x:Name="txtCount" Margin="16,0,0,0"
                        VerticalAlignment="Center" FontSize="13" Foreground="#6B7280" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Background="#059669"
                            Click="BtnAddGroup_Click" Content="+ Gruppo"
                            Foreground="White" Style="{StaticResource SuccessBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  STATUS BAR  -->
        <Border Padding="16,6" Background="White" BorderBrush="#E4E7EC"
                BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
            <TextBlock x:Name="txtStatus" FontSize="12" Foreground="#6B7280" />
        </Border>

        <!--  MAIN CONTENT  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!--  LEFT PANEL  -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  REPARTI  -->
                <DockPanel Grid.Row="0">
                    <Border Padding="12,8" Background="#F0F4FF"
                            BorderBrush="#E4E7EC" BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Click="BtnAddDepartment_Click"
                                    Content="+" Width="22" Height="22" FontSize="12"
                                    FontWeight="Bold" Background="#E0E7FF" Foreground="#4F6EF7"
                                    BorderThickness="0" Cursor="Hand" ToolTip="Nuovo reparto" />
                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                       Foreground="#4F6EF7" Text="REPARTI — trascina su una sezione"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <StackPanel x:Name="pnlDepartments" Margin="8,6,8,8" />
                </DockPanel>

                <!--  FASI TEMPLATE (non collegate)  -->
                <DockPanel Grid.Row="1">
                    <Border Padding="12,8" Background="#FFF8F0"
                            BorderBrush="#E4E7EC" BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Click="BtnAddPhaseGlobal_Click"
                                    Content="+ Fase"
                                    Height="24" Padding="8,0"
                                    Background="#D9770620" BorderThickness="0"
                                    Foreground="#D97706" FontSize="11" FontWeight="SemiBold"
                                    Cursor="Hand" VerticalAlignment="Center"
                                    ToolTip="Crea nuova fase template" />
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="#D97706" Text="FASI TEMPLATE — trascina su una sezione" />
                                <TextBlock x:Name="txtPhaseCount" Margin="0,2,0,0"
                                           FontSize="11" Foreground="#9CA3AF" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="txtSearchPhase" DockPanel.Dock="Top"
                             Height="28" Margin="8,6,8,4"
                             Padding="6,3" BorderBrush="#D0D5DD" FontSize="12"
                             Tag="Cerca fase..." TextChanged="TxtSearchPhase_TextChanged" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlPhases" Margin="8,2,8,8" />
                    </ScrollViewer>
                </DockPanel>
            </Grid>

            <!--  SPLITTER  -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#E4E7EC" />

            <!--  RIGHT: TREEVIEW  -->
            <DockPanel Grid.Column="2">
                <Border Padding="12,8" Background="#F0FFF4"
                        BorderBrush="#E4E7EC" BorderThickness="0,0,0,1"
                        DockPanel.Dock="Top">
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Foreground="#12B76A" Text="STRUTTURA SEZIONI COSTO" />
                </Border>
                <TreeView x:Name="tvSections" Padding="8"
                          AllowDrop="True" Background="White" BorderThickness="0"
                          DragOver="TvSections_DragOver" Drop="TvSections_Drop" FontSize="13">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="IsExpanded" Value="True" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black" />
                            </Style.Resources>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>

        </Grid>

    </DockPanel>
</Page>
