<Window
    x:Class="ATEC.PM.Client.UserControls.NewChatDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nuova Chat"
    Width="420" Height="480"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border Padding="16,12" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock x:Name="txtError" FontSize="12" Foreground="#EF4444" VerticalAlignment="Center" />
                <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="90" Height="34" Background="#F3F4F6" BorderThickness="0"
                            Click="BtnCancel_Click" Content="Annulla" Cursor="Hand" Foreground="#374151" />
                    <Button Width="90" Height="34" Margin="8,0,0,0" Background="#4F6EF7" BorderThickness="0"
                            Click="BtnCreate_Click" Content="Crea" Cursor="Hand" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>
        <StackPanel Margin="24,16,24,8">
            <TextBlock Text="TITOLO CHAT *" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,4" />
            <TextBox x:Name="txtTitle" Height="32" Padding="8,5" FontSize="13" BorderBrush="#E4E7EC" />

            <TextBlock Text="PARTECIPANTI" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,16,0,6" />
            <TextBlock Text="(Tu sei aggiunto automaticamente)" FontSize="10" Foreground="#9CA3AF" Margin="0,0,0,6" />

            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="pnlEmployees" />
            </ScrollViewer>
        </StackPanel>
    </DockPanel>
</Window>
