<Page
    x:Class="ATEC.PM.Client.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uc="clr-namespace:ATEC.PM.Client.UserControls"
    Background="#F7F8FA">

    <DockPanel>
        <!--  TOOLBAR  -->
        <Border
            Style="{StaticResource ToolbarBorder}"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Click="BtnNew_Click"
                        Content="+ Nuovo"
                        Style="{StaticResource PrimaryBtn}" />
                    <Button
                        Background="#12B76A"
                        Click="BtnImportEasyfatt_Click"
                        Content="📥 Importa Easyfatt"
                        Foreground="White"
                        Style="{StaticResource SuccessBtn}" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <!--  COLUMN SELECTOR  -->
                    <ToggleButton
                        x:Name="btnColumnToggle"
                        Margin="0,0,8,0"
                        Style="{StaticResource ColumnSelectorToggle}" />
                    <Popup
                        AllowsTransparency="True"
                        IsOpen="{Binding IsChecked, ElementName=btnColumnToggle}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=btnColumnToggle}"
                        StaysOpen="False">
                        <Border
                            x:Name="popBorder"
                            RenderTransformOrigin="0.5,0"
                            Style="{StaticResource ColumnSelectorPopup}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="popTranslate" Y="-8" />
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="popBorder"
                                                Storyboard.TargetProperty="Opacity"
                                                From="0"
                                                To="1"
                                                Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="popTranslate"
                                                Storyboard.TargetProperty="Y"
                                                From="-8"
                                                To="0"
                                                Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel x:Name="wpColumns" />
                        </Border>
                    </Popup>

                    <Separator
                        Width="1"
                        Margin="4,0"
                        Background="#E4E7EC" />

                    <Button
                        Click="BtnClearFilters_Click"
                        Content="Reset Filtri"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <uc:DaneaSyncBar x:Name="syncBar" DockPanel.Dock="Top" />

        <!--  STATUS BAR  -->
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <Grid>
                <TextBlock
                    x:Name="txtStatus"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Foreground="#667085"
                    Text="Pronto" />
                <TextBlock
                    HorizontalAlignment="Right"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="#9CA3AF"
                    Text="Filtri: abc = contiene  |  abc* = inizia con  |  *abc = finisce con" />
            </Grid>
        </Border>

        <!--  DATAGRID  -->
        <DataGrid
            x:Name="dgCatalog"
            Margin="16"
            ColumnHeaderHeight="65"
            IsReadOnly="True"
            MouseDoubleClick="Dg_DoubleClick"
            SelectionMode="Single"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.Columns>
                <DataGridTemplateColumn
                    x:Name="colCode"
                    Width="*"
                    MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Codice" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Code"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Medium"
                                Text="{Binding Code}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colDescription"
                    Width="2*"
                    MinWidth="200">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Descrizione" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Desc"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{Binding Description}"
                                TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colSupplier"
                    Width="*"
                    MinWidth="120">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Fornitore" />
                                <ComboBox
                                    Height="28"
                                    Margin="0,4,0,2"
                                    Padding="6,0"
                                    FontSize="12"
                                    IsEditable="True"
                                    Loaded="ComboFilter_Loaded"
                                    SelectionChanged="ComboFilter_Changed"
                                    Tag="Supp" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding SupplierName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colManufacturer"
                    Width="*"
                    MinWidth="120">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Produttore" />
                                <ComboBox
                                    Height="28"
                                    Margin="0,4,0,2"
                                    Padding="6,0"
                                    FontSize="12"
                                    IsEditable="True"
                                    Loaded="ComboFilter_Loaded"
                                    SelectionChanged="ComboFilter_Changed"
                                    Tag="Man" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Manufacturer}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colCategory"
                    Width="*"
                    MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Categoria" />
                                <ComboBox
                                    Height="28"
                                    Margin="0,4,0,2"
                                    Padding="6,0"
                                    FontSize="12"
                                    IsEditable="True"
                                    Loaded="ComboFilter_Loaded"
                                    SelectionChanged="ComboFilter_Changed"
                                    Tag="Cat" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Category}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colUnit"
                    Width="0.5*"
                    MinWidth="50">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,0,0,30"
                                FontWeight="Bold"
                                Foreground="#667085"
                                Text="UdM" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Unit}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colUnitCost"
                    Width="*"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,0,0,30"
                                FontWeight="Bold"
                                Foreground="#667085"
                                Text="Acquisto" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Text="{Binding UnitCost, StringFormat='{}{0:N2} €'}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colListPrice"
                    Width="*"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,0,0,30"
                                FontWeight="Bold"
                                Foreground="#667085"
                                Text="Listino" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Text="{Binding ListPrice, StringFormat='{}{0:N2} €'}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="80" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Click="BtnEdit_Click"
                                    Style="{StaticResource RowEditBtn}" />
                                <Button
                                    Margin="4,0,0,0"
                                    Click="BtnDelete_Click"
                                    Style="{StaticResource RowDeleteBtn}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>