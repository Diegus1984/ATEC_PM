<Page
    x:Class="ATEC.PM.Client.Views.MaterialCategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">
    <DockPanel>

        <!--  TOOLBAR  -->
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#1A1D26"
                        Text="Categorie Materiali" />
                    <TextBlock
                        x:Name="txtCount"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#6B7280" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Height="32"
                        Padding="16,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnAdd_Click"
                        Content="+ Nuova Categoria"
                        Cursor="Hand"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  HEADER COLONNE  -->
        <Border
            Padding="16,6"
            Background="#F9FAFB"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="NOME CATEGORIA" />
                <TextBlock
                    Grid.Column="1"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="MARKUP" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="K VALORE" />
                <TextBlock
                    Grid.Column="3"
                    HorizontalAlignment="Center"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="ORDINE" />
                <TextBlock
                    Grid.Column="4"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="" />
            </Grid>
        </Border>

        <!--  STATUS  -->
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#6B7280" />
        </Border>

        <!--  LISTA  -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="pnlCategories" Margin="16,8,16,16" />
        </ScrollViewer>

    </DockPanel>
</Page>
