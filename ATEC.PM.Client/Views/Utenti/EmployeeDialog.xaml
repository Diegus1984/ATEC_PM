<Window
    x:Class="ATEC.PM.Client.Views.EmployeeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Utente"
    Width="560"
    Height="720"
    Background="#F7F8FA"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ExpHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#374151" />
        </Style>
        <Style x:Key="ExpBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <!--  BOTTOM BUTTONS  -->
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtError"
                    MaxWidth="300"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="12"
                    Foreground="#EF4444"
                    TextWrapping="Wrap" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Height="34"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Cursor="Hand"
                        Foreground="#374151" />
                    <Button
                        x:Name="btnSave"
                        Width="110"
                        Height="34"
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnSave_Click"
                        Content="Salva"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  FORM  -->
        <ScrollViewer Padding="16,12,16,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  ═══ ANAGRAFICA ═══  -->
                <Expander
                    x:Name="expAnagrafica"
                    Margin="0,0,0,8"
                    IsExpanded="True">
                    <Expander.Header>
                        <Border Padding="0,6" Background="Transparent">
                            <TextBlock Style="{StaticResource ExpHeader}" Text="👤  ANAGRAFICA" />
                        </Border>
                    </Expander.Header>
                    <Border Padding="16,4,16,12" Style="{StaticResource ExpBorder}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="NOME *" />
                                    <TextBox x:Name="txtFirstName" Style="{StaticResource FieldInput}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="COGNOME *" />
                                    <TextBox x:Name="txtLastName" Style="{StaticResource FieldInput}" />
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="EMAIL" />
                                    <TextBox x:Name="txtEmail" Style="{StaticResource FieldInput}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="TIPO" />
                                    <ComboBox
                                        x:Name="cmbType"
                                        Height="32"
                                        Padding="8,5"
                                        BorderBrush="#E4E7EC"
                                        FontSize="13">
                                        <ComboBoxItem Content="INTERNAL" IsSelected="True" />
                                        <ComboBoxItem Content="EXTERNAL" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!--  ═══ ACCESSO E RUOLO ═══  -->
                <Expander
                    x:Name="expAccesso"
                    Margin="0,0,0,8"
                    IsExpanded="True">
                    <Expander.Header>
                        <Border Padding="0,6" Background="Transparent">
                            <TextBlock Style="{StaticResource ExpHeader}" Text="🔐  ACCESSO E RUOLO" />
                        </Border>
                    </Expander.Header>
                    <Border Padding="16,8,16,12" Style="{StaticResource ExpBorder}">
                        <StackPanel>
                            <!--  Ruolo  -->
                            <TextBlock Style="{StaticResource FieldLabel}" Text="RUOLO SISTEMA" />
                            <Border
                                Padding="12,8"
                                Background="#F9FAFB"
                                BorderBrush="#E4E7EC"
                                BorderThickness="1">
                                <UniformGrid Columns="2" Rows="2">
                                    <RadioButton
                                        x:Name="rbTech"
                                        Margin="0,3"
                                        Content="TECH — Tecnico operativo"
                                        FontSize="12"
                                        GroupName="Role"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="rbResp"
                                        Margin="0,3"
                                        Content="RESP — Responsabile reparto"
                                        FontSize="12"
                                        GroupName="Role" />
                                    <RadioButton
                                        x:Name="rbPm"
                                        Margin="0,3"
                                        Content="PM — Project Manager"
                                        FontSize="12"
                                        GroupName="Role" />
                                    <RadioButton
                                        x:Name="rbAdmin"
                                        Margin="0,3"
                                        Content="ADMIN — Accesso totale"
                                        FontSize="12"
                                        GroupName="Role" />
                                </UniformGrid>
                            </Border>
                            <!--  Credenziali  -->
                            <TextBlock Style="{StaticResource FieldLabel}" Text="USERNAME" />
                            <TextBox x:Name="txtUsername" Style="{StaticResource FieldInput}" />
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="PASSWORD" />
                                    <PasswordBox
                                        x:Name="txtPassword"
                                        Height="32"
                                        Padding="8,5"
                                        BorderBrush="#E4E7EC"
                                        BorderThickness="1"
                                        FontSize="13" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="CONFERMA PASSWORD" />
                                    <PasswordBox
                                        x:Name="txtPasswordConfirm"
                                        Height="32"
                                        Padding="8,5"
                                        BorderBrush="#E4E7EC"
                                        BorderThickness="1"
                                        FontSize="13" />
                                </StackPanel>
                            </Grid>
                            <TextBlock
                                x:Name="txtPasswordHint"
                                Margin="0,4,0,0"
                                FontSize="11"
                                Foreground="#9CA3AF"
                                Text="Lascia vuoto per non modificare la password" />
                            <!--  Stato  -->
                            <TextBlock Style="{StaticResource FieldLabel}" Text="STATO" />
                            <ComboBox
                                x:Name="cmbStatus"
                                Height="32"
                                Padding="8,5"
                                BorderBrush="#E4E7EC"
                                FontSize="13">
                                <ComboBoxItem Content="ACTIVE" IsSelected="True" />
                                <ComboBoxItem Content="ON_LEAVE" />
                                <ComboBoxItem Content="SICK" />
                                <ComboBoxItem Content="TERMINATED" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </Expander>

                <!--  ═══ REPARTI ═══  -->
                <Expander
                    x:Name="expReparti"
                    Margin="0,0,0,8"
                    IsExpanded="False">
                    <Expander.Header>
                        <Border Padding="0,6" Background="Transparent">
                            <TextBlock Style="{StaticResource ExpHeader}" Text="🏭  REPARTI DI APPARTENENZA" />
                        </Border>
                    </Expander.Header>
                    <Border Padding="16,8,16,12" Style="{StaticResource ExpBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#9CA3AF"
                                    Text="REPARTO" />
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#9CA3AF"
                                    Text="★ RESP." />
                                <TextBlock
                                    Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#9CA3AF"
                                    Text="◆ PRIM." />
                            </Grid>
                            <ItemsControl x:Name="lstDeptMembership">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="28" Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsMember}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Text="{Binding DepartmentName}" />
                                            <CheckBox
                                                Grid.Column="2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsResponsible}"
                                                IsEnabled="{Binding IsMember}" />
                                            <CheckBox
                                                Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsPrimary}"
                                                IsEnabled="{Binding IsMember}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Expander>

                <!--  ═══ COMPETENZE ═══  -->
                <Expander
                    x:Name="expCompetenze"
                    Margin="0,0,0,8"
                    IsExpanded="False">
                    <Expander.Header>
                        <Border Padding="0,6" Background="Transparent">
                            <TextBlock Style="{StaticResource ExpHeader}" Text="⚙️  COMPETENZE TECNICHE" />
                        </Border>
                    </Expander.Header>
                    <Border Padding="16,8,16,12" Style="{StaticResource ExpBorder}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="11"
                                Foreground="#9CA3AF"
                                Text="Reparti su cui è tecnicamente abilitato (anche senza appartenenza formale)" />
                            <ItemsControl x:Name="lstCompetences">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,3">
                                            <CheckBox
                                                Content="{Binding DepartmentName}"
                                                FontSize="13"
                                                IsChecked="{Binding IsEnabled}" />
                                            <TextBox
                                                Height="28"
                                                Margin="22,2,0,0"
                                                Padding="6,4"
                                                BorderBrush="#E4E7EC"
                                                FontSize="11"
                                                IsEnabled="{Binding IsEnabled}"
                                                Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacity}}"
                                                Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="Note specifiche (es. Fanuc R30iB, Siemens S7-1500)" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
