<Window
    x:Class="ATEC.PM.Client.UserControls.CostResourceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi Risorsa"
    Width="600"
    Height="420"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border Padding="16,12" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock x:Name="txtError" VerticalAlignment="Center" FontSize="12" Foreground="#EF4444" />
                <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="90" Height="34" Background="#F3F4F6" BorderThickness="0" Click="BtnCancel_Click" Content="Annulla" Cursor="Hand" Foreground="#374151" />
                    <Button Width="90" Height="34" Margin="8,0,0,0" Background="#4F6EF7" BorderThickness="0" Click="BtnSave_Click" Content="Salva" Cursor="Hand" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>
        <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="NOME RISORSA *" />
                <TextBox x:Name="txtName" Height="32" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="GG. LAVORO" />
                        <TextBox x:Name="txtDays" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="ORE / GIORNO" />
                        <TextBox x:Name="txtHoursDay" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="8" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="COSTO €/H" />
                        <TextBox x:Name="txtCostH" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0" />
                    </StackPanel>
                </Grid>

                <!--  TRASFERTA (visibile solo per DA_CLIENTE)  -->
                <StackPanel x:Name="pnlTrasferta" Margin="0,16,0,0" Visibility="Collapsed">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#D97706" Text="— TRASFERTA —" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="N. VIAGGI" />
                            <TextBox x:Name="txtTrips" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="KM / VIAGGIO" />
                            <TextBox x:Name="txtKm" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="COSTO €/KM" />
                            <TextBox x:Name="txtCostKm" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0.90" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="€ VITTO/GG" />
                            <TextBox x:Name="txtFood" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="80" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="€ HOTEL/GG" />
                            <TextBox x:Name="txtHotel" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="120" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="GG INDENNITÀ" />
                            <TextBox x:Name="txtAllowDays" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="€/GG INDENN." />
                            <TextBox x:Name="txtAllowRate" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="60" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
