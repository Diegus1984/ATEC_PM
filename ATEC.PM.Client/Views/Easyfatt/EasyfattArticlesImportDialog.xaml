<Window
    x:Class="ATEC.PM.Client.Views.EasyfattArticlesImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Importa Articoli da Easyfatt"
    Width="1200"
    Height="700"
    Background="#F7F8FA"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#374151"
                        Text="File .eft:" />
                    <TextBox
                        x:Name="txtFilePath"
                        Width="400"
                        Height="34"
                        Padding="8,6"
                        BorderBrush="#E4E7EC"
                        FontSize="13"
                        Text="C:\ATEC_Commesse\Srl-2020-2021.eft" />
                    <Button
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        Click="BtnLoad_Click"
                        Content="Carica"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnImport"
                        Background="#059669"
                        Click="BtnImport_Click"
                        Content="Importa selezionati"
                        Foreground="White"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Border
            Padding="16,8"
            Background="#F9FAFB"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock
                        x:Name="txtSummary"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#374151"
                        Text="" />
                    <TextBlock
                        Margin="12,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#6B7280"
                        Text="  |  Filtra:" />
                    <RadioButton
                        x:Name="rbAll"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Checked="Filter_Changed"
                        Content="Tutti"
                        IsChecked="True" />
                    <RadioButton
                        x:Name="rbNew"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Checked="Filter_Changed"
                        Content="Nuovi" />
                    <RadioButton
                        x:Name="rbDup"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Checked="Filter_Changed"
                        Content="Duplicati" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#6B7280"
                        Text="Cerca:" />
                    <TextBox
                        x:Name="txtSearch"
                        Width="200"
                        Height="30"
                        Padding="8,4"
                        BorderBrush="#E4E7EC"
                        FontSize="13"
                        TextChanged="TxtSearch_Changed" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtStatus"
                    FontSize="12"
                    Foreground="#6B7280"
                    Text="Inserire il percorso del file .eft e premere Carica" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Height="28"
                        Padding="12,0"
                        Background="#F3F4F6"
                        Click="BtnSelectAll_Click"
                        Content="Seleziona tutti"
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Height="28"
                        Margin="6,0,0,0"
                        Padding="12,0"
                        Background="#F3F4F6"
                        Click="BtnDeselectAll_Click"
                        Content="Deseleziona tutti"
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>
        <DataGrid
            x:Name="dgImport"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            CanUserAddRows="False"
            ColumnHeaderHeight="38"
            FontSize="12"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="False"
            RowHeight="36">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F9FAFB" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="8,0" />
                    <Setter Property="BorderBrush" Value="#E4E7EC" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="DUPLICATO">
                            <Setter Property="Background" Value="#FEF9C3" />
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EEF2FF" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn
                    Width="40"
                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                    Header="Sel." />
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding Code}"
                    Header="Codice"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Description}"
                    Header="Descrizione"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Category}"
                    Header="Categoria"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding Unit}"
                    Header="UdM"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding UnitCost, StringFormat='{}{0:N4}'}"
                    Header="Prezzo Acq."
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding ResolvedSupplierName}"
                    Header="Fornitore"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Manufacturer}"
                    Header="Produttore"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Status}"
                    Header="Stato"
                    IsReadOnly="True" />
                <DataGridComboBoxColumn
                    Width="90"
                    Header="Azione"
                    SelectedValueBinding="{Binding Action, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array xmlns:sys="clr-namespace:System;assembly=mscorlib" Type="sys:String">
                            <sys:String>INSERT</sys:String>
                            <sys:String>UPDATE</sys:String>
                            <sys:String>SKIP</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
