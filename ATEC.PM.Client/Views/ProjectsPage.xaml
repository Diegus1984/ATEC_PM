<Page
    x:Class="ATEC.PM.Client.Views.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  LEFT: Tree Panel  -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <!--  Toolbar  -->
                <Border
                    Padding="12,8"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <Button
                            Background="#4F6EF7"
                            Click="BtnNew_Click"
                            Content="+ Nuova"
                            Foreground="White"
                            Style="{StaticResource FlatBtn}" />
                        <Button
                            HorizontalAlignment="Right"
                            Background="#F3F4F6"
                            Click="BtnRefresh_Click"
                            Content="Aggiorna"
                            DockPanel.Dock="Right"
                            Foreground="#374151"
                            Style="{StaticResource FlatBtn}" />
                    </DockPanel>
                </Border>

                <!--  Search  -->
                <Border
                    Padding="12,8"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <Grid>
                        <TextBox
                            x:Name="txtSearch"
                            Height="32"
                            Padding="8,5"
                            BorderBrush="#E4E7EC"
                            FontSize="13"
                            TextChanged="TxtSearch_TextChanged" />
                        <TextBlock
                            x:Name="txtSearchPlaceholder"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#9CA3AF"
                            IsHitTestVisible="False"
                            Text="Cerca commessa o cliente..." />
                    </Grid>
                </Border>

                <!--  Status  -->
                <Border
                    Padding="12,6"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <TextBlock
                        x:Name="txtStatus"
                        FontSize="11"
                        Foreground="#9CA3AF"
                        Text="Caricamento..." />
                </Border>

                <!--  TreeView  -->
                <TreeView
                    x:Name="treeProjects"
                    Padding="4"
                    Background="White"
                    BorderThickness="0"
                    SelectedItemChanged="Tree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,4" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>
        </Border>

        <!--  RIGHT: Content  -->
        <Border Grid.Column="1">
            <DockPanel>
                <Border
                    Padding="24,12"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            x:Name="txtSectionTitle"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="Seleziona una commessa" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnAction"
                                Height="32"
                                Padding="16,0"
                                Background="#4F6EF7"
                                BorderThickness="0"
                                Click="BtnAction_Click"
                                Content=""
                                Cursor="Hand"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ScrollViewer x:Name="scrollContent" Padding="24,16">
                    <ContentControl x:Name="SectionContent" />
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>