<Page x:Class="ATEC.PM.Client.Views.ProjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">

    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Tree Panel -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Toolbar -->
                <Border DockPanel.Dock="Top" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" Padding="12,8">
                    <DockPanel>
                        <Button Content="+ Nuova" Background="#4F6EF7" Foreground="White" Style="{StaticResource FlatBtn}" Click="BtnNew_Click"/>
                        <Button Content="Aggiorna" Background="#F3F4F6" Foreground="#374151" Style="{StaticResource FlatBtn}" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="BtnRefresh_Click"/>
                    </DockPanel>
                </Border>

                <!-- Search -->
                <Border DockPanel.Dock="Top" Padding="12,8" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBox x:Name="txtSearch" Height="32" Padding="8,5" FontSize="13" BorderBrush="#E4E7EC" TextChanged="TxtSearch_TextChanged"/>
                        <TextBlock x:Name="txtSearchPlaceholder" Text="Cerca commessa o cliente..." Foreground="#9CA3AF" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Status -->
                <Border DockPanel.Dock="Bottom" Padding="12,6" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="txtStatus" Text="Caricamento..." FontSize="11" Foreground="#9CA3AF"/>
                </Border>

                <!-- TreeView -->
                <TreeView x:Name="treeProjects" BorderThickness="0" Background="White" Padding="4"
                          SelectedItemChanged="Tree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,4"/>
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- RIGHT: Content -->
        <Border Grid.Column="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" Padding="24,12">
                    <DockPanel>
                        <TextBlock x:Name="txtSectionTitle" Text="Seleziona una commessa" FontSize="18" FontWeight="Bold" Foreground="#1A1D26"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="btnAction" Content="" Visibility="Collapsed" Height="32" Padding="16,0"
                                    Background="#4F6EF7" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand" Click="BtnAction_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ScrollViewer x:Name="scrollContent" Padding="24,16">
                    <ContentControl x:Name="SectionContent"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>