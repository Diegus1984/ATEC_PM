<Window x:Class="ATEC.PM.Client.Views.CredentialsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Imposta Credenziali" Width="400" MinHeight="280"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F7F8FA">

    <Border Margin="20" Background="White" BorderBrush="#E4E7EC" BorderThickness="1" Padding="20">
        <StackPanel>
            <TextBlock Text="Imposta credenziali di accesso" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Username" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
            <TextBox x:Name="txtUsername" Height="32" FontSize="13" Padding="8,4" 
                     BorderBrush="#E4E7EC" BorderThickness="1"/>

            <TextBlock Text="Password" FontSize="12" Foreground="#64748B" Margin="0,12,0,4"/>
            <PasswordBox x:Name="txtPassword" Height="32" FontSize="13" Padding="8,4"
                         BorderBrush="#E4E7EC" BorderThickness="1"/>

            <TextBlock Text="Conferma Password" FontSize="12" Foreground="#64748B" Margin="0,12,0,4"/>
            <PasswordBox x:Name="txtPasswordConfirm" Height="32" FontSize="13" Padding="8,4"
                         BorderBrush="#E4E7EC" BorderThickness="1"/>

            <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Annulla" Width="80" Height="32" Click="BtnCancel_Click"
                        Background="White" BorderBrush="#E4E7EC" BorderThickness="1" Cursor="Hand"/>
                <Button x:Name="btnSave" Content="Salva" Width="80" Height="32" Margin="8,0,0,0"
                        Click="BtnSave_Click" Background="#4F6EF7" Foreground="White" 
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>