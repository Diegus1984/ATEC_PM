<Window
    x:Class="ATEC.PM.Client.Views.CredentialsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Imposta Credenziali"
    Width="400"
    MinHeight="280"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Border
        Margin="20"
        Padding="20"
        Background="White"
        BorderBrush="#E4E7EC"
        BorderThickness="1">
        <StackPanel>
            <TextBlock
                Margin="0,0,0,16"
                FontSize="14"
                FontWeight="SemiBold"
                Text="Imposta credenziali di accesso" />

            <TextBlock
                Margin="0,0,0,4"
                FontSize="12"
                Foreground="#64748B"
                Text="Username" />
            <TextBox
                x:Name="txtUsername"
                Height="32"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                FontSize="13" />

            <TextBlock
                Margin="0,12,0,4"
                FontSize="12"
                Foreground="#64748B"
                Text="Password" />
            <PasswordBox
                x:Name="txtPassword"
                Height="32"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                FontSize="13" />

            <TextBlock
                Margin="0,12,0,4"
                FontSize="12"
                Foreground="#64748B"
                Text="Conferma Password" />
            <PasswordBox
                x:Name="txtPasswordConfirm"
                Height="32"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                FontSize="13" />

            <TextBlock
                x:Name="txtError"
                Margin="0,8,0,0"
                FontSize="11"
                Foreground="#EF4444"
                TextWrapping="Wrap" />

            <StackPanel
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Height="32"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand" />
                <Button
                    x:Name="btnSave"
                    Width="80"
                    Height="32"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Cursor="Hand"
                    Foreground="White" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>