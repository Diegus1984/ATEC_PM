<Window x:Class="ATEC.PM.Client.Views.EmployeeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dipendente" Width="500" Height="580"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F8FA">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- BOTTOM BUTTONS -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" Width="90" Height="34" Background="#F3F4F6" Foreground="#374151"
                        BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button x:Name="btnSave" Content="Salva" Width="90" Height="34" Background="#4F6EF7" Foreground="White"
                        FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>

        <!-- FORM -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
            <StackPanel>
                <!-- Row 1: Badge + Tipo -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BADGE" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtBadge" Style="{StaticResource FieldInput}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TIPO" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbType" Height="34" FontSize="13" Padding="8,6" BorderBrush="#E4E7EC">
                            <ComboBoxItem Content="INTERNAL" IsSelected="True"/>
                            <ComboBoxItem Content="EXTERNAL"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Nome + Cognome -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NOME *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtFirstName" Style="{StaticResource FieldInput}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="COGNOME *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtLastName" Style="{StaticResource FieldInput}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3: Email + Phone -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource FieldInput}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TELEFONO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtPhone" Style="{StaticResource FieldInput}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 4: Costo + Ore -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="COSTO ORARIO (€)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtHourlyCost" Style="{StaticResource FieldInput}" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ORE SETTIMANALI" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtWeeklyHours" Style="{StaticResource FieldInput}" Text="40"/>
                    </StackPanel>
                </Grid>

                <!-- Row 5: HireDate + Status -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DATA ASSUNZIONE" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="dpHireDate" Height="34" FontSize="13" BorderBrush="#E4E7EC"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="STATO" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbStatus" Height="34" FontSize="13" Padding="8,6" BorderBrush="#E4E7EC">
                            <ComboBoxItem Content="ACTIVE" IsSelected="True"/>
                            <ComboBoxItem Content="ON_LEAVE"/>
                            <ComboBoxItem Content="SICK"/>
                            <ComboBoxItem Content="TERMINATED"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <TextBlock Text="NOTE" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtNotes" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                         Padding="8,6" FontSize="13" BorderBrush="#E4E7EC" VerticalScrollBarVisibility="Auto"/>

                <!-- Error -->
                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
