<Window
    x:Class="ATEC.PM.Client.Views.EmployeeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Dipendente"
    Width="500"
    Height="580"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <!--  BOTTOM BUTTONS  -->
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="90"
                    Height="34"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand"
                    Foreground="#374151" />
                <Button
                    x:Name="btnSave"
                    Width="90"
                    Height="34"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </StackPanel>
        </Border>

        <!--  FORM  -->
        <ScrollViewer Padding="24,8,24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  Row 1: Badge + Tipo  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="BADGE" />
                        <TextBox x:Name="txtBadge" Style="{StaticResource FieldInput}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="TIPO" />
                        <ComboBox
                            x:Name="cmbType"
                            Height="34"
                            Padding="8,6"
                            BorderBrush="#E4E7EC"
                            FontSize="13">
                            <ComboBoxItem Content="INTERNAL" IsSelected="True" />
                            <ComboBoxItem Content="EXTERNAL" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!--  Row 2: Nome + Cognome  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="NOME *" />
                        <TextBox x:Name="txtFirstName" Style="{StaticResource FieldInput}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="COGNOME *" />
                        <TextBox x:Name="txtLastName" Style="{StaticResource FieldInput}" />
                    </StackPanel>
                </Grid>

                <!--  Row 3: Email + Phone  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="EMAIL" />
                        <TextBox x:Name="txtEmail" Style="{StaticResource FieldInput}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="TELEFONO" />
                        <TextBox x:Name="txtPhone" Style="{StaticResource FieldInput}" />
                    </StackPanel>
                </Grid>

                <!--  Row 4: Costo + Ore  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="COSTO ORARIO (€)" />
                        <TextBox
                            x:Name="txtHourlyCost"
                            Style="{StaticResource FieldInput}"
                            Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="ORE SETTIMANALI" />
                        <TextBox
                            x:Name="txtWeeklyHours"
                            Style="{StaticResource FieldInput}"
                            Text="40" />
                    </StackPanel>
                </Grid>

                <!--  Row 5: HireDate + Status  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="DATA ASSUNZIONE" />
                        <DatePicker
                            x:Name="dpHireDate"
                            Height="34"
                            BorderBrush="#E4E7EC"
                            FontSize="13" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="STATO" />
                        <ComboBox
                            x:Name="cmbStatus"
                            Height="34"
                            Padding="8,6"
                            BorderBrush="#E4E7EC"
                            FontSize="13">
                            <ComboBoxItem Content="ACTIVE" IsSelected="True" />
                            <ComboBoxItem Content="ON_LEAVE" />
                            <ComboBoxItem Content="SICK" />
                            <ComboBoxItem Content="TERMINATED" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!--  Notes  -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="NOTE" />
                <TextBox
                    x:Name="txtNotes"
                    Height="60"
                    Padding="8,6"
                    AcceptsReturn="True"
                    BorderBrush="#E4E7EC"
                    FontSize="13"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />

                <!--  Error  -->
                <TextBlock
                    x:Name="txtError"
                    Margin="0,12,0,0"
                    FontSize="12"
                    Foreground="#EF4444"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
