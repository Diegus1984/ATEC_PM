<UserControl
    x:Class="ATEC.PM.Client.Views.ProjectCostingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">
    <DockPanel>

        <!--  TOOLBAR  -->
        <Border
            Padding="12,8"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <RadioButton x:Name="tabRisorse" Checked="Tab_Changed" Content="  Impegno Risorse  "
                        FontSize="13" FontWeight="SemiBold" GroupName="CostTabs" IsChecked="True"
                        Style="{StaticResource {x:Type ToggleButton}}" />
                    <RadioButton x:Name="tabMateriali" Margin="8,0,0,0" Checked="Tab_Changed" Content="  Materiali  "
                        FontSize="13" FontWeight="SemiBold" GroupName="CostTabs"
                        Style="{StaticResource {x:Type ToggleButton}}" />
                    <RadioButton x:Name="tabRiepilogo" Margin="8,0,0,0" Checked="Tab_Changed" Content="  Riepilogo e Prezzi  "
                        FontSize="13" FontWeight="SemiBold" GroupName="CostTabs"
                        Style="{StaticResource {x:Type ToggleButton}}" />
                </StackPanel>
                <TextBlock x:Name="txtStatus" HorizontalAlignment="Right" VerticalAlignment="Center"
                    DockPanel.Dock="Right" FontSize="12" Foreground="#6B7280" />
            </DockPanel>
        </Border>

        <!--  INIT PANEL  -->
        <StackPanel x:Name="pnlInit" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            <TextBlock HorizontalAlignment="Center" FontSize="16" Foreground="#6B7280"
                Text="Configurazione costi non ancora inizializzata." />
            <Button Width="200" Height="36" Margin="0,16,0,0" Background="#4F6EF7" BorderThickness="0"
                Click="BtnInit_Click" Content="Inizializza Configurazione" Cursor="Hand"
                FontSize="14" FontWeight="SemiBold" Foreground="White" />
        </StackPanel>

        <!--  CONTENT  -->
        <ScrollViewer x:Name="scrollContent" Padding="16" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
            <StackPanel x:Name="pnlContent" />
        </ScrollViewer>

    </DockPanel>
</UserControl>
