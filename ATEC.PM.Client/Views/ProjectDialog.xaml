<Window
    x:Class="ATEC.PM.Client.Views.ProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Commessa"
    Width="540"
    Height="620"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="90"
                    Height="34"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand"
                    Foreground="#374151" />
                <Button
                    x:Name="btnSave"
                    Width="90"
                    Height="34"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </StackPanel>
        </Border>

        <ScrollViewer Padding="24,8,24,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="CODICE *" />
                        <TextBox x:Name="txtCode" Style="{StaticResource Inp}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="TITOLO *" />
                        <TextBox x:Name="txtTitle" Style="{StaticResource Inp}" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="CLIENTE *" />
                        <ComboBox
                            x:Name="cmbCustomer"
                            Height="34"
                            DisplayMemberPath="Name"
                            FontSize="13"
                            SelectedValuePath="Id" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="PROJECT MANAGER *" />
                        <ComboBox
                            x:Name="cmbPm"
                            Height="34"
                            DisplayMemberPath="Name"
                            FontSize="13"
                            SelectedValuePath="Id" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="DATA INIZIO" />
                        <DatePicker
                            x:Name="dpStart"
                            Height="34"
                            FontSize="13" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="DATA FINE PREVISTA" />
                        <DatePicker
                            x:Name="dpEnd"
                            Height="34"
                            FontSize="13" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="RICAVO (€)" />
                        <TextBox
                            x:Name="txtRevenue"
                            Style="{StaticResource Inp}"
                            Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="BUDGET (€)" />
                        <TextBox
                            x:Name="txtBudget"
                            Style="{StaticResource Inp}"
                            Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource Lbl}" Text="ORE PREVISTE" />
                        <TextBox
                            x:Name="txtHours"
                            Style="{StaticResource Inp}"
                            Text="0" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="STATO" />
                        <ComboBox
                            x:Name="cmbStatus"
                            Height="34"
                            FontSize="13">
                            <ComboBoxItem Content="DRAFT" IsSelected="True" />
                            <ComboBoxItem Content="ACTIVE" />
                            <ComboBoxItem Content="ON_HOLD" />
                            <ComboBoxItem Content="COMPLETED" />
                            <ComboBoxItem Content="CANCELLED" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="PRIORITA" />
                        <ComboBox
                            x:Name="cmbPriority"
                            Height="34"
                            FontSize="13">
                            <ComboBoxItem Content="LOW" />
                            <ComboBoxItem Content="MEDIUM" IsSelected="True" />
                            <ComboBoxItem Content="HIGH" />
                            <ComboBoxItem Content="CRITICAL" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource Lbl}" Text="PATH SERVER" />
                <TextBox x:Name="txtServerPath" Style="{StaticResource Inp}" />

                <TextBlock Style="{StaticResource Lbl}" Text="NOTE" />
                <TextBox
                    x:Name="txtNotes"
                    Height="60"
                    Padding="8,6"
                    AcceptsReturn="True"
                    BorderBrush="#E4E7EC"
                    FontSize="13"
                    TextWrapping="Wrap" />

                <CheckBox
                    x:Name="chkDefaultPhases"
                    Margin="0,16,0,0"
                    Content="Crea fasi di default"
                    FontSize="13"
                    IsChecked="True" />

                <TextBlock
                    x:Name="txtError"
                    Margin="0,12,0,0"
                    FontSize="12"
                    Foreground="#EF4444"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
