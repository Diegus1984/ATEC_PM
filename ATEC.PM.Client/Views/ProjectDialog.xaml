<Window x:Class="ATEC.PM.Client.Views.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commessa" Width="540" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F8FA">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/><Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="34"/><Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="BorderBrush" Value="#E4E7EC"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" Width="90" Height="34" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button x:Name="btnSave" Content="Salva" Width="90" Height="34" Background="#4F6EF7" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer Padding="24,8,24,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CODICE *" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtCode" Style="{StaticResource Inp}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TITOLO *" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtTitle" Style="{StaticResource Inp}"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CLIENTE *" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbCustomer" Height="34" FontSize="13" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PROJECT MANAGER *" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbPm" Height="34" FontSize="13" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DATA INIZIO" Style="{StaticResource Lbl}"/>
                        <DatePicker x:Name="dpStart" Height="34" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DATA FINE PREVISTA" Style="{StaticResource Lbl}"/>
                        <DatePicker x:Name="dpEnd" Height="34" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="RICAVO (€)" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtRevenue" Style="{StaticResource Inp}" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="BUDGET (€)" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtBudget" Style="{StaticResource Inp}" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="ORE PREVISTE" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtHours" Style="{StaticResource Inp}" Text="0"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="STATO" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbStatus" Height="34" FontSize="13">
                            <ComboBoxItem Content="DRAFT" IsSelected="True"/>
                            <ComboBoxItem Content="ACTIVE"/>
                            <ComboBoxItem Content="ON_HOLD"/>
                            <ComboBoxItem Content="COMPLETED"/>
                            <ComboBoxItem Content="CANCELLED"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PRIORITA" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbPriority" Height="34" FontSize="13">
                            <ComboBoxItem Content="LOW"/>
                            <ComboBoxItem Content="MEDIUM" IsSelected="True"/>
                            <ComboBoxItem Content="HIGH"/>
                            <ComboBoxItem Content="CRITICAL"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="PATH SERVER" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="txtServerPath" Style="{StaticResource Inp}"/>

                <TextBlock Text="NOTE" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="txtNotes" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" FontSize="13" BorderBrush="#E4E7EC"/>

                <CheckBox x:Name="chkDefaultPhases" Content="Crea fasi di default" IsChecked="True" Margin="0,16,0,0" FontSize="13"/>

                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
