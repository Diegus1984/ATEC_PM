<Page
    x:Class="ATEC.PM.Client.Views.CustomersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="800"
    Background="#F7F8FA">

    <DockPanel>
        <Border
            Padding="20,15"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="btnNew"
                        Background="#2E90FA"
                        Click="BtnNew_Click"
                        Content="+ Nuovo Cliente"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />

                    <Button
                        x:Name="btnEdit"
                        Click="BtnEdit_Click"
                        Content="Modifica"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />

                    <Button
                        x:Name="btnDelete"
                        Background="#FEF3F2"
                        BorderBrush="#FECDCA"
                        Click="BtnDelete_Click"
                        Content="Elimina"
                        Foreground="#B42318"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />

                    <Separator
                        Width="1"
                        Margin="5,0"
                        Background="#E4E7EC" />

                    <Button
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnClearFilters_Click"
                        Content="Pulisci Filtri"
                        Foreground="#667085"
                        Style="{StaticResource FlatBtn}" />

                    <Button
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>

                <Button
                    HorizontalAlignment="Right"
                    Background="#12B76A"
                    Click="BtnImportEasyfatt_Click"
                    Content="Importa da Easyfatt"
                    Foreground="White"
                    Style="{StaticResource FlatBtn}" />
            </Grid>
        </Border>

        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#667085"
                Text="Pronto" />
        </Border>

        <DataGrid
            x:Name="dgCustomers"
            Margin="20"
            IsReadOnly="True"
            MouseDoubleClick="Dg_DoubleClick"
            SelectionChanged="Dg_SelectionChanged"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*" MinWidth="150">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Ragione Sociale" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Name"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Medium"
                                Text="{Binding CompanyName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="140" MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Referente" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Contact"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding ContactName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="140" MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="P.IVA" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Vat"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding VatNumber}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="180" MinWidth="120">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Email" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Email"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Email}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="120"
                    MinWidth="80"
                    Binding="{Binding Phone}"
                    Header="Telefono" />
                <DataGridTextColumn
                    Width="120"
                    MinWidth="80"
                    Binding="{Binding Pec}"
                    Header="PEC" />
                <DataGridTextColumn
                    Width="100"
                    MinWidth="70"
                    Binding="{Binding FiscalCode}"
                    Header="C.F." />
                <DataGridTextColumn
                    Width="80"
                    MinWidth="60"
                    Binding="{Binding SdiCode}"
                    Header="SDI" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
