<Page
    x:Class="ATEC.PM.Client.Views.EmployeesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <DockPanel>
        <!--  TOOLBAR  -->
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        Background="#4F6EF7"
                        Click="BtnNew_Click"
                        Content="+ Nuovo"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnEdit"
                        Margin="8,0,0,0"
                        Background="#F3F4F6"
                        Click="BtnEdit_Click"
                        Content="Modifica"
                        Foreground="#374151"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnDelete"
                        Margin="8,0,0,0"
                        Background="#FEE2E2"
                        Click="BtnDelete_Click"
                        Content="Elimina"
                        Foreground="#DC2626"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <TextBox
                        x:Name="txtSearch"
                        Width="200"
                        Height="34"
                        Padding="8,6"
                        BorderBrush="#E4E7EC"
                        Text=""
                        TextChanged="TxtSearch_TextChanged" />
                    <TextBlock
                        x:Name="txtSearchPlaceholder"
                        Margin="-190,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#9CA3AF"
                        IsHitTestVisible="False"
                        Text="Cerca..." />
                    <Button
                        Margin="8,0,0,0"
                        Background="#F3F4F6"
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  STATUS BAR  -->
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#6B7280"
                Text="Caricamento..." />
        </Border>

        <!--  DATAGRID  -->
        <DataGrid
            x:Name="dgEmployees"
            Margin="0"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            ColumnHeaderHeight="40"
            FontFamily="Segoe UI"
            FontSize="13"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="True"
            MouseDoubleClick="DgEmployees_DoubleClick"
            RowHeight="40"
            SelectionChanged="DgEmployees_SelectionChanged"
            SelectionMode="Single">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F9FAFB" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderBrush" Value="#E4E7EC" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EEF2FF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F9FAFB" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#1A1D26" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding BadgeNumber}"
                    Header="Badge" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding FullName}"
                    Header="Nome Completo" />
                <DataGridTextColumn
                    Width="180"
                    Binding="{Binding Email}"
                    Header="Email" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Phone}"
                    Header="Telefono" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding EmpType}"
                    Header="Tipo" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding Status}"
                    Header="Stato" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding HourlyCost, StringFormat='{}{0:N2} €'}"
                    Header="Costo/h" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding WeeklyHours}"
                    Header="Ore/sett" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
