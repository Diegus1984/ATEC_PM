<UserControl
    x:Class="ATEC.PM.Client.Views.BudgetVsCosting.BudgetVsActualControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ATEC.PM.Client.Views.BudgetVsCosting"
    Background="#F7F8FA">

    <UserControl.Resources>
        <Style x:Key="BvaColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="BvaCell" TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <!--  ═══ DataGrid PREVENTIVO ═══  -->
        <DataTemplate x:Key="BudgetGridTemplate">
            <DataGrid
                AutoGenerateColumns="False" BorderThickness="0"
                CanUserAddRows="False" CanUserDeleteRows="False"
                CanUserReorderColumns="False" CanUserResizeRows="False"
                CellStyle="{StaticResource BvaCell}" ColumnHeaderHeight="26"
                ColumnHeaderStyle="{StaticResource BvaColumnHeader}" FontSize="11"
                GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                HorizontalGridLinesBrush="#F3F4F6" IsReadOnly="True"
                ItemsSource="{Binding BudgetResources}" RowHeight="28" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding ResourceName}" Header="RISORSA" />
                    <DataGridTextColumn Width="40" Binding="{Binding WorkDays, StringFormat=F0}" Header="GG" />
                    <DataGridTextColumn Width="40" Binding="{Binding HoursPerDay, StringFormat=F0}" Header="H/G" />
                    <DataGridTextColumn Width="50" Binding="{Binding TotalHours, StringFormat=F1}" Header="ORE" />
                    <DataGridTextColumn Width="50" Binding="{Binding HourlyCost, StringFormat=F2}" Header="€/H" />
                    <DataGridTextColumn Width="65" Binding="{Binding TotalCost, StringFormat=N2}" Header="COSTO €" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <!--  ═══ CONSUNTIVO: Expander per dipendente ═══  -->
        <DataTemplate x:Key="ActualGridTemplate">
            <ItemsControl ItemsSource="{Binding ActualEmployees}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:BvaActualEmployeeVM}">
                        <Border Margin="0,0,0,2" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <!--  Header dipendente  -->
                                <Grid Background="#FAFBFC" Cursor="Hand" MouseLeftButtonDown="EmployeeRow_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="55" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="4,4,0,4" Orientation="Horizontal">
                                        <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" FontSize="9"
                                                   Foreground="#9CA3AF" RenderTransformOrigin="0.5,0.5" Text="▶">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource BoolToAngle}}" />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <TextBlock VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1A1D26"
                                                   Text="{Binding EmployeeName}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" FontSize="11" FontWeight="SemiBold" Foreground="#1A1D26">
                                        <Run Text="{Binding TotalHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h" /></TextBlock>
                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" FontSize="11" Foreground="#6B7280">
                                        <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </Grid>

                                <!--  Dettaglio timbrature  -->
                                <DataGrid AutoGenerateColumns="False" BorderThickness="0"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          CanUserReorderColumns="False" CanUserResizeRows="False"
                                          CellStyle="{StaticResource BvaCell}" ColumnHeaderHeight="24"
                                          ColumnHeaderStyle="{StaticResource BvaColumnHeader}"
                                          FontSize="11" GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column" HorizontalGridLinesBrush="#F3F4F6"
                                          IsReadOnly="True" ItemsSource="{Binding Details}"
                                          RowHeight="26" SelectionMode="Single"
                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="80" Binding="{Binding WorkDate, StringFormat=dd/MM/yyyy}" Header="DATA" />
                                        <DataGridTextColumn Width="*" Binding="{Binding PhaseName}" Header="CAUSALE" />
                                        <DataGridTextColumn Width="55" Binding="{Binding EntryType}" Header="TIPO" />
                                        <DataGridTextColumn Width="45" Binding="{Binding Hours, StringFormat=F1}" Header="ORE" />
                                        <DataGridTextColumn Width="65" Binding="{Binding TotalCost, StringFormat=N2}" Header="COSTO €" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <!--  ═══ SEZIONE: card collassabile ▶ ═══  -->
        <DataTemplate x:Key="SectionTemplate" DataType="{x:Type local:BvaSectionVM}">
            <Border Margin="0,0,0,2" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                <StackPanel>

                    <!--  Header sezione  -->
                    <Grid Background="#FAFBFC" Cursor="Hand" MouseLeftButtonDown="SectionRow_Click">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="12,8,0,8" Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="9"
                                       Foreground="#9CA3AF" RenderTransformOrigin="0.5,0.5" Text="▶">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1A1D26" Text="{Binding SectionName}" />
                        </StackPanel>

                        <TextBlock Grid.Column="1" Margin="0,0,8,0" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" FontSize="12" Foreground="#6B7280">
                            <Run Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h" /></TextBlock>

                        <TextBlock Grid.Column="2" Margin="0,0,8,0" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#4F6EF7">
                            <Run Text="{Binding ActualHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h" /></TextBlock>

                        <Border Grid.Column="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="{Binding TypeColor, Converter={StaticResource HexToAlphaBrush}, ConverterParameter=20}">
                            <TextBlock FontSize="9" FontWeight="Bold"
                                       Foreground="{Binding TypeColor, Converter={StaticResource HexToBrush}}"
                                       Text="{Binding TypeLabel}" />
                        </Border>

                        <TextBlock Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding DeltaColor, Converter={StaticResource HexToBrush}}"
                                   Text="{Binding DeltaText}"
                                   Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}" />
                    </Grid>

                    <!--  Dettaglio split (collassabile)  -->
                    <Border Padding="8,4,8,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  SX: Preventivo  -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,4" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#6B7280" Text="RISORSE PIANIFICATE" />
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource BudgetGridTemplate}"
                                                    Visibility="{Binding HasBudget, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Margin="4,4,0,0" FontSize="11" FontStyle="Italic" Foreground="#9CA3AF"
                                               Text="Nessuna risorsa pianificata">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasBudget}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#E4E7EC" VerticalAlignment="Stretch" />

                                <!--  DX: Consuntivo  -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,4" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#6B7280" Text="ORE VERSATE PER CAUSALE" />
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ActualGridTemplate}"
                                                    Visibility="{Binding HasActual, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Margin="4,4,0,0" FontSize="11" FontStyle="Italic" Foreground="#9CA3AF"
                                               Text="Nessuna ora versata">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasActual}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <!--  Subtotale sezione — barra unica allineata  -->
                            <Border Margin="0,4,0,0" Padding="8,6" Background="#F9FAFB"
                                    BorderBrush="#E4E7EC" BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" Foreground="#1A1D26" Margin="4,0,0,0">
                                        <Run Text="Prev: " /><Run Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" />
                                        <Run Text=" h  —  " /><Run Text="{Binding BudgetCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                    <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Foreground="#4F6EF7" Margin="4,0,0,0">
                                        <Run Text="Cons: " /><Run Text="{Binding ActualHours, StringFormat=F1, Mode=OneWay}" />
                                        <Run Text=" h  —  " /><Run Text="{Binding ActualCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TextBlock x:Name="txtLoading" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14" Foreground="#9CA3AF" Text="Caricamento..." />

        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="#9CA3AF"
                   Text="Nessun dato di preventivazione disponibile. Configurare prima la commessa."
                   Visibility="{Binding ShowEmpty, Converter={StaticResource BoolToVis}}" />

        <DockPanel Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}">

            <Border Padding="12,6" Background="#F9FAFB" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" DockPanel.Dock="Top">
                <TextBlock FontSize="12" Foreground="#6B7280" Text="{Binding StatusText}" />
            </Border>

            <Border Padding="12,4" Background="#F9FAFB" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" DockPanel.Dock="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="65" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="12,0,0,0" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="SEZIONE" />
                    <TextBlock Grid.Column="1" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="PREVENTIVO" />
                    <TextBlock Grid.Column="2" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="CONSUNTIVO" />
                    <TextBlock Grid.Column="3" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="TIPO" />
                    <TextBlock Grid.Column="4" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="DELTA" />
                </Grid>
            </Border>

            <Border Background="#1A1D26" DockPanel.Dock="Bottom" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="PREVENTIVO  " />
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="White" Text="{Binding TotalBudgetHours, StringFormat=F1}" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="  h     " />
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="White" Text="{Binding TotalBudgetCost, StringFormat=N2}" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="  €" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="CONSUNTIVO  " />
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="White" Text="{Binding TotalActualHours, StringFormat=F1}" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="  h     " />
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="White" Text="{Binding TotalActualCost, StringFormat=N2}" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="  €" />
                    </StackPanel>
                    <TextBlock Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"
                               Foreground="{Binding TotalDeltaColor, Converter={StaticResource HexToBrush}}" Text="{Binding TotalDeltaText}" />
                </Grid>
            </Border>

            <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:BvaGroupVM}">
                            <Expander Margin="0,8,0,0" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                <Expander.Style>
                                    <Style BasedOn="{StaticResource SmoothExpander}" TargetType="Expander" />
                                </Expander.Style>
                                <Expander.Header>
                                    <Border Padding="12,6" Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                        <DockPanel>
                                            <TextBlock VerticalAlignment="Center" DockPanel.Dock="Right" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="#C8FFFFFF">
                                                <Run Text="Prev. " /><Run Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h / " />
                                                <Run Text="{Binding BudgetCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €  →  Cons. " />
                                                <Run Text="{Binding ActualHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h / " />
                                                <Run Text="{Binding ActualCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                            <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold"
                                                       Foreground="White" Text="{Binding GroupName}" />
                                        </DockPanel>
                                    </Border>
                                </Expander.Header>
                                <ItemsControl ItemTemplate="{StaticResource SectionTemplate}" ItemsSource="{Binding Sections}" />
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>