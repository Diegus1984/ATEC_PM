<UserControl
    x:Class="ATEC.PM.Client.Views.BudgetVsCosting.BudgetVsActualControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ATEC.PM.Client.Views.BudgetVsCosting"
    Background="#F7F8FA">

    <UserControl.Resources>
        <Style x:Key="BvaColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="BvaCell" TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="BvaCellClickable" TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  ═══ DataGrid PREVENTIVO ═══  -->
        <DataTemplate x:Key="BudgetGridTemplate">
            <DataGrid
                AutoGenerateColumns="False"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeRows="False"
                CellStyle="{StaticResource BvaCell}"
                ColumnHeaderHeight="26"
                ColumnHeaderStyle="{StaticResource BvaColumnHeader}"
                FontSize="11"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#F3F4F6"
                IsReadOnly="True"
                ItemsSource="{Binding BudgetResources}"
                RowHeight="28"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ResourceName}"
                        Header="RISORSA" />
                    <DataGridTextColumn
                        Width="40"
                        Binding="{Binding WorkDays, StringFormat=F0}"
                        Header="GG" />
                    <DataGridTextColumn
                        Width="40"
                        Binding="{Binding HoursPerDay, StringFormat=F0}"
                        Header="H/G" />
                    <DataGridTextColumn
                        Width="50"
                        Binding="{Binding TotalHours, StringFormat=F1}"
                        Header="ORE" />
                    <DataGridTextColumn
                        Width="50"
                        Binding="{Binding HourlyCost, StringFormat=F2}"
                        Header="€/H" />
                    <DataGridTextColumn
                        Width="65"
                        Binding="{Binding TotalCost, StringFormat=N2}"
                        Header="COSTO €" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <!--  ═══ DataGrid TRASFERTA (DA_CLIENTE) ═══  -->
        <DataTemplate x:Key="TravelGridTemplate">
            <DataGrid
                AutoGenerateColumns="False"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeRows="False"
                CellStyle="{StaticResource BvaCell}"
                ColumnHeaderHeight="26"
                ColumnHeaderStyle="{StaticResource BvaColumnHeader}"
                FontSize="11"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#F3F4F6"
                IsReadOnly="True"
                ItemsSource="{Binding BudgetResources}"
                RowHeight="28"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="35"
                        Binding="{Binding NumTrips}"
                        Header="N.V" />
                    <DataGridTextColumn
                        Width="45"
                        Binding="{Binding KmPerTrip, StringFormat=F0}"
                        Header="KM" />
                    <DataGridTextColumn
                        Width="45"
                        Binding="{Binding CostPerKm, StringFormat=F2}"
                        Header="€/KM" />
                    <DataGridTextColumn
                        Width="50"
                        Binding="{Binding DailyFood, StringFormat=F0}"
                        Header="VITTO" />
                    <DataGridTextColumn
                        Width="50"
                        Binding="{Binding DailyHotel, StringFormat=F0}"
                        Header="HOTEL" />
                    <DataGridTextColumn
                        Width="35"
                        Binding="{Binding AllowanceDays}"
                        Header="GG.I" />
                    <DataGridTextColumn
                        Width="45"
                        Binding="{Binding DailyAllowance, StringFormat=F0}"
                        Header="€/GG" />
                    <DataGridTextColumn
                        Width="65"
                        Binding="{Binding TotalTravelCost, StringFormat=N2}"
                        Header="TOT. €" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <!--  ═══ FASI ASSEGNATE: raggruppate per fase con tecnici ═══  -->
        <DataTemplate x:Key="PhasesGroupedTemplate">
            <ItemsControl ItemsSource="{Binding PhaseGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:BvaPhaseGroupVM}">
                        <StackPanel Margin="0,0,0,6">

                            <!--  Header fase  -->
                            <Border
                                Padding="6,4"
                                Background="#F0F4FF"
                                BorderBrush="#E4E7EC"
                                BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock
                                        DockPanel.Dock="Right"
                                        FontSize="10"
                                        Foreground="#6B7280">
                                        <Run Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h prev.  |  " />
                                        <Run Text="{Binding HoursWorked, StringFormat=F1, Mode=OneWay}" /><Run Text=" h lav.  |  " />
                                        <Run Text="{Binding ProgressPct, Mode=OneWay}" /><Run Text="%" /></TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="#6B7280"
                                            Text="FASE — " />
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="#1A1D26"
                                            Text="{Binding PhaseName}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!--  DataGrid tecnici assegnati  -->
                            <DataGrid
                                AutoGenerateColumns="False"
                                BorderThickness="0"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                CanUserReorderColumns="False"
                                CanUserResizeRows="False"
                                CellStyle="{StaticResource BvaCell}"
                                ColumnHeaderHeight="22"
                                ColumnHeaderStyle="{StaticResource BvaColumnHeader}"
                                FontSize="11"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                HorizontalGridLinesBrush="#F3F4F6"
                                IsReadOnly="True"
                                ItemsSource="{Binding Assignments}"
                                RowHeight="26"
                                SelectionMode="Single"
                                Visibility="{Binding HasAssignments, Converter={StaticResource BoolToVis}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding EmployeeName}"
                                        Header="TECNICO" />
                                    <DataGridTemplateColumn Width="60" Header="ORE PR." CellStyle="{StaticResource BvaCellClickable}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox
                                                    Padding="2,0"
                                                    VerticalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0,0,0,1"
                                                    BorderBrush="#D1D5DB"
                                                    FontSize="11"
                                                    LostFocus="PlannedHours_LostFocus"
                                                    Tag="{Binding}"
                                                    Text="{Binding PlannedHours, StringFormat=F1, UpdateSourceTrigger=LostFocus}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn
                                        Width="60"
                                        Binding="{Binding HoursWorked, StringFormat=F1}"
                                        Header="ORE LAV." />
                                    <DataGridTextColumn
                                        Width="40"
                                        Binding="{Binding Pct}"
                                        Header="%" />
                                    <DataGridTemplateColumn Width="30" Header="" CellStyle="{StaticResource BvaCellClickable}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Width="20"
                                                    Height="20"
                                                    Background="#EF44441A"
                                                    BorderThickness="0"
                                                    Click="BtnRemoveBvaAssignment_Click"
                                                    Content="✕"
                                                    Cursor="Hand"
                                                    FontSize="9"
                                                    Foreground="#EF4444"
                                                    Tag="{Binding}"
                                                    ToolTip="Rimuovi tecnico"
                                                    Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!--  Nessun tecnico  -->
                            <TextBlock
                                Margin="6,2,0,0"
                                FontSize="10"
                                FontStyle="Italic"
                                Foreground="#9CA3AF"
                                Text="Nessun tecnico assegnato">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAssignments}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!--  Pulsante aggiungi tecnico per questa fase  -->
                            <Button
                                Margin="0,3,0,0"
                                Padding="8,0"
                                Height="22"
                                HorizontalAlignment="Left"
                                Background="#4F6EF7"
                                BorderThickness="0"
                                Click="BtnAssignTecnicoToPhase_Click"
                                Content="+ Aggiungi Tecnico"
                                Cursor="Hand"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Tag="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <!--  ═══ SEZIONE: card collassabile ▶ ═══  -->
        <DataTemplate x:Key="SectionTemplate" DataType="{x:Type local:BvaSectionVM}">
            <Border
                Margin="0,0,0,2"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,0,1">
                <StackPanel>

                    <!--  Header sezione  -->
                    <Grid
                        Background="#FAFBFC"
                        Cursor="Hand"
                        MouseLeftButtonDown="SectionRow_Click">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Margin="12,8,0,8"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="9"
                                Foreground="#9CA3AF"
                                RenderTransformOrigin="0.5,0.5"
                                Text="▶">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#1A1D26"
                                Text="{Binding SectionName}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="#6B7280">
                            <Run Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h" /></TextBlock>

                        <TextBlock
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="#D97706">
                            <Run Text="{Binding AssignedHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h" /></TextBlock>

                        <TextBlock
                            Grid.Column="3"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="#4F6EF7">
                            <Run Text="{Binding ActualHours, StringFormat=F1, Mode=OneWay}" /><Run Text=" h" /></TextBlock>

                        <Border
                            Grid.Column="4"
                            Padding="4,2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{Binding TypeColor, Converter={StaticResource HexToAlphaBrush}, ConverterParameter=20}">
                            <TextBlock
                                FontSize="9"
                                FontWeight="Bold"
                                Foreground="{Binding TypeColor, Converter={StaticResource HexToBrush}}"
                                Text="{Binding TypeLabel}" />
                        </Border>

                        <TextBlock
                            Grid.Column="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{Binding DeltaColor, Converter={StaticResource HexToBrush}}"
                            Text="{Binding DeltaText}"
                            Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}" />
                    </Grid>

                    <!--  Dettaglio split (collassabile)  -->
                    <Border Padding="8,4,8,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  COL 0: Preventivo  -->
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition>
                                            <ColumnDefinition.Style>
                                                <Style TargetType="ColumnDefinition">
                                                    <Setter Property="Width" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsClientSide}" Value="True">
                                                            <Setter Property="Width" Value="*" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ColumnDefinition.Style>
                                        </ColumnDefinition>
                                    </Grid.ColumnDefinitions>

                                    <!--  Risorse manodopera  -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            Margin="4,0,0,4"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="#6B7280"
                                            Text="RISORSE PIANIFICATE" />
                                        <ContentControl
                                            Content="{Binding}"
                                            ContentTemplate="{StaticResource BudgetGridTemplate}"
                                            Visibility="{Binding HasBudget, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock
                                            Margin="4,4,0,0"
                                            FontSize="11"
                                            FontStyle="Italic"
                                            Foreground="#9CA3AF"
                                            Text="Nessuna risorsa pianificata">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasBudget}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  Separatore (solo DA_CLIENTE)  -->
                                    <Border
                                        Grid.Column="1"
                                        Width="1"
                                        Margin="4,0"
                                        VerticalAlignment="Stretch"
                                        Background="#E4E7EC"
                                        Visibility="{Binding IsClientSide, Converter={StaticResource BoolToVis}}" />

                                    <!--  Griglia trasferta inline (solo DA_CLIENTE)  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Visibility="{Binding IsClientSide, Converter={StaticResource BoolToVis}}">
                                        <TextBlock
                                            Margin="4,0,0,4"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="#D97706"
                                            Text="TRASFERTA" />
                                        <ContentControl
                                            Content="{Binding}"
                                            ContentTemplate="{StaticResource TravelGridTemplate}"
                                            Visibility="{Binding HasBudget, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Column="1" VerticalAlignment="Stretch" Background="#E4E7EC" />

                                <!--  COL 2: Fasi assegnate (DataGrid)  -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock
                                        Margin="4,0,0,4"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="FASI ASSEGNATE" />
                                    <ContentControl
                                        Content="{Binding}"
                                        ContentTemplate="{StaticResource PhasesGroupedTemplate}"
                                        Visibility="{Binding HasPhases, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock
                                        Margin="4,4,0,0"
                                        FontSize="11"
                                        FontStyle="Italic"
                                        Foreground="#9CA3AF"
                                        Text="Nessuna fase collegata a questa sezione">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPhases}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                            </Grid>

                            <!--  Subtotale sezione — barra unica allineata  -->
                            <Border
                                Margin="0,4,0,0"
                                Padding="8,6"
                                Background="#F9FAFB"
                                BorderBrush="#E4E7EC"
                                BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="4,0,0,0">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="#1A1D26">
                                            <Run Text="Prev: " /><Run Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" />
                                            <Run Text=" h  —  " /><Run Text="{Binding BudgetCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="#92400E"
                                            Visibility="{Binding HasTravel, Converter={StaticResource BoolToVis}}">
                                            <Run Text="+ Trasferta: " /><Run FontWeight="SemiBold" Text="{Binding BudgetTotalTravelCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="4,0,0,0"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#D97706">
                                        <Run Text="Assegn: " /><Run Text="{Binding AssignedHours, StringFormat=F1, Mode=OneWay}" />
                                        <Run Text=" h  —  " /><Run Text="{Binding AssignedCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="4,0,0,0"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#4F6EF7">
                                        <Run Text="Cons: " /><Run Text="{Binding ActualHours, StringFormat=F1, Mode=OneWay}" />
                                        <Run Text=" h  —  " /><Run Text="{Binding ActualCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TextBlock
            x:Name="txtLoading"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="#9CA3AF"
            Text="Caricamento..." />

        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="#9CA3AF"
            Text="Nessun dato di preventivazione disponibile. Configurare prima la commessa."
            Visibility="{Binding ShowEmpty, Converter={StaticResource BoolToVis}}" />

        <DockPanel Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}">

            <Border
                Padding="12,6"
                Background="#F9FAFB"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,0,1"
                DockPanel.Dock="Top">
                <TextBlock
                    FontSize="12"
                    Foreground="#6B7280"
                    Text="{Binding StatusText}" />
            </Border>

            <ScrollViewer Padding="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

            <!--  ═══ SEZIONE RISORSE (collassabile) ═══  -->
            <Expander x:Name="expResources" Expanded="MainExpander_Changed" Collapsed="MainExpander_Changed" IsExpanded="True">
                <Expander.Style>
                    <Style BasedOn="{StaticResource SmoothExpander}" TargetType="Expander" />
                </Expander.Style>
                <Expander.Header>
                    <Border Padding="16,10" Background="#1A1D26">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White" Text="TOTALE RISORSE    " />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="Prev: " />
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White" Text="{Binding TotalBudgetHours, StringFormat=F1}" />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text=" h / " />
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White" Text="{Binding TotalBudgetCost, StringFormat=N2}" />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text=" €" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#D97706" Text="Assegn: " />
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#FBBF24" Text="{Binding TotalAssignedHours, StringFormat=F1}" />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#D97706" Text=" h / " />
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#FBBF24" Text="{Binding TotalAssignedCost, StringFormat=N2}" />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#D97706" Text=" €" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text="Cons: " />
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White" Text="{Binding TotalActualHours, StringFormat=F1}" />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text=" h / " />
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White" Text="{Binding TotalActualCost, StringFormat=N2}" />
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF" Text=" €" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center"
                                FontSize="12" FontWeight="Bold"
                                Foreground="{Binding TotalDeltaColor, Converter={StaticResource HexToBrush}}"
                                Text="{Binding TotalDeltaText}" />
                        </Grid>
                    </Border>
                </Expander.Header>
                <StackPanel>

            <Border
                Padding="12,4"
                Background="#F9FAFB"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="65" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Margin="12,0,0,0"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="SEZIONE" />
                    <TextBlock
                        Grid.Column="1"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="PREVENTIVATE" />
                    <TextBlock
                        Grid.Column="2"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#D97706"
                        Text="ASSEGNATE" />
                    <TextBlock
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#4F6EF7"
                        Text="CONSUMATE" />
                    <TextBlock
                        Grid.Column="4"
                        HorizontalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="TIPO" />
                    <TextBlock
                        Grid.Column="5"
                        HorizontalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="DELTA" />
                </Grid>
            </Border>

            <ItemsControl Padding="16" ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:BvaGroupVM}">
                            <Expander Margin="0,8,0,0" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                <Expander.Style>
                                    <Style BasedOn="{StaticResource SmoothExpander}" TargetType="Expander" />
                                </Expander.Style>
                                <Expander.Header>
                                    <Border Padding="12,6" Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                        <DockPanel>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                DockPanel.Dock="Right"
                                                FontSize="11"
                                                FontWeight="SemiBold">
                                                <Run Foreground="#C8FFFFFF" Text="Prev: " /><Run Foreground="#C8FFFFFF" Text="{Binding BudgetHours, StringFormat=F1, Mode=OneWay}" /><Run Foreground="#C8FFFFFF" Text=" h / " />
                                                <Run Foreground="#C8FFFFFF" Text="{Binding BudgetCost, StringFormat=N2, Mode=OneWay}" /><Run Foreground="#C8FFFFFF" Text=" €    " />
                                                <Run Foreground="#FBBF24" Text="Assegn: " /><Run Foreground="#FBBF24" Text="{Binding AssignedHours, StringFormat=F1, Mode=OneWay}" /><Run Foreground="#FBBF24" Text=" h / " />
                                                <Run Foreground="#FBBF24" Text="{Binding AssignedCost, StringFormat=N2, Mode=OneWay}" /><Run Foreground="#FBBF24" Text=" €    " />
                                                <Run Foreground="White" Text="Cons: " /><Run Foreground="White" Text="{Binding ActualHours, StringFormat=F1, Mode=OneWay}" /><Run Foreground="White" Text=" h / " />
                                                <Run Foreground="White" Text="{Binding ActualCost, StringFormat=N2, Mode=OneWay}" /><Run Foreground="White" Text=" €" /></TextBlock>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding GroupName}" />
                                        </DockPanel>
                                    </Border>
                                </Expander.Header>
                                <ItemsControl ItemTemplate="{StaticResource SectionTemplate}" ItemsSource="{Binding Sections}" />
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                </StackPanel>
            </Expander>
            <!--  ═══ FINE SEZIONE RISORSE ═══  -->

            <!--  ═══ SEZIONE MATERIALI (collassabile) ═══  -->
            <Expander x:Name="expMaterials" Margin="0,8,0,0" Expanded="MainExpander_Changed" Collapsed="MainExpander_Changed" IsExpanded="True" Visibility="{Binding HasMaterials, Converter={StaticResource BoolToVis}}">
                <Expander.Style>
                    <Style BasedOn="{StaticResource SmoothExpander}" TargetType="Expander" />
                </Expander.Style>
                <Expander.Header>
                    <Border Padding="16,10" Background="#1A1D26">
                        <DockPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                FontSize="11"
                                FontWeight="SemiBold">
                                <Run Foreground="#9CA3AF" Text="Netto: " />
                                <Run Foreground="White" FontSize="12" FontWeight="Bold" Text="{Binding TotalMaterialNetCost, StringFormat=N2, Mode=OneWay}" />
                                <Run Foreground="#9CA3AF" Text=" €    Vendita: " />
                                <Run Foreground="#FBBF24" FontSize="12" FontWeight="Bold" Text="{Binding TotalMaterialSaleCost, StringFormat=N2, Mode=OneWay}" />
                                <Run Foreground="#9CA3AF" Text=" €" />
                            </TextBlock>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="TOTALE MATERIALI" />
                        </DockPanel>
                    </Border>
                </Expander.Header>

                <ItemsControl Padding="16,8" ItemsSource="{Binding MaterialSections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Background="White"
                                BorderBrush="#E4E7EC"
                                BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <!--  Header categoria  -->
                                    <Border Padding="8,6" Background="#F0F4FF">
                                        <DockPanel>
                                            <TextBlock
                                                DockPanel.Dock="Right"
                                                FontSize="11"
                                                Foreground="#6B7280">
                                                <Run Text="Netto: " />
                                                <Run FontWeight="SemiBold" Text="{Binding TotalNetCost, StringFormat=N2, Mode=OneWay}" />
                                                <Run Text=" €    Vendita: " />
                                                <Run FontWeight="SemiBold" Foreground="#D97706" Text="{Binding TotalSaleCost, StringFormat=N2, Mode=OneWay}" />
                                                <Run Text=" €" />
                                            </TextBlock>
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="#1A1D26"
                                                Text="{Binding SectionName}" />
                                        </DockPanel>
                                    </Border>

                                    <!--  Items  -->
                                    <DataGrid
                                        AutoGenerateColumns="False"
                                        BorderThickness="0"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False"
                                        CanUserReorderColumns="False"
                                        CanUserResizeRows="False"
                                        ColumnHeaderHeight="26"
                                        ColumnHeaderStyle="{StaticResource BvaColumnHeader}"
                                        FontSize="11"
                                        GridLinesVisibility="Horizontal"
                                        HeadersVisibility="Column"
                                        HorizontalGridLinesBrush="#F3F4F6"
                                        IsReadOnly="True"
                                        ItemsSource="{Binding Items}"
                                        RowHeight="28"
                                        SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Width="*"
                                                Binding="{Binding Description}"
                                                Header="DESCRIZIONE" />
                                            <DataGridTextColumn
                                                Width="50"
                                                Binding="{Binding Quantity, StringFormat=F0}"
                                                Header="QTA" />
                                            <DataGridTextColumn
                                                Width="70"
                                                Binding="{Binding UnitCost, StringFormat=N2}"
                                                Header="€ UNIT." />
                                            <DataGridTextColumn
                                                Width="40"
                                                Binding="{Binding MarkupValue, StringFormat=F2}"
                                                Header="K" />
                                            <DataGridTextColumn
                                                Width="80"
                                                Binding="{Binding NetCost, StringFormat=N2}"
                                                Header="NETTO €" />
                                            <DataGridTextColumn
                                                Width="80"
                                                Binding="{Binding SaleCost, StringFormat=N2}"
                                                Header="VENDITA €" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
            <!--  ═══ FINE SEZIONE MATERIALI ═══  -->

            <!--  ═══ SCHEDA PREZZI (collassabile) ═══  -->
            <Expander x:Name="expPricing" Margin="0,8,0,0" Expanded="MainExpander_Changed" Collapsed="MainExpander_Changed" IsExpanded="True" Visibility="{Binding HasPricing, Converter={StaticResource BoolToVis}}">
                <Expander.Style>
                    <Style BasedOn="{StaticResource SmoothExpander}" TargetType="Expander" />
                </Expander.Style>
                <Expander.Header>
                    <Border Padding="16,10" Background="#1A1D26">
                        <DockPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="#34D399"
                                Text="{Binding Pricing.FinalPrice, StringFormat=N2}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                FontSize="11"
                                Foreground="#9CA3AF"
                                Text="FINAL OFFER PRICE  " />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="SCHEDA PREZZI" />
                        </DockPanel>
                    </Border>
                </Expander.Header>

                <Border Padding="16,8" Background="White">
                    <StackPanel>
                        <!--  NET COST  -->
                        <Border Padding="12,8" Background="#F9FAFB" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#1A1D26">
                                    <Run Text="{Binding Pricing.NetCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" EUR" /></TextBlock>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#6B7280"
                                    Text="NET COST (risorse + materiali + trasferte)" />
                            </DockPanel>
                        </Border>

                        <!--  Contingency  -->
                        <Border Padding="12,6" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="12"
                                    Foreground="#6B7280">
                                    <Run Text="{Binding Pricing.ContingencyAmount, StringFormat=N2, Mode=OneWay}" /></TextBlock>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    Margin="0,0,12,0"
                                    FontSize="12"
                                    Foreground="#9CA3AF">
                                    <Run Text="{Binding Pricing.ContingencyPct, StringFormat=P1, Mode=OneWay}" /></TextBlock>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#9CA3AF"
                                    Text="+ Contingency" />
                            </DockPanel>
                        </Border>

                        <!--  OFFER PRICE  -->
                        <Border Padding="12,8" Background="#2563EB">
                            <DockPanel>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="White">
                                    <Run Text="{Binding Pricing.OfferPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" EUR" /></TextBlock>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="OFFER PRICE" />
                            </DockPanel>
                        </Border>

                        <!--  Margine trattativa  -->
                        <Border Padding="12,6" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="12"
                                    Foreground="#6B7280">
                                    <Run Text="{Binding Pricing.NegotiationAmount, StringFormat=N2, Mode=OneWay}" /></TextBlock>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    Margin="0,0,12,0"
                                    FontSize="12"
                                    Foreground="#9CA3AF">
                                    <Run Text="{Binding Pricing.NegotiationPct, StringFormat=P1, Mode=OneWay}" /></TextBlock>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#9CA3AF"
                                    Text="+ Margine trattativa" />
                            </DockPanel>
                        </Border>

                        <!--  FINAL OFFER PRICE  -->
                        <Border Padding="12,8" Background="#2563EB">
                            <DockPanel>
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="White">
                                    <Run Text="{Binding Pricing.FinalPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" EUR" /></TextBlock>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="FINAL OFFER PRICE" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Expander>
            <!--  ═══ FINE SCHEDA PREZZI ═══  -->

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>