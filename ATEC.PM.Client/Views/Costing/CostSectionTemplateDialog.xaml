<Window
    x:Class="ATEC.PM.Client.Views.CostSectionTemplateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nuova Sezione Costo"
    Width="480"
    Height="460"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtError"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#EF4444" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Height="34"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Cursor="Hand"
                        Foreground="#374151" />
                    <Button
                        Width="90"
                        Height="34"
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnSave_Click"
                        Content="Salva"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>
        <ScrollViewer Padding="24,16,24,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="NOME SEZIONE *" />
                <TextBox
                    x:Name="txtName"
                    Height="32"
                    Padding="8,5"
                    BorderBrush="#E4E7EC"
                    FontSize="13" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="TIPO *" />
                        <ComboBox
                            x:Name="cmbType"
                            Height="32"
                            Padding="8,5"
                            BorderBrush="#E4E7EC"
                            FontSize="13">
                            <ComboBoxItem Content="IN_SEDE" IsSelected="True" />
                            <ComboBoxItem Content="DA_CLIENTE" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="GRUPPO *" />
                        <ComboBox
                            x:Name="cmbGroup"
                            Height="32"
                            Padding="8,5"
                            BorderBrush="#E4E7EC"
                            FontSize="13" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="ORDINAMENTO" />
                        <TextBox
                            x:Name="txtSortOrder"
                            Height="32"
                            Padding="8,5"
                            BorderBrush="#E4E7EC"
                            FontSize="13"
                            Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="DEFAULT" />
                        <CheckBox
                            x:Name="chkDefault"
                            Margin="0,8,0,0"
                            Content="Inserisci di default"
                            FontSize="13"
                            IsChecked="True" />
                    </StackPanel>
                </Grid>

                <!--  REPARTI  -->
                <TextBlock
                    Margin="0,16,0,6"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="#6B7280"
                    Text="REPARTI DI PERTINENZA" />
                <Border
                    Padding="12,8"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1">
                    <WrapPanel x:Name="wpDepartments" />
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
