<Window
    x:Class="ATEC.PM.Client.Views.Costing.CatalogPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Seleziona prodotti dal catalogo"
    Width="900"
    Height="600"
    Background="#F7F8FA"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <DockPanel>

        <!--  BOTTOM BAR  -->
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtSelectionCount"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#6B7280"
                    Text="0 varianti selezionate" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Height="34"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Cursor="Hand"
                        Foreground="#374151" />
                    <Button
                        x:Name="btnAdd"
                        Width="110"
                        Height="34"
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnAdd_Click"
                        Content="Aggiungi"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  MAIN 2-COLUMN LAYOUT  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  LEFT: Tree  -->
            <Border
                Grid.Column="0"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,1,0">
                <DockPanel>

                    <!--  Listino selector  -->
                    <Border
                        Padding="8,8"
                        Background="#F0F4FF"
                        BorderBrush="#E4E7EC"
                        BorderThickness="0,0,0,1"
                        DockPanel.Dock="Top">
                        <DockPanel>
                            <TextBlock
                                Margin="4,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#4F6EF7"
                                Text="LISTINO:" />
                            <ComboBox
                                x:Name="cmbPriceList"
                                Height="32"
                                Padding="6,3"
                                DisplayMemberPath="Name"
                                FontSize="12"
                                IsEditable="True"
                                SelectionChanged="CmbPriceList_SelectionChanged" />
                        </DockPanel>
                    </Border>

                    <!--  Tree status  -->
                    <Border
                        Padding="12,6"
                        BorderBrush="#E4E7EC"
                        BorderThickness="0,1,0,0"
                        DockPanel.Dock="Bottom">
                        <TextBlock
                            x:Name="txtTreeStatus"
                            FontSize="11"
                            Foreground="#9CA3AF"
                            Text="Caricamento..." />
                    </Border>

                    <!--  TreeView  -->
                    <TreeView
                        x:Name="treeCatalog"
                        Padding="4"
                        Background="White"
                        BorderThickness="0"
                        SelectedItemChanged="Tree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="4,4" />
                                <Setter Property="FontSize" Value="13" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F4FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E8EDFB" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!--  RIGHT: Products / Variants  -->
            <Border Grid.Column="1">
                <DockPanel>

                    <!--  Header  -->
                    <Border
                        Padding="20,10"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="0,0,0,1"
                        DockPanel.Dock="Top">
                        <TextBlock
                            x:Name="txtProductName"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="Seleziona una categoria" />
                    </Border>

                    <!--  Variant list  -->
                    <ListView
                        x:Name="lstVariants"
                        Background="#F7F8FA"
                        BorderThickness="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="8,4,8,0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border
                                                Padding="12,8"
                                                Background="White"
                                                BorderBrush="#E4E7EC"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Checkbox  -->
                                    <CheckBox
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Checked="Variant_CheckChanged"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                        Unchecked="Variant_CheckChanged" />

                                    <!--  Name + Code  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="#1A1D26"
                                            Text="{Binding VariantName}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#9CA3AF"
                                            Text="{Binding VariantCode}" />
                                    </StackPanel>

                                    <!--  Cost price  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="12,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="#9CA3AF"
                                            Text="costo" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#374151"
                                            Text="{Binding CostPrice, StringFormat='€ {0:N2}'}" />
                                    </StackPanel>

                                    <!--  Sell price  -->
                                    <StackPanel
                                        Grid.Column="3"
                                        Margin="12,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="#9CA3AF"
                                            Text="vendita" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#374151"
                                            Text="{Binding SellPrice, StringFormat='€ {0:N2}'}" />
                                    </StackPanel>

                                    <!--  Quantity  -->
                                    <StackPanel
                                        Grid.Column="4"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="#9CA3AF"
                                            Text="qty" />
                                        <TextBox
                                            Width="50"
                                            Height="26"
                                            Padding="4,2"
                                            BorderBrush="#E4E7EC"
                                            FontSize="13"
                                            Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
