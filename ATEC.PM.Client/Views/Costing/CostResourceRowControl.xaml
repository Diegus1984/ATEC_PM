<UserControl
    x:Class="ATEC.PM.Client.Views.Costing.CostResourceRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:ATEC.PM.Client.Views.Costing.ViewModels"
    Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#9CA3AF" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,2,0" />
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#1A1D26" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="38" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="TariffInput" TargetType="TextBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="38" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="BorderBrush" Value="#D97706" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFBEB" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DropBtn" TargetType="Button">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="7" />
            <Setter Property="Content" Value="&#x25BC;" />
            <Setter Property="Background" Value="#FEF3C7" />
            <Setter Property="Foreground" Value="#D97706" />
            <Setter Property="BorderBrush" Value="#D97706" />
            <Setter Property="BorderThickness" Value="0,1,1,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
    </UserControl.Resources>

    <Border Padding="6,4" Margin="0,1" Background="Yellow" BorderBrush="Red" BorderThickness="3">
        <WrapPanel VerticalAlignment="Center">

            <!-- DEBUG -->
            <TextBlock Text="=== CUSTOM CONTROL ATTIVO ===" FontSize="16" FontWeight="Bold" Foreground="Red" Margin="0,0,20,0" />

            <!-- NOME RISORSA -->
            <TextBlock Text="{Binding ResourceName}" FontSize="12" FontWeight="Bold" Foreground="#1A1D26"
                       MinWidth="140" Margin="0,0,12,0" VerticalAlignment="Center" />

            <!-- REP -->
            <TextBlock x:Name="txtRep" Style="{StaticResource Val}" Foreground="#4F6EF7" MinWidth="30" />

            <!-- GG -->
            <TextBlock Text="GG" Style="{StaticResource Lbl}" />
            <TextBox Text="{Binding WorkDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Inp}" />

            <!-- ORE/G -->
            <TextBlock Text="ORE/G" Style="{StaticResource Lbl}" />
            <TextBox Text="{Binding HoursPerDay, StringFormat=F0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Inp}" />

            <!-- TOT ORE -->
            <TextBlock Text="TOT" Style="{StaticResource Lbl}" />
            <TextBlock Text="{Binding TotalHours, StringFormat=F1}" Style="{StaticResource Val}" />

            <!-- E/H -->
            <TextBlock Text="&#x20AC;/H" Style="{StaticResource Lbl}" />
            <TextBlock Text="{Binding HourlyCost, StringFormat=N2}" Style="{StaticResource Val}" Foreground="#4F6EF7" />

            <!-- COSTO -->
            <TextBlock Text="COSTO" Style="{StaticResource Lbl}" />
            <TextBlock Text="{Binding TotalCost, StringFormat=N2}" Style="{StaticResource Val}" />

            <!-- K -->
            <TextBlock Text="K" Style="{StaticResource Lbl}" />
            <TextBox Text="{Binding MarkupValue, StringFormat=N3, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Inp}" Width="45" />

            <!-- VENDITA -->
            <TextBlock Text="VENDITA" Style="{StaticResource Lbl}" />
            <TextBlock Text="{Binding TotalSale, StringFormat=N2}" Style="{StaticResource Val}" Foreground="#059669" />

            <!-- SEPARATORE TRASFERTA -->
            <Border Width="1" Height="20" Background="#E4E7EC" Margin="4,0,8,0"
                    Visibility="{Binding IsTravelVisible, FallbackValue=Collapsed}" x:Name="brdSep" />

            <!-- VIAGGI -->
            <TextBlock Text="VIAGGI" Style="{StaticResource Lbl}" x:Name="lblViaggi" />
            <TextBox Text="{Binding NumTrips, StringFormat=F0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Inp}" Width="30" x:Name="txtViaggi" />

            <!-- KM -->
            <TextBlock Text="KM" Style="{StaticResource Lbl}" x:Name="lblKm" />
            <TextBox Text="{Binding KmPerTrip, StringFormat=F0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Inp}" Width="35" x:Name="txtKmTrip" />

            <!-- E/KM (dropdown) -->
            <TextBlock Text="&#x20AC;/KM" Style="{StaticResource Lbl}" x:Name="lblCostKm" />
            <StackPanel Orientation="Horizontal" x:Name="pnlCostKm">
                <TextBox x:Name="txtCostKm" Text="{Binding CostPerKm, StringFormat=N2, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TariffInput}" />
                <Button Style="{StaticResource DropBtn}" Click="BtnDropDown_Click" Tag="CostPerKm" />
            </StackPanel>
            <Popup x:Name="popCostKm" PlacementTarget="{Binding ElementName=txtCostKm}" Placement="Bottom" StaysOpen="False">
                <Border Background="White" BorderBrush="#D97706" BorderThickness="1" MaxHeight="150">
                    <ListBox FontSize="11" BorderThickness="0"
                             ItemsSource="{x:Static vm:CostResourceVM.CostPerKmOptions}"
                             MouseUp="LstTariff_MouseUp" Tag="CostPerKm" />
                </Border>
            </Popup>

            <!-- VITTO/G (dropdown) -->
            <TextBlock Text="VITTO/G" Style="{StaticResource Lbl}" x:Name="lblFood" />
            <StackPanel Orientation="Horizontal" x:Name="pnlFood">
                <TextBox x:Name="txtFood" Text="{Binding DailyFood, StringFormat=N0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TariffInput}" />
                <Button Style="{StaticResource DropBtn}" Click="BtnDropDown_Click" Tag="DailyFood" />
            </StackPanel>
            <Popup x:Name="popFood" PlacementTarget="{Binding ElementName=txtFood}" Placement="Bottom" StaysOpen="False">
                <Border Background="White" BorderBrush="#D97706" BorderThickness="1" MaxHeight="150">
                    <ListBox FontSize="11" BorderThickness="0"
                             ItemsSource="{x:Static vm:CostResourceVM.DailyFoodOptions}"
                             MouseUp="LstTariff_MouseUp" Tag="DailyFood" />
                </Border>
            </Popup>

            <!-- HOTEL/G (dropdown) -->
            <TextBlock Text="HOTEL/G" Style="{StaticResource Lbl}" x:Name="lblHotel" />
            <StackPanel Orientation="Horizontal" x:Name="pnlHotel">
                <TextBox x:Name="txtHotel" Text="{Binding DailyHotel, StringFormat=N0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TariffInput}" />
                <Button Style="{StaticResource DropBtn}" Click="BtnDropDown_Click" Tag="DailyHotel" />
            </StackPanel>
            <Popup x:Name="popHotel" PlacementTarget="{Binding ElementName=txtHotel}" Placement="Bottom" StaysOpen="False">
                <Border Background="White" BorderBrush="#D97706" BorderThickness="1" MaxHeight="150">
                    <ListBox FontSize="11" BorderThickness="0"
                             ItemsSource="{x:Static vm:CostResourceVM.DailyHotelOptions}"
                             MouseUp="LstTariff_MouseUp" Tag="DailyHotel" />
                </Border>
            </Popup>

            <!-- GG IND -->
            <TextBlock Text="GG IND" Style="{StaticResource Lbl}" x:Name="lblAllowDays" />
            <TextBox Text="{Binding AllowanceDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource Inp}" Width="30" x:Name="txtAllowDays" />

            <!-- E/G IND (dropdown) -->
            <TextBlock Text="&#x20AC;/G IND" Style="{StaticResource Lbl}" x:Name="lblAllow" />
            <StackPanel Orientation="Horizontal" x:Name="pnlAllow">
                <TextBox x:Name="txtAllow" Text="{Binding DailyAllowance, StringFormat=N0, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TariffInput}" />
                <Button Style="{StaticResource DropBtn}" Click="BtnDropDown_Click" Tag="DailyAllowance" />
            </StackPanel>
            <Popup x:Name="popAllow" PlacementTarget="{Binding ElementName=txtAllow}" Placement="Bottom" StaysOpen="False">
                <Border Background="White" BorderBrush="#D97706" BorderThickness="1" MaxHeight="150">
                    <ListBox FontSize="11" BorderThickness="0"
                             ItemsSource="{x:Static vm:CostResourceVM.DailyAllowanceOptions}"
                             MouseUp="LstTariff_MouseUp" Tag="DailyAllowance" />
                </Border>
            </Popup>

            <!-- DELETE -->
            <Button Content="X" Width="22" Height="22" Margin="8,0,0,0"
                    Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0"
                    FontSize="10" FontWeight="Bold" Cursor="Hand"
                    Click="BtnDelete_Click" />

        </WrapPanel>
    </Border>
</UserControl>
