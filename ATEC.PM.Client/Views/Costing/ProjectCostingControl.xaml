<UserControl
    x:Class="ATEC.PM.Client.Views.Costing.ProjectCostingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:ATEC.PM.Client.Views.Costing.ViewModels"
    MinWidth="900"
    MinHeight="800"
    Background="#F7F8FA"
    FontFamily="Segoe UI">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ATEC.PM.Client;component/Views/Costing/Styles/ProjectCostingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>


            <!--  ========== DATA TEMPLATES ==========  -->
            <DataTemplate x:Key="DeleteButtonTemplate">
                <Button
                    Width="20"
                    Height="20"
                    Background="#EF44441A"
                    BorderThickness="0"
                    Click="BtnDeleteResource_Click"
                    Cursor="Hand"
                    Tag="{Binding Id}"
                    ToolTip="Elimina risorsa">
                    <TextBlock
                        FontSize="9"
                        FontWeight="Bold"
                        Foreground="#EF4444"
                        Text="✕" />
                </Button>
            </DataTemplate>

            <DataTemplate x:Key="DeleteMaterialButtonTemplate">
                <Button
                    Width="20"
                    Height="20"
                    Background="#EF44441A"
                    BorderThickness="0"
                    Click="BtnDeleteMaterialItem_Click"
                    Cursor="Hand"
                    Tag="{Binding Id}"
                    ToolTip="Elimina materiale">
                    <TextBlock
                        FontSize="9"
                        FontWeight="Bold"
                        Foreground="#EF4444"
                        Text="✕" />
                </Button>
            </DataTemplate>

            <!--  Template Risorse In Sede  -->
            <DataTemplate x:Key="ResourceGridInSede">
                <DataGrid
                    AlternatingRowBackground="#F9FAFB"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CellEditEnding="ResourceGrid_CellEditEnding"
                    CellStyle="{StaticResource CostingCell}"
                    ColumnHeaderHeight="28"
                    ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                    FontSize="12"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#F3F4F6"
                    ItemsSource="{Binding Resources}"
                    RowBackground="Transparent"
                    RowHeight="36"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="2*" Header="RISORSA">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Padding="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding ResourceName}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox
                                        DisplayMemberPath="FullName"
                                        IsEditable="True"
                                        IsTextSearchEnabled="True"
                                        Loaded="EmployeeCombo_Loaded"
                                        SelectionChanged="EmployeeCombo_SelectionChanged"
                                        StaysOpenOnEdit="True"
                                        Style="{StaticResource InlineComboBox}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding WorkDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                            Header="GG">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="55"
                            Binding="{Binding HoursPerDay, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                            Header="ORE/G">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="65"
                            Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}"
                            Header="TOT ORE"
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="70"
                            Binding="{Binding HourlyCost, StringFormat=N2}"
                            Header="€/H"
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="Foreground" Value="#4F6EF7" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                            Header="TOT €"
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="70" Header="K">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox
                                        Width="50"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource NumericTextBox}"
                                        Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                        ToolTip="Markup applicato (es: 1.45 = 45%)" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}"
                            Header="VENDITA €"
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="Foreground" Value="#059669" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn
                            Width="30"
                            CellTemplate="{StaticResource DeleteButtonTemplate}"
                            Header="" />
                    </DataGrid.Columns>
                </DataGrid>
            </DataTemplate>

            <!--  Template Risorse Da Cliente (con trasferte)  -->
            <DataTemplate x:Key="ResourceGridDaCliente">
                <StackPanel>
                    <DataGrid
                        AlternatingRowBackground="#F9FAFB"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CellEditEnding="ResourceGrid_CellEditEnding"
                        CellStyle="{StaticResource CostingCell}"
                        ColumnHeaderHeight="28"
                        ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                        FontSize="12"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#F3F4F6"
                        ItemsSource="{Binding Resources}"
                        RowBackground="Transparent"
                        RowHeight="36"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="2*" Header="RISORSA">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Padding="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="{Binding ResourceName}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            DisplayMemberPath="FullName"
                                            Loaded="EmployeeCombo_Loaded"
                                            SelectionChanged="EmployeeCombo_SelectionChanged"
                                            Style="{StaticResource InlineComboBox}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="45"
                                Binding="{Binding WorkDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                Header="GG">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding HoursPerDay, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                Header="ORE/G">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="60"
                                Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}"
                                Header="TOT ORE"
                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="65"
                                Binding="{Binding HourlyCost, StringFormat=N2}"
                                Header="€/H"
                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                        <Setter Property="Foreground" Value="#4F6EF7" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="85"
                                Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                                Header="TOT €"
                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Width="60" Header="K">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            Width="45"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource NumericTextBox}"
                                            Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="85"
                                Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}"
                                Header="VENDITA €"
                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                        <Setter Property="Foreground" Value="#059669" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="45"
                                Binding="{Binding NumTrips, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                Header="VIAGGI">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="VIAGGI" ToolTip="Numero viaggi" />
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="45"
                                Binding="{Binding KmPerTrip, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                Header="KM">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="KM" ToolTip="Km per viaggio" />
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding CostPerKm, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                                Header="€/KM">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="€/KM" ToolTip="Costo al chilometro" />
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding DailyFood, StringFormat=N0, UpdateSourceTrigger=LostFocus}"
                                Header="VITTO/G">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="VITTO/G" ToolTip="Vitto giornaliero" />
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding DailyHotel, StringFormat=N0, UpdateSourceTrigger=LostFocus}"
                                Header="HOTEL/G">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="HOTEL/G" ToolTip="Hotel giornaliero" />
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Margin" Value="0,0,8,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding AllowanceDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                Header="GG IND.">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="GG IND." ToolTip="Giorni indennità" />
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Width="70" Header="€/G IND.">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="€/G IND." ToolTip="Indennità giornaliera" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            Width="60"
                                            HorizontalAlignment="Center"
                                            ItemsSource="{x:Static vm:CostResourceVM.AllowanceOptions}"
                                            SelectedItem="{Binding DailyAllowance, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource InlineComboBox}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn
                                Width="30"
                                CellTemplate="{StaticResource DeleteButtonTemplate}"
                                Header="" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--  Subtotali  -->
                    <Border
                        Margin="0,4,0,0"
                        Padding="12,8"
                        Background="#F9FAFB"
                        BorderBrush="#E4E7EC"
                        BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#1A1D26"
                                Text="SUBTOTALI" />

                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#6B7280"
                                    Text="Ore: " />
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#1A1D26"
                                    Text="{Binding TotalCostOre, StringFormat=N2}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#1A1D26"
                                    Text=" €" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#6B7280"
                                    Text="Viaggi: " />
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#1A1D26"
                                    Text="{Binding TotalViaggi, StringFormat=N2}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#1A1D26"
                                    Text=" €" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="3"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#6B7280"
                                    Text="Vitto/Alloggio: " />
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#1A1D26"
                                    Text="{Binding TotalAlloggio, StringFormat=N2}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#1A1D26"
                                    Text=" €" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="4"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#6B7280"
                                    Text="Indennità: " />
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#1A1D26"
                                    Text="{Binding TotalIndennita, StringFormat=N2}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#1A1D26"
                                    Text=" €" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </DataTemplate>

            <!--  Template Material Items  -->
            <DataTemplate x:Key="MaterialItemsGrid">
                <DataGrid
                    AlternatingRowBackground="#F9FAFB"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CellEditEnding="MaterialGrid_CellEditEnding"
                    CellStyle="{StaticResource CostingCell}"
                    ColumnHeaderHeight="28"
                    ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                    FontSize="12"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#F3F4F6"
                    ItemsSource="{Binding Items}"
                    RowBackground="Transparent"
                    RowHeight="36"
                    SelectionMode="Single">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EBF0FF" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F3F4F6" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1A1D26" />
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="3*"
                            Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"
                            Header="DESCRIZIONE">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0,0,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding Quantity, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                            Header="QTÀ">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding UnitCost, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                            Header="COSTO UNIT.">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                            Header="COSTO TOT."
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="80" Header="K">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox
                                        Width="60"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource NumericTextBox}"
                                        Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                        ToolTip="Markup applicato" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}"
                            Header="PREZZO VENDITA"
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="Foreground" Value="#059669" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="40" Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="4,2"
                                        HorizontalAlignment="Center"
                                        Background="#F3F4F6"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="9"
                                            FontWeight="Bold"
                                            Foreground="#4F6EF7"
                                            Text="{Binding ItemType, Converter={StaticResource ItemTypeToBadge}}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn
                            Width="30"
                            CellTemplate="{StaticResource DeleteMaterialButtonTemplate}"
                            Header="" />
                    </DataGrid.Columns>
                </DataGrid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  ========== LAYOUT PRINCIPALE ==========  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  HEADER  -->
        <Border
            Grid.Row="0"
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Stato  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#6B7280"
                        Text="{Binding StatusText}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  CONTENUTO PRINCIPALE  -->
        <Grid Grid.Row="1">
            <!--  Stato Inizializzazione  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ShowInit, Converter={StaticResource BoolToVis}}">
                <TextBlock
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Foreground="#6B7280"
                    Text="Configurazione costi non ancora inizializzata." />
                <Button
                    Width="240"
                    Height="40"
                    Click="BtnInit_Click"
                    Content="🚀 Inizializza Configurazione"
                    FontSize="14"
                    Style="{StaticResource PrimaryButton}" />
            </StackPanel>

            <!--  Contenuto Principale con Scroll  -->
            <ScrollViewer
                Padding="16"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!--  ========== SEZIONE RISORSE ==========  -->
                    <Border
                        Margin="0,0,0,16"
                        Padding="0"
                        Background="White"
                        CornerRadius="8">
                        <StackPanel>
                            <!--  Header sezione risorse  -->
                            <Border
                                Padding="16,12"
                                Background="#F9FAFB"
                                CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="#1A1D26"
                                        Text="IMPEGNO RISORSE" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button
                                            Margin="0,0,8,0"
                                            Click="BtnAddGroup_Click"
                                            Content="➕ Nuovo Gruppo"
                                            Style="{StaticResource SecondaryButton}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--  Intestazione colonne riepilogo  -->
                            <Border
                                Padding="12,6"
                                Background="#F9FAFB"
                                BorderBrush="#E4E7EC"
                                BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="SEZIONE" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="QTÀ" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="COSTO NETTO" />
                                    <TextBlock
                                        Grid.Column="3"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="PREZZO VENDITA" />
                                    <TextBlock
                                        Grid.Column="4"
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="TIPO" />
                                    <TextBlock
                                        Grid.Column="5"
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#D97706"
                                        Text="CONT.%">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfferMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        Grid.Column="6"
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#7C3AED"
                                        Text="MARG.%">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfferMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!--  Gruppi e Sezioni  -->
                            <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CostGroupVM}">
                                        <StackPanel Margin="0,4,0,0">

                                            <!--  Header Gruppo  -->
                                            <Border
                                                Padding="12,8"
                                                Background="{Binding Color, Converter={StaticResource HexToBrush}}"
                                                CornerRadius="4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="GroupHeader_Click">
                                                <DockPanel>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        DockPanel.Dock="Right"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="#C8FFFFFF">
                                                        <Run Text="Netto " />
                                                        <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" />
                                                        <Run Text=" €  →  Vendita " />
                                                        <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" />
                                                        <Run Text=" €" />
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path
                                                            Width="8"
                                                            Height="10"
                                                            Margin="4,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Data="M 0,0 L 5,5 L 0,10"
                                                            RenderTransformOrigin="0.5,0.5"
                                                            Stroke="#FFFFFF90"
                                                            StrokeThickness="1.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource BoolToAngle}}" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="White"
                                                            Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>

                                            <!--  Contenuto Gruppo  -->
                                            <StackPanel Margin="16,8,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl ItemsSource="{Binding Sections}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:CostSectionVM}">
                                                            <Border
                                                                Margin="0,0,0,4"
                                                                Background="White"
                                                                BorderBrush="#E4E7EC"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                                <StackPanel>

                                                                    <!--  Header Sezione  -->
                                                                    <Grid
                                                                        Height="36"
                                                                        Background="#FAFBFC"
                                                                        Cursor="Hand"
                                                                        MouseLeftButtonDown="SectionRow_Click">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="50" />
                                                                            <ColumnDefinition Width="120" />
                                                                            <ColumnDefinition Width="120" />
                                                                            <ColumnDefinition Width="70" />
                                                                            <ColumnDefinition Width="70" />
                                                                            <ColumnDefinition Width="70" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel
                                                                            Grid.Column="0"
                                                                            Margin="12,0,0,0"
                                                                            VerticalAlignment="Center"
                                                                            Orientation="Horizontal">
                                                                            <Path
                                                                                Width="7"
                                                                                Height="9"
                                                                                Margin="0,0,8,0"
                                                                                VerticalAlignment="Center"
                                                                                Data="M 0,0 L 4.5,4.5 L 0,9"
                                                                                Stroke="#9CA3AF"
                                                                                StrokeThickness="1.5">
                                                                                <Path.RenderTransform>
                                                                                    <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                                                                </Path.RenderTransform>
                                                                            </Path>
                                                                            <TextBlock
                                                                                FontSize="13"
                                                                                FontWeight="SemiBold"
                                                                                Foreground="#1A1D26"
                                                                                Text="{Binding Name}" />
                                                                        </StackPanel>

                                                                        <TextBlock
                                                                            Grid.Column="1"
                                                                            Margin="0,0,8,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="12"
                                                                            Foreground="#6B7280"
                                                                            Text="{Binding ResourceCount}" />

                                                                        <TextBlock
                                                                            Grid.Column="2"
                                                                            Margin="0,0,8,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="12"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="#1A1D26">
                                                                            <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                                        </TextBlock>

                                                                        <TextBlock
                                                                            Grid.Column="3"
                                                                            Margin="0,0,8,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="12"
                                                                            FontWeight="Bold"
                                                                            Foreground="#4F6EF7">
                                                                            <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                                        </TextBlock>

                                                                        <Border
                                                                            Grid.Column="4"
                                                                            Padding="6,2"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Background="#F3F4F6"
                                                                            CornerRadius="12">
                                                                            <TextBlock
                                                                                FontSize="9"
                                                                                FontWeight="Bold"
                                                                                Foreground="#6B7280"
                                                                                Text="{Binding TypeLabel}" />
                                                                        </Border>

                                                                        <TextBox
                                                                            Grid.Column="5"
                                                                            Width="50"
                                                                            Height="22"
                                                                            IsReadOnly="True"
                                                                            Style="{StaticResource NumericTextBox}"
                                                                            Tag="contingency"
                                                                            Text="{Binding ContingencyPct, Converter={StaticResource PctToString}, Mode=OneWay}"
                                                                            Visibility="{Binding DataContext.IsOfferMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />

                                                                        <TextBox
                                                                            Grid.Column="6"
                                                                            Width="50"
                                                                            Height="22"
                                                                            IsReadOnly="True"
                                                                            Style="{StaticResource NumericTextBox}"
                                                                            Tag="margin"
                                                                            Text="{Binding MarginPct, Converter={StaticResource PctToString}, Mode=OneWay}"
                                                                            Visibility="{Binding DataContext.IsOfferMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
                                                                    </Grid>

                                                                    <!--  Dettaglio Sezione (espanso)  -->
                                                                    <Border Padding="12,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                                                        <StackPanel>
                                                                            <ContentControl Content="{Binding}">
                                                                                <ContentControl.Style>
                                                                                    <Style TargetType="ContentControl">
                                                                                        <Setter Property="ContentTemplate" Value="{StaticResource ResourceGridInSede}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsDaCliente}" Value="True">
                                                                                                <Setter Property="ContentTemplate" Value="{StaticResource ResourceGridDaCliente}" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </ContentControl.Style>
                                                                            </ContentControl>

                                                                            <Button
                                                                                Margin="0,8,0,0"
                                                                                Padding="12,6"
                                                                                HorizontalAlignment="Left"
                                                                                Click="BtnAddResource_Click"
                                                                                Content="➕ Aggiungi Risorsa"
                                                                                FontSize="11"
                                                                                Style="{StaticResource PrimaryButton}"
                                                                                Tag="{Binding Id}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Button
                                                    Margin="0,8,0,4"
                                                    Padding="12,6"
                                                    HorizontalAlignment="Left"
                                                    Click="BtnAddSection_Click"
                                                    Content="➕ Aggiungi Sezione"
                                                    FontSize="11"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Tag="{Binding Name}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Totali Risorse  -->
                            <Border
                                Margin="0,8,0,0"
                                Padding="16,10"
                                Background="#1A1D26"
                                CornerRadius="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Width="200"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="TOTALE RISORSE" />
                                    <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#9CA3AF"
                                            Text="Netto: " />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding GrandTotalCost, StringFormat=N2}" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="White"
                                            Text=" €" />
                                    </StackPanel>
                                    <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#9CA3AF"
                                            Text="Vendita: " />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="#4F6EF7"
                                            Text="{Binding GrandTotalSale, StringFormat=N2}" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#4F6EF7"
                                            Text=" €" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!--  ========== SEZIONE MATERIALI ==========  -->
                    <Border
                        Margin="0,0,0,16"
                        Padding="0"
                        Background="White"
                        CornerRadius="8">
                        <StackPanel>
                            <!--  Header materiali  -->
                            <Border
                                Padding="16,12"
                                Background="#F9FAFB"
                                CornerRadius="8,8,0,0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="#1A1D26"
                                    Text="MATERIALI" />
                            </Border>

                            <!--  Intestazione colonne  -->
                            <Border
                                Padding="12,6"
                                Background="#F9FAFB"
                                BorderBrush="#E4E7EC"
                                BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="CATEGORIA" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="VOCI" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="COSTO NETTO" />
                                    <TextBlock
                                        Grid.Column="3"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="PREZZO VENDITA" />
                                </Grid>
                            </Border>

                            <!--  Sezioni materiali  -->
                            <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding MaterialSections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:MaterialSectionVM}">
                                        <Border
                                            Margin="0,0,0,4"
                                            Background="White"
                                            BorderBrush="#E4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <StackPanel>
                                                <!--  Header sezione materiali  -->
                                                <Grid
                                                    Height="36"
                                                    Background="#FAFBFC"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="MaterialSectionRow_Click">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="50" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel
                                                        Grid.Column="0"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">
                                                        <Path
                                                            Width="7"
                                                            Height="9"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Data="M 0,0 L 4.5,4.5 L 0,9"
                                                            Stroke="#9CA3AF"
                                                            StrokeThickness="1.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <TextBlock
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="#1A1D26"
                                                            Text="{Binding Name}" />
                                                    </StackPanel>

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="#6B7280"
                                                        Text="{Binding ItemCount}" />

                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="#1A1D26">
                                                        <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                    </TextBlock>

                                                    <TextBlock
                                                        Grid.Column="3"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Foreground="#4F6EF7">
                                                        <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                    </TextBlock>
                                                </Grid>

                                                <!--  Dettaglio materiali  -->
                                                <Border Padding="12,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel>
                                                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource MaterialItemsGrid}" />

                                                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                                            <Button
                                                                Margin="0,0,8,0"
                                                                Padding="12,6"
                                                                Click="BtnAddMaterialItem_Click"
                                                                Content="➕ Riga Materiale"
                                                                FontSize="11"
                                                                Style="{StaticResource PrimaryButton}"
                                                                Tag="{Binding Id}" />
                                                            <Button
                                                                Padding="12,6"
                                                                Click="BtnAddCommission_Click"
                                                                Content="💰 Provvigione"
                                                                FontSize="11"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Tag="{Binding Id}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Totali materiali  -->
                            <Border
                                Margin="0,8,0,0"
                                Padding="16,10"
                                Background="#1A1D26"
                                CornerRadius="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Width="200"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="TOTALE MATERIALI" />
                                    <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#9CA3AF"
                                            Text="Netto: " />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding GrandMaterialCost, StringFormat=N2}" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="White"
                                            Text=" €" />
                                    </StackPanel>
                                    <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#9CA3AF"
                                            Text="Vendita: " />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="#4F6EF7"
                                            Text="{Binding GrandMaterialSale, StringFormat=N2}" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#4F6EF7"
                                            Text=" €" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!--  ========== SCHEDA PREZZI ==========  -->
                    <Border
                        Margin="0,0,0,16"
                        Padding="16"
                        Background="White"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="#1A1D26"
                                Text="SCHEDA PREZZI" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--  NET COST  -->
                                <Border
                                    Grid.Row="0"
                                    Grid.ColumnSpan="3"
                                    Margin="0,0,0,8"
                                    Padding="12,8"
                                    Background="#F3F4F6"
                                    CornerRadius="4">
                                    <DockPanel>
                                        <TextBlock
                                            DockPanel.Dock="Right"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="#1A1D26">
                                            <Run Text="{Binding NetPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#6B7280"
                                            Text="NET COST (risorse + materiali + trasferte)" />
                                    </DockPanel>
                                </Border>

                                <!--  Contingency  -->
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="8,4,0,4"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#6B7280"
                                    Text="+ Contingency" />

                                <TextBox
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="80"
                                    HorizontalAlignment="Right"
                                    GotFocus="MarkupTextBox_GotFocus"
                                    KeyDown="PricingPct_KeyDown"
                                    LostFocus="PricingPct_LostFocus"
                                    Style="{StaticResource NumericTextBox}"
                                    Tag="contingency"
                                    Text="{Binding ContingencyPct, Converter={StaticResource PctToString}, Mode=OneWay}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#1A1D26"
                                    Text="{Binding ContingencyAmount, StringFormat=N2}" />

                                <!--  OFFER PRICE  -->
                                <Border
                                    Grid.Row="2"
                                    Grid.ColumnSpan="3"
                                    Margin="0,12,0,12"
                                    Padding="12,8"
                                    Background="#1A1D26"
                                    CornerRadius="4">
                                    <DockPanel>
                                        <TextBlock
                                            DockPanel.Dock="Right"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="#4F6EF7">
                                            <Run Text="{Binding OfferPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="OFFER PRICE" />
                                    </DockPanel>
                                </Border>

                                <!--  Margine trattativa  -->
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="8,4,0,4"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#6B7280"
                                    Text="+ Margine trattativa" />

                                <TextBox
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Width="80"
                                    HorizontalAlignment="Right"
                                    GotFocus="MarkupTextBox_GotFocus"
                                    KeyDown="PricingPct_KeyDown"
                                    LostFocus="PricingPct_LostFocus"
                                    Style="{StaticResource NumericTextBox}"
                                    Tag="negotiation"
                                    Text="{Binding NegotiationMarginPct, Converter={StaticResource PctToString}, Mode=OneWay}" />

                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#1A1D26"
                                    Text="{Binding NegotiationMarginAmount, StringFormat=N2}" />

                                <!--  FINAL OFFER PRICE  -->
                                <Border
                                    Grid.Row="4"
                                    Grid.ColumnSpan="3"
                                    Margin="0,8,0,0"
                                    Padding="12,10"
                                    Background="#059669"
                                    CornerRadius="4">
                                    <DockPanel>
                                        <TextBlock
                                            DockPanel.Dock="Right"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Foreground="White">
                                            <Run Text="{Binding FinalOfferPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="FINAL OFFER PRICE" />
                                    </DockPanel>
                                </Border>

                                <!--  Pulsante ridistribuzione  -->
                                <Button
                                    Grid.Row="5"
                                    Grid.ColumnSpan="3"
                                    Margin="0,12,0,0"
                                    Padding="14,8"
                                    HorizontalAlignment="Left"
                                    Click="BtnGenerateDistribution_Click"
                                    Content="🔄 Ridistribuisci (reset pin)"
                                    FontSize="11"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="{Binding IsOfferMode, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  ═══ DISTRIBUZIONE PREZZO (offer only) ═══  -->
                    <StackPanel Visibility="{Binding IsOfferMode, Converter={StaticResource BoolToVis}}">
                        <Border
                            Height="1"
                            Margin="0,20,0,0"
                            Background="#E4E7EC" />
                        <TextBlock
                            Margin="0,12,0,8"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="DISTRIBUZIONE PREZZO" />

                        <!--  4 Summary Cards  -->
                        <UniformGrid Margin="0,0,0,12" Columns="4">
                            <Border
                                Margin="0,0,4,0"
                                Padding="12,10"
                                Background="White"
                                BorderBrush="#E4E7EC"
                                BorderThickness="1">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="RISORSE" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="#2563EB">
                                        <Run Text="{Binding ResourceDistributed, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="2,0"
                                Padding="12,10"
                                Background="White"
                                BorderBrush="#E4E7EC"
                                BorderThickness="1">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="MATERIALI" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="#7C3AED">
                                        <Run Text="{Binding MaterialDistributed, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="2,0"
                                Padding="12,10"
                                Background="White"
                                BorderBrush="#E4E7EC"
                                BorderThickness="1">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#6B7280"
                                        Text="TRASFERTE" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="#D97706">
                                        <Run Text="{Binding TravelDistributed, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="4,0,0,0"
                                Padding="12,10"
                                Background="#059669"
                                BorderThickness="0">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#FFFFFFB0"
                                        Text="TOTALE OFFERTA" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White">
                                        <Run Text="{Binding FinalOfferPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!--  Distribution table (editable)  -->
                        <Border
                            Background="White"
                            BorderBrush="#E4E7EC"
                            BorderThickness="1">
                            <StackPanel>
                                <!--  Header  -->
                                <Grid Height="28" Background="#F9FAFB">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="25" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="25" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="25" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="#6B7280" Text="👁" ToolTip="Shadow: nascondi voce e spalma costo" />
                                    <TextBlock Grid.Column="2" Margin="4,0" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="SEZIONE" />
                                    <TextBlock Grid.Column="3" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="VENDITA" />
                                    <TextBlock Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#D97706" Text="CONT %" />
                                    <TextBlock Grid.Column="6" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#D97706" Text="CONT €" />
                                    <TextBlock Grid.Column="8" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#7C3AED" Text="MARG %" />
                                    <TextBlock Grid.Column="9" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#7C3AED" Text="MARG €" />
                                    <TextBlock Grid.Column="10" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#0891B2" Text="SHADOW €" />
                                    <TextBlock Grid.Column="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#0891B2" Text="SH %" />
                                    <TextBlock Grid.Column="12" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="#1A1D26" Text="TOTALE SEZ." />
                                </Grid>
                                <!--  Rows  -->
                                <ItemsControl ItemsSource="{Binding DistributionRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="0,3"
                                                BorderBrush="#F3F4F6"
                                                BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="25" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="25" />
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="25" />
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="110" />
                                                    </Grid.ColumnDefinitions>
                                                    <!--  Eye toggle  -->
                                                    <Button
                                                        Grid.Column="0"
                                                        Width="22" Height="22"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Click="ShadowToggle_Click"
                                                        Content="{Binding EyeIcon, Mode=OneWay}"
                                                        Cursor="Hand"
                                                        FontSize="12"
                                                        Padding="0"
                                                        ToolTip="Nascondi voce e spalma costo sulle altre" />
                                                    <!--  Badge R/M  -->
                                                    <Border
                                                        Grid.Column="1"
                                                        Width="18"
                                                        Height="18"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding TypeBadgeColor, Converter={StaticResource HexToAlphaBrush}, ConverterParameter=30}"
                                                        CornerRadius="2">
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="9"
                                                            FontWeight="Bold"
                                                            Foreground="{Binding TypeBadgeColor, Converter={StaticResource HexToBrush}}"
                                                            Text="{Binding TypeBadge}" />
                                                    </Border>
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Margin="4,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="#1A1D26"
                                                        Text="{Binding SectionName}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Grid.Column="3"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="#6B7280">
                                                        <Run Text="{Binding DisplaySaleAmount, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                                    <TextBlock
                                                        Grid.Column="4"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Text="{Binding ContingencyPinIcon, Mode=OneWay}"
                                                        ToolTip="Bloccato manualmente" />
                                                    <TextBox
                                                        Grid.Column="5"
                                                        Height="22"
                                                        Foreground="#D97706"
                                                        GotFocus="MarkupTextBox_GotFocus"
                                                        KeyDown="DistPct_KeyDown"
                                                        LostFocus="DistPct_LostFocus"
                                                        Style="{StaticResource NumericTextBox}"
                                                        Tag="contingency"
                                                        Text="{Binding ContingencyPct, Converter={StaticResource PctToString}, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="6"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="#D97706">
                                                        <Run Text="{Binding ContingencyAmount, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                                    <TextBlock
                                                        Grid.Column="7"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Text="{Binding MarginPinIcon, Mode=OneWay}"
                                                        ToolTip="Bloccato manualmente" />
                                                    <TextBox
                                                        Grid.Column="8"
                                                        Height="22"
                                                        Foreground="#7C3AED"
                                                        GotFocus="MarkupTextBox_GotFocus"
                                                        KeyDown="DistPct_KeyDown"
                                                        LostFocus="DistPct_LostFocus"
                                                        Style="{StaticResource NumericTextBox}"
                                                        Tag="margin"
                                                        Text="{Binding MarginPct, Converter={StaticResource PctToString}, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="9"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="#7C3AED">
                                                        <Run Text="{Binding MarginAmount, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                                    <TextBlock
                                                        Grid.Column="10"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="#0891B2">
                                                        <Run Text="{Binding ShadowedAmount, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                                    <TextBlock
                                                        Grid.Column="11"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Foreground="#0891B2"
                                                        Text="{Binding ShadowedPct, Converter={StaticResource PctToString}, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="12"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="#1A1D26">
                                                        <Run Text="{Binding SectionTotal, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!--  Footer  -->
                                <Border
                                    Padding="0,5"
                                    Background="#F3F4F6"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="25" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="25" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="25" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="4,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="#1A1D26"
                                            Text="TOTALE" />
                                        <TextBlock
                                            Grid.Column="3"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="#1A1D26">
                                            <Run Text="{Binding TotalCombinedSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                        <TextBlock
                                            Grid.Column="6"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="#D97706">
                                            <Run Text="{Binding TotalDistContingencyCheck, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                        <TextBlock
                                            Grid.Column="9"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="#7C3AED">
                                            <Run Text="{Binding TotalDistMarginCheck, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                        <TextBlock
                                            Grid.Column="12"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="#059669">
                                            <Run Text="{Binding FinalOfferPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Status Bar (footer)  -->
        <Border
            Grid.Row="2"
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0">
            <TextBlock
                FontSize="11"
                Foreground="#6B7280"
                Text="{Binding StatusText}" />
        </Border>
    </Grid>
</UserControl>