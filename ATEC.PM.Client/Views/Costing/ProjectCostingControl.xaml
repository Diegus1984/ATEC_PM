>>>>>>> v1
                                                                                 Visibility="{Binding DataContext.IsOfferMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                                                                    </Grid>

                                                                    <!-- Dettaglio Sezione (espanso) -->
                                                                    <Border Padding="12,8"
                                                                            Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                                                        <StackPanel>
                                                                            <ContentControl Content="{Binding}">
                                                                                <ContentControl.Style>
                                                                                    <Style TargetType="ContentControl">
                                                                                        <Setter Property="ContentTemplate" Value="{StaticResource ResourceGridInSede}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsDaCliente}" Value="True">
                                                                                                <Setter Property="ContentTemplate" Value="{StaticResource ResourceGridDaCliente}" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </ContentControl.Style>
                                                                            </ContentControl>

                                                                            <Button Style="{StaticResource PrimaryButton}"
                                                                                    Content="➕ Aggiungi Risorsa"
                                                                                    HorizontalAlignment="Left"
                                                                                    Margin="0,8,0,0"
                                                                                    Padding="12,6"
                                                                                    FontSize="11"
                                                                                    Click="BtnAddResource_Click"
                                                                                    Tag="{Binding Id}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Content="➕ Aggiungi Sezione"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,8,0,4"
                                                        Padding="12,6"
                                                        FontSize="11"
                                                        Click="BtnAddSection_Click"
                                                        Tag="{Binding Name}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Totali Risorse -->
                            <Border Margin="0,8,0,0"
                                    Padding="16,10"
                                    Background="#1A1D26"
                                    CornerRadius="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="200"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Text="TOTALE RISORSE" />
                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                        <TextBlock Text="Netto: " FontSize="13" Foreground="#9CA3AF"/>
                                        <TextBlock Text="{Binding GrandTotalCost, StringFormat=N2}" 
                                                   FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text=" €" FontSize="13" Foreground="White"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                        <TextBlock Text="Vendita: " FontSize="13" Foreground="#9CA3AF"/>
                                        <TextBlock Text="{Binding GrandTotalSale, StringFormat=N2}" 
                                                   FontSize="13" FontWeight="Bold" Foreground="#4F6EF7"/>
                                        <TextBlock Text=" €" FontSize="13" Foreground="#4F6EF7"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ========== SEZIONE MATERIALI ========== -->
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="0"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Header materiali -->
                            <Border Background="#F9FAFB"
                                    Padding="16,12"
                                    CornerRadius="8,8,0,0">
                                <TextBlock Text="MATERIALI"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#1A1D26"/>
                            </Border>

                            <!-- Intestazione colonne -->
                            <Border Padding="12,6"
                                    Background="#F9FAFB"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="CATEGORIA" />
                                    <TextBlock Grid.Column="1" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="VOCI" />
                                    <TextBlock Grid.Column="2" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="COSTO NETTO" />
                                    <TextBlock Grid.Column="3" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="PREZZO VENDITA" />
                                </Grid>
                            </Border>

                            <!-- Sezioni materiali -->
                            <ItemsControl ItemsSource="{Binding MaterialSections}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:MaterialSectionVM}">
                                        <Border Margin="0,0,0,4"
                                                Background="White"
                                                BorderBrush="#E4E7EC"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <StackPanel>
                                                <!-- Header sezione materiali -->
                                                <Grid Background="#FAFBFC"
                                                      Cursor="Hand"
                                                      MouseLeftButtonDown="MaterialSectionRow_Click"
                                                      Height="36">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="50" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Margin="12,0,0,0"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <Path Width="7"
                                                              Height="9"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Center"
                                                              Data="M 0,0 L 4.5,4.5 L 0,9"
                                                              Stroke="#9CA3AF"
                                                              StrokeThickness="1.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1A1D26"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ItemCount}"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               Foreground="#6B7280"/>

                                                    <TextBlock Grid.Column="2"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1A1D26">
                                                        <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                    </TextBlock>

                                                    <TextBlock Grid.Column="3"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="#4F6EF7">
                                                        <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                    </TextBlock>
                                                </Grid>

                                                <!-- Dettaglio materiali -->
                                                <Border Padding="12,8"
                                                        Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel>
                                                        <ContentControl Content="{Binding}" 
                                                                        ContentTemplate="{StaticResource MaterialItemsGrid}" />

                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                            <Button Style="{StaticResource PrimaryButton}"
                                                                    Content="➕ Riga Materiale"
                                                                    Padding="12,6"
                                                                    FontSize="11"
                                                                    Click="BtnAddMaterialItem_Click"
                                                                    Tag="{Binding Id}"
                                                                    Margin="0,0,8,0"/>
                                                            <Button Style="{StaticResource SecondaryButton}"
                                                                    Content="💰 Provvigione"
                                                                    Padding="12,6"
                                                                    FontSize="11"
                                                                    Click="BtnAddCommission_Click"
                                                                    Tag="{Binding Id}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Totali materiali -->
                            <Border Margin="0,8,0,0"
                                    Padding="16,10"
                                    Background="#1A1D26"
                                    CornerRadius="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="200"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Text="TOTALE MATERIALI" />
                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                        <TextBlock Text="Netto: " FontSize="13" Foreground="#9CA3AF"/>
                                        <TextBlock Text="{Binding GrandMaterialCost, StringFormat=N2}" 
                                                   FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text=" €" FontSize="13" Foreground="White"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                        <TextBlock Text="Vendita: " FontSize="13" Foreground="#9CA3AF"/>
                                        <TextBlock Text="{Binding GrandMaterialSale, StringFormat=N2}" 
                                                   FontSize="13" FontWeight="Bold" Foreground="#4F6EF7"/>
                                        <TextBlock Text=" €" FontSize="13" Foreground="#4F6EF7"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ========== SCHEDA PREZZI ========== -->
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="SCHEDA PREZZI"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#1A1D26"
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- NET COST -->
                                <Border Grid.Row="0"
                                        Grid.ColumnSpan="3"
                                        Background="#F3F4F6"
                                        Padding="12,8"
                                        CornerRadius="4"
                                        Margin="0,0,0,8">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#1A1D26">
                                            <Run Text="{Binding NetPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                        </TextBlock>
                                        <TextBlock Text="NET COST (risorse + materiali + trasferte)"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#6B7280"/>
                                    </DockPanel>
                                </Border>

                                <!-- Contingency -->
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="+ Contingency"
                                           VerticalAlignment="Center"
                                           Margin="8,4,0,4"
                                           FontSize="12"
                                           Foreground="#6B7280"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource NumericTextBox}"
                                         Width="80"
                                         HorizontalAlignment="Right"
                                         Tag="contingency"
                                         Text="{Binding ContingencyPct, Converter={StaticResource PctToString}, UpdateSourceTrigger=LostFocus}"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="{Binding ContingencyAmount, StringFormat=N2}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="12"
                                           Foreground="#1A1D26"/>

                                <!-- OFFER PRICE -->
                                <Border Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Background="#1A1D26"
                                        Padding="12,8"
                                        CornerRadius="4"
                                        Margin="0,12,0,12">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#4F6EF7">
                                            <Run Text="{Binding OfferPrice, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                        </TextBlock>
                                        <TextBlock Text="OFFER PRICE"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </DockPanel>
                                </Border>

                                <!-- Margine trattativa -->
                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="+ Margine trattativa"
                                           VerticalAlignment="Center"
                                           Margin="8,4,0,4"
                                           FontSize="12"
                                           Foreground="#6B7280"/>

                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Style="{StaticResource NumericTextBox}"
                                         Width="80"
                                         HorizontalAlignment="Right"
