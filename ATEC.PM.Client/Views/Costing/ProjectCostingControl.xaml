<UserControl
    x:Class="ATEC.PM.Client.Views.Costing.ProjectCostingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:ATEC.PM.Client.Views.Costing.Converters"
    xmlns:vm="clr-namespace:ATEC.PM.Client.Views.Costing.ViewModels"
    Background="#F7F8FA">

    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexToBrush" />
        <conv:HexToAlphaBrushConverter x:Key="HexToAlphaBrush" />
        <conv:EuroCurrencyConverter x:Key="EuroCurrency" />
        <conv:BoolToAngleConverter x:Key="BoolToAngle" />
        <conv:DaClienteToVisibilityConverter x:Key="DaClienteToVisibility" />
        <conv:MarkupToStringConverter x:Key="MarkupToString" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--  Stili DataGrid condivisi  -->
        <Style x:Key="CostingColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="CostingCell" TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  ═══════════════════════════════════════════════  -->
        <!--  DataGrid risorse IN_SEDE  -->
        <!--  ═══════════════════════════════════════════════  -->
        <DataTemplate x:Key="ResourceGridInSede">
            <DataGrid
                AutoGenerateColumns="False"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CellEditEnding="ResourceGrid_CellEditEnding"
                CellStyle="{StaticResource CostingCell}"
                ColumnHeaderHeight="28"
                ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                FontSize="12"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#F3F4F6"
                ItemsSource="{Binding Resources}"
                RowHeight="32"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ResourceName}"
                        Header="RISORSA"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="50"
                        Binding="{Binding WorkDays, StringFormat=F0}"
                        Header="GG" />
                    <DataGridTextColumn
                        Width="55"
                        Binding="{Binding HoursPerDay, StringFormat=F0}"
                        Header="ORE/G" />
                    <DataGridTextColumn
                        Width="65"
                        Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}"
                        Header="TOT ORE"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="60"
                        Binding="{Binding HourlyCost, StringFormat=F2}"
                        Header="€/H"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                        Header="TOT €"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <!--  ═══════════════════════════════════════════════  -->
        <!--  DataGrid risorse DA_CLIENTE (con trasferta)  -->
        <!--  ═══════════════════════════════════════════════  -->
        <DataTemplate x:Key="ResourceGridDaCliente">
            <StackPanel>
                <DataGrid
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CellEditEnding="ResourceGrid_CellEditEnding"
                    CellStyle="{StaticResource CostingCell}"
                    ColumnHeaderHeight="28"
                    ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                    FontSize="12"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#F3F4F6"
                    ItemsSource="{Binding Resources}"
                    RowHeight="32"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ResourceName}"
                            Header="RISORSA"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding WorkDays, StringFormat=F0}"
                            Header="GG" />
                        <DataGridTextColumn
                            Width="55"
                            Binding="{Binding HoursPerDay, StringFormat=F0}"
                            Header="ORE/G" />
                        <DataGridTextColumn
                            Width="65"
                            Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}"
                            Header="TOT ORE"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding HourlyCost, StringFormat=F2}"
                            Header="€/H"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}"
                            Header="TOT €"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding NumTrips}"
                            Header="VIAGGI" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding KmPerTrip, StringFormat=F0}"
                            Header="KM" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding CostPerKm, StringFormat=F2}"
                            Header="€/KM" />
                        <DataGridTextColumn
                            Width="55"
                            Binding="{Binding DailyFood, StringFormat=F0}"
                            Header="VITTO/G" />
                        <DataGridTextColumn
                            Width="55"
                            Binding="{Binding DailyHotel, StringFormat=F0}"
                            Header="HOTEL/G" />
                        <DataGridTextColumn
                            Width="55"
                            Binding="{Binding AllowanceDays, StringFormat=F0}"
                            Header="GG IND." />
                        <DataGridComboBoxColumn
                            Width="70"
                            Header="€/G IND."
                            SelectedItemBinding="{Binding DailyAllowance, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{x:Static vm:CostResourceVM.AllowanceOptions}" />
                                    <Setter Property="IsReadOnly" Value="True" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{x:Static vm:CostResourceVM.AllowanceOptions}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--  Subtotali trasferta  -->
                <Border
                    Margin="0,4,0,0"
                    Padding="8,6"
                    Background="#F9FAFB"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#1A1D26"
                            Text="Subtotali" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#1A1D26">
                            <Run Text="Ore: " /><Run Text="{Binding TotalCostOre, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                        </TextBlock>
                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#1A1D26">
                            <Run Text="Viaggi: " /><Run Text="{Binding TotalViaggi, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                        </TextBlock>
                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Right"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#1A1D26">
                            <Run Text="Vitto/Alloggio: " /><Run Text="{Binding TotalAlloggio, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                        </TextBlock>
                        <TextBlock
                            Grid.Column="4"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#1A1D26">
                            <Run Text="Indennità: " /><Run Text="{Binding TotalIndennita, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                        </TextBlock>
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!--  STATUS BAR  -->
        <Border
            Padding="12,8"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <TextBlock
                FontSize="12"
                Foreground="#6B7280"
                Text="{Binding StatusText}" />
        </Border>

        <!--  INIT PANEL  -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding ShowInit, Converter={StaticResource BoolToVis}}">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="16"
                Foreground="#6B7280"
                Text="Configurazione costi non ancora inizializzata." />
            <Button
                Width="200"
                Height="36"
                Margin="0,16,0,0"
                Background="#4F6EF7"
                BorderThickness="0"
                Click="BtnInit_Click"
                Content="Inizializza Configurazione"
                Cursor="Hand"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="White" />
        </StackPanel>

        <!--  CONTENT  -->
        <ScrollViewer
            Padding="16"
            VerticalScrollBarVisibility="Auto"
            Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}">
            <StackPanel>

                <!--  LEGENDA COLONNE  -->
                <Border
                    Margin="0,0,0,4"
                    Padding="12,6"
                    Background="#F9FAFB"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="SEZIONE" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="QTÀ" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="COSTO NETTO" />
                        <TextBlock
                            Grid.Column="3"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="K RICARICO" />
                        <TextBlock
                            Grid.Column="4"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="PREZZO VENDITA" />
                        <TextBlock
                            Grid.Column="5"
                            HorizontalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="TIPO" />
                    </Grid>
                </Border>

                <!--  GRUPPI  -->
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CostGroupVM}">
                            <Expander Margin="0,8,0,0" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                <Expander.Style>
                                    <Style BasedOn="{StaticResource SmoothExpander}" TargetType="Expander" />
                                </Expander.Style>
                                <Expander.Header>
                                    <Border Padding="12,6" Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                        <DockPanel>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                DockPanel.Dock="Right"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="#C8FFFFFF">
                                                <Run Text="Netto " /><Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" />
                                                <Run Text=" €  →  Vendita " /><Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                            </TextBlock>
                                            <TextBlock
                                                Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Name}" />
                                        </DockPanel>
                                    </Border>
                                </Expander.Header>

                                <ItemsControl ItemsSource="{Binding Sections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CostSectionVM}">
                                            <Border
                                                Margin="0,0,0,2"
                                                Background="White"
                                                BorderBrush="#E4E7EC"
                                                BorderThickness="1">
                                                <StackPanel>

                                                    <!--  RIGA SOMMARIO  -->
                                                    <Grid
                                                        Background="#FAFBFC"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="SectionRow_Click">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="50" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="70" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel
                                                            Grid.Column="0"
                                                            Margin="12,8,0,8"
                                                            Orientation="Horizontal">
                                                            <TextBlock
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="9"
                                                                Foreground="#9CA3AF"
                                                                RenderTransformOrigin="0.5,0.5"
                                                                Text="▶">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="#1A1D26"
                                                                Text="{Binding Name}" />
                                                        </StackPanel>

                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="#6B7280"
                                                            Text="{Binding ResourceCount}" />

                                                        <TextBlock
                                                            Grid.Column="2"
                                                            Margin="0,0,8,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="#1A1D26">
                                                            <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                        </TextBlock>

                                                        <TextBox
                                                            Grid.Column="3"
                                                            Width="60"
                                                            Height="24"
                                                            Margin="0,0,8,0"
                                                            Padding="2,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            HorizontalContentAlignment="Center"
                                                            Background="#05966910"
                                                            BorderBrush="#05966940"
                                                            BorderThickness="1"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            Foreground="#059669"
                                                            GotFocus="MarkupTextBox_GotFocus"
                                                            KeyDown="MarkupTextBox_KeyDown"
                                                            LostFocus="MarkupTextBox_LostFocus"
                                                            PreviewMouseLeftButtonDown="MarkupTextBox_PreviewMouseDown"
                                                            Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, UpdateSourceTrigger=LostFocus}" />

                                                        <TextBlock
                                                            Grid.Column="4"
                                                            Margin="0,0,8,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            Foreground="#4F6EF7">
                                                            <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                        </TextBlock>

                                                        <Border
                                                            Grid.Column="5"
                                                            Padding="4,2"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding TypeColor, Converter={StaticResource HexToAlphaBrush}, ConverterParameter=20}">
                                                            <TextBlock
                                                                FontSize="9"
                                                                FontWeight="Bold"
                                                                Foreground="{Binding TypeColor, Converter={StaticResource HexToBrush}}"
                                                                Text="{Binding TypeLabel}" />
                                                        </Border>
                                                    </Grid>

                                                    <!--  DETTAGLIO RISORSE  -->
                                                    <Border Padding="8,4,8,8" Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                                                        <StackPanel>
                                                            <ContentControl Content="{Binding}">
                                                                <ContentControl.Style>
                                                                    <Style TargetType="ContentControl">
                                                                        <Setter Property="ContentTemplate" Value="{StaticResource ResourceGridInSede}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDaCliente}" Value="True">
                                                                                <Setter Property="ContentTemplate" Value="{StaticResource ResourceGridDaCliente}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ContentControl.Style>
                                                            </ContentControl>

                                                            <Button
                                                                Height="26"
                                                                Margin="0,4,0,0"
                                                                Padding="10,0"
                                                                HorizontalAlignment="Left"
                                                                Background="#4F6EF7"
                                                                BorderThickness="0"
                                                                Click="BtnAddResource_Click"
                                                                Content="+ Risorsa"
                                                                Cursor="Hand"
                                                                FontSize="11"
                                                                Foreground="White"
                                                                Tag="{Binding Id}" />
                                                        </StackPanel>
                                                    </Border>

                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  TOTALE GENERALE  -->
                <Border
                    Margin="0,8,0,0"
                    Padding="16,10"
                    Background="#1A1D26">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="200"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="TOTALE RISORSE" />
                        <TextBlock
                            Margin="20,0,0,0"
                            FontSize="13"
                            Foreground="#9CA3AF">
                            <Run Text="Netto: " /><Run Text="{Binding GrandTotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                        </TextBlock>
                        <TextBlock
                            Margin="20,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#4F6EF7">
                            <Run Text="Vendita: " /><Run Text="{Binding GrandTotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
