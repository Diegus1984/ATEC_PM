<UserControl
    x:Class="ATEC.PM.Client.Views.Costing.ProjectCostingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:ATEC.PM.Client.Views.Costing.ViewModels"
    MinWidth="900"
    MinHeight="800"
    Background="#F7F8FA"
    FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- Shadow Effects -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.1" Direction="270" Color="#AAAAAA"/>

        <!-- ========== STILI GLOBALI ========== -->

        <!-- Stile TextBox Numerico -->
        <Style x:Key="NumericTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1A1D26"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#9CA3AF"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4F6EF7"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F3F4F6"/>
                    <Setter Property="Foreground" Value="#9CA3AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stile Pulsante Principale -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F6EF7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B5FDF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2A4ABF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stile Pulsante Secondario -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4F6EF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4F6EF7"/>
        </Style>

        <!-- Stile DataGrid Columns -->
        <Style x:Key="CostingColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CostingCell" TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4F6EF720"/>
                    <Setter Property="BorderBrush" Value="#4F6EF7"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stile ComboBox -->
        <Style x:Key="InlineComboBox" TargetType="ComboBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="#4F6EF7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ========== DATA TEMPLATES ========== -->

        <DataTemplate x:Key="DeleteButtonTemplate">
            <Button Width="20" Height="20"
                    Background="#EF44441A"
                    BorderThickness="0"
                    Click="BtnDeleteResource_Click"
                    Cursor="Hand"
                    ToolTip="Elimina risorsa">
                <TextBlock Text="✕" FontSize="9" Foreground="#EF4444" FontWeight="Bold"/>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="DeleteMaterialButtonTemplate">
            <Button Width="20" Height="20"
                    Background="#EF44441A"
                    BorderThickness="0"
                    Click="BtnDeleteMaterialItem_Click"
                    Cursor="Hand"
                    ToolTip="Elimina materiale">
                <TextBlock Text="✕" FontSize="9" Foreground="#EF4444" FontWeight="Bold"/>
            </Button>
        </DataTemplate>

        <!-- Template Risorse In Sede -->
        <DataTemplate x:Key="ResourceGridInSede">
            <DataGrid AutoGenerateColumns="False"
                      BorderThickness="0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CellEditEnding="ResourceGrid_CellEditEnding"
                      CellStyle="{StaticResource CostingCell}"
                      ColumnHeaderHeight="28"
                      ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                      FontSize="12"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F3F4F6"
                      ItemsSource="{Binding Resources}"
                      RowHeight="36"
                      SelectionMode="Single"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#F9FAFB">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="2*" Header="RISORSA">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Padding="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding ResourceName}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox Style="{StaticResource InlineComboBox}"
                                          DisplayMemberPath="FullName"
                                          Loaded="EmployeeCombo_Loaded"
                                          SelectionChanged="EmployeeCombo_SelectionChanged"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          StaysOpenOnEdit="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Width="50" Header="GG" 
                                        Binding="{Binding WorkDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="55" Header="ORE/G"
                                        Binding="{Binding HoursPerDay, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="65" Header="TOT ORE" IsReadOnly="True"
                                        Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="70" Header="€/H" IsReadOnly="True"
                                        Binding="{Binding HourlyCost, StringFormat=N2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="Foreground" Value="#4F6EF7"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="90" Header="TOT €" IsReadOnly="True"
                                        Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="70" Header="K">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, 
                                               ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource NumericTextBox}"
                                         Width="50"
                                         HorizontalAlignment="Center"
                                         ToolTip="Markup applicato (es: 1.45 = 45%)"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Width="90" Header="VENDITA €" IsReadOnly="True"
                                        Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="Foreground" Value="#059669"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="30" Header=""
                                            CellTemplate="{StaticResource DeleteButtonTemplate}" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <!-- Template Risorse Da Cliente (con trasferte) -->
        <DataTemplate x:Key="ResourceGridDaCliente">
            <StackPanel>
                <DataGrid AutoGenerateColumns="False"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CellEditEnding="ResourceGrid_CellEditEnding"
                          CellStyle="{StaticResource CostingCell}"
                          ColumnHeaderHeight="28"
                          ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                          FontSize="12"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          HorizontalGridLinesBrush="#F3F4F6"
                          ItemsSource="{Binding Resources}"
                          RowHeight="36"
                          SelectionMode="Single"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#F9FAFB">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="2*" Header="RISORSA">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Padding="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding ResourceName}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Style="{StaticResource InlineComboBox}"
                                              DisplayMemberPath="FullName"
                                              Loaded="EmployeeCombo_Loaded"
                                              SelectionChanged="EmployeeCombo_SelectionChanged"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Width="45" Header="GG"
                                            Binding="{Binding WorkDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="50" Header="ORE/G"
                                            Binding="{Binding HoursPerDay, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="60" Header="TOT ORE" IsReadOnly="True"
                                            Binding="{Binding TotalHours, StringFormat=F1, Mode=OneWay}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="65" Header="€/H" IsReadOnly="True"
                                            Binding="{Binding HourlyCost, StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                    <Setter Property="Foreground" Value="#4F6EF7"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="85" Header="TOT €" IsReadOnly="True"
                                            Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="60" Header="K">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, 
                                                   ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource NumericTextBox}"
                                             Width="45"
                                             HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Width="85" Header="VENDITA €" IsReadOnly="True"
                                            Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                    <Setter Property="Foreground" Value="#059669"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="45" Header="VIAGGI"
                                            Binding="{Binding NumTrips, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="VIAGGI" ToolTip="Numero viaggi"/>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="45" Header="KM"
                                            Binding="{Binding KmPerTrip, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="KM" ToolTip="Km per viaggio"/>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="50" Header="€/KM"
                                            Binding="{Binding CostPerKm, StringFormat=N2, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="€/KM" ToolTip="Costo al chilometro"/>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="50" Header="VITTO/G"
                                            Binding="{Binding DailyFood, StringFormat=N0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="VITTO/G" ToolTip="Vitto giornaliero"/>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="50" Header="HOTEL/G"
                                            Binding="{Binding DailyHotel, StringFormat=N0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="HOTEL/G" ToolTip="Hotel giornaliero"/>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Width="50" Header="GG IND."
                                            Binding="{Binding AllowanceDays, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="GG IND." ToolTip="Giorni indennità"/>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="70" Header="€/G IND.">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="€/G IND." ToolTip="Indennità giornaliera"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{x:Static vm:CostResourceVM.AllowanceOptions}"
                                              SelectedItem="{Binding DailyAllowance, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource InlineComboBox}"
                                              Width="60"
                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="30" Header=""
                                                CellTemplate="{StaticResource DeleteButtonTemplate}" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Subtotali -->
                <Border Margin="0,4,0,0"
                        Padding="12,8"
                        Background="#F9FAFB"
                        BorderBrush="#E4E7EC"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1D26"
                                   Text="SUBTOTALI"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Ore: " FontSize="11" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalCostOre, StringFormat=N2}" 
                                       FontSize="11" FontWeight="Bold" Foreground="#1A1D26"/>
                            <TextBlock Text=" €" FontSize="11" Foreground="#1A1D26"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Viaggi: " FontSize="11" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalViaggi, StringFormat=N2}" 
                                       FontSize="11" FontWeight="Bold" Foreground="#1A1D26"/>
                            <TextBlock Text=" €" FontSize="11" Foreground="#1A1D26"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Vitto/Alloggio: " FontSize="11" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalAlloggio, StringFormat=N2}" 
                                       FontSize="11" FontWeight="Bold" Foreground="#1A1D26"/>
                            <TextBlock Text=" €" FontSize="11" Foreground="#1A1D26"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                            <TextBlock Text="Indennità: " FontSize="11" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalIndennita, StringFormat=N2}" 
                                       FontSize="11" FontWeight="Bold" Foreground="#1A1D26"/>
                            <TextBlock Text=" €" FontSize="11" Foreground="#1A1D26"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Template Material Items -->
        <DataTemplate x:Key="MaterialItemsGrid">
            <DataGrid AutoGenerateColumns="False"
                      BorderThickness="0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CellEditEnding="MaterialGrid_CellEditEnding"
                      CellStyle="{StaticResource CostingCell}"
                      ColumnHeaderHeight="28"
                      ColumnHeaderStyle="{StaticResource CostingColumnHeader}"
                      FontSize="12"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F3F4F6"
                      ItemsSource="{Binding Items}"
                      RowHeight="36"
                      SelectionMode="Single"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#F9FAFB">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="3*" Header="DESCRIZIONE"
                                        Binding="{Binding Description, UpdateSourceTrigger=LostFocus}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="8,0,0,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="60" Header="QTÀ"
                                        Binding="{Binding Quantity, StringFormat=F0, UpdateSourceTrigger=LostFocus}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="100" Header="COSTO UNIT."
                                        Binding="{Binding UnitCost, StringFormat=N2, UpdateSourceTrigger=LostFocus}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="100" Header="COSTO TOT." IsReadOnly="True"
                                        Binding="{Binding TotalCost, StringFormat=N2, Mode=OneWay}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="80" Header="K">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MarkupValue, Converter={StaticResource MarkupToString}, 
                                               ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource NumericTextBox}"
                                         Width="60"
                                         HorizontalAlignment="Center"
                                         ToolTip="Markup applicato"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Width="120" Header="PREZZO VENDITA" IsReadOnly="True"
                                        Binding="{Binding TotalSale, StringFormat=N2, Mode=OneWay}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="Foreground" Value="#059669"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="40" Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="4,2"
                                        Background="#F3F4F6"
                                        CornerRadius="4"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding ItemType, Converter={StaticResource ItemTypeToBadge}}"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="#4F6EF7"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="30" Header=""
                                            CellTemplate="{StaticResource DeleteMaterialButtonTemplate}" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- ========== LAYOUT PRINCIPALE ========== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Padding="16,10"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stato -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Azioni rapide -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="💾 Salva"
                            Style="{StaticResource PrimaryButton}"
                            Padding="10,4"
                            Click="BtnSaveAll_Click"
                            Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENUTO PRINCIPALE -->
        <Grid Grid.Row="1">
            <!-- Stato Inizializzazione -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowInit, Converter={StaticResource BoolToVis}}">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="16"
                           Foreground="#6B7280"
                           Text="Configurazione costi non ancora inizializzata."
                           Margin="0,0,0,16"/>
                <Button Width="240"
                        Height="40"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnInit_Click"
                        Content="🚀 Inizializza Configurazione"
                        FontSize="14"/>
            </StackPanel>

            <!-- Contenuto Principale con Scroll -->
            <ScrollViewer Padding="16"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!-- ========== SEZIONE RISORSE ========== -->
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="0"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Header sezione risorse -->
                            <Border Background="#F9FAFB"
                                    Padding="16,12"
                                    CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IMPEGNO RISORSE"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1A1D26"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="➕ Nuovo Gruppo"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="BtnAddGroup_Click"
                                                Margin="0,0,8,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Intestazione colonne riepilogo -->
                            <Border Padding="12,6"
                                    Background="#F9FAFB"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="SEZIONE" />
                                    <TextBlock Grid.Column="1" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="QTÀ" />
                                    <TextBlock Grid.Column="2" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="COSTO NETTO" />
                                    <TextBlock Grid.Column="3" Margin="0,0,8,0" HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="PREZZO VENDITA" />
                                    <TextBlock Grid.Column="4" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Text="TIPO" />
                                    <TextBlock Grid.Column="5" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#D97706" Text="CONT.%">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfferMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="6" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#7C3AED" Text="MARG.%">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfferMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Gruppi e Sezioni -->
                            <ItemsControl ItemsSource="{Binding Groups}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CostGroupVM}">
                                        <StackPanel Margin="0,4,0,0">

                                            <!-- Header Gruppo -->
                                            <Border Padding="12,8"
                                                    Background="{Binding Color, Converter={StaticResource HexToBrush}}"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="GroupHeader_Click"
                                                    CornerRadius="4">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="#C8FFFFFF">
                                                        <Run Text="Netto " />
                                                        <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" />
                                                        <Run Text=" €  →  Vendita " />
                                                        <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" />
                                                        <Run Text=" €" />
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="8"
                                                              Height="10"
                                                              Margin="4,0,8,0"
                                                              VerticalAlignment="Center"
                                                              Data="M 0,0 L 5,5 L 0,10"
                                                              RenderTransformOrigin="0.5,0.5"
                                                              Stroke="#FFFFFF90"
                                                              StrokeThickness="1.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource BoolToAngle}}" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>

                                            <!-- Contenuto Gruppo -->
                                            <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                        Margin="16,8,0,0">
                                                <ItemsControl ItemsSource="{Binding Sections}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:CostSectionVM}">
                                                            <Border Margin="0,0,0,4"
                                                                    Background="White"
                                                                    BorderBrush="#E4E7EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel>

                                                                    <!-- Header Sezione -->
                                                                    <Grid Background="#FAFBFC"
                                                                          Cursor="Hand"
                                                                          MouseLeftButtonDown="SectionRow_Click"
                                                                          Height="36">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="50" />
                                                                            <ColumnDefinition Width="120" />
                                                                            <ColumnDefinition Width="120" />
                                                                            <ColumnDefinition Width="70" />
                                                                            <ColumnDefinition Width="70" />
                                                                            <ColumnDefinition Width="70" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel Grid.Column="0"
                                                                                    Margin="12,0,0,0"
                                                                                    Orientation="Horizontal"
                                                                                    VerticalAlignment="Center">
                                                                            <Path Width="7"
                                                                                  Height="9"
                                                                                  Margin="0,0,8,0"
                                                                                  VerticalAlignment="Center"
                                                                                  Data="M 0,0 L 4.5,4.5 L 0,9"
                                                                                  Stroke="#9CA3AF"
                                                                                  StrokeThickness="1.5">
                                                                                <Path.RenderTransform>
                                                                                    <RotateTransform Angle="{Binding IsDetailExpanded, Converter={StaticResource BoolToAngle}}" />
                                                                                </Path.RenderTransform>
                                                                            </Path>
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       FontSize="13"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#1A1D26"/>
                                                                        </StackPanel>

                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding ResourceCount}"
                                                                                   HorizontalAlignment="Right"
                                                                                   Margin="0,0,8,0"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="12"
                                                                                   Foreground="#6B7280"/>

                                                                        <TextBlock Grid.Column="2"
                                                                                   HorizontalAlignment="Right"
                                                                                   Margin="0,0,8,0"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#1A1D26">
                                                                            <Run Text="{Binding TotalCost, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                                        </TextBlock>

                                                                        <TextBlock Grid.Column="3"
                                                                                   HorizontalAlignment="Right"
                                                                                   Margin="0,0,8,0"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="12"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#4F6EF7">
                                                                            <Run Text="{Binding TotalSale, StringFormat=N2, Mode=OneWay}" /><Run Text=" €" />
                                                                        </TextBlock>

                                                                        <Border Grid.Column="4"
                                                                                Padding="6,2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Background="#F3F4F6"
                                                                                CornerRadius="12">
                                                                            <TextBlock Text="{Binding TypeLabel}"
                                                                                       FontSize="9"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="#6B7280"/>
                                                                        </Border>

                                                                        <TextBox Grid.Column="5"
                                                                                 Width="50"
                                                                                 Height="22"
                                                                                 Style="{StaticResource NumericTextBox}"
                                                                                 Tag="contingency"
<<<<<<< HEAD
                                                                                 Text="{Binding ContingencyPct, Converter={StaticResource PctToString}, UpdateSourceTrigger=LostFocus}"
=======
                                                                                 IsReadOnly="True"
