<UserControl
    x:Class="ATEC.PM.Client.Views.Costing.BudgetVsActualControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Stile header colonne -->
        <Style x:Key="BvaColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="BvaCell" TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <!-- ═══ DataGrid PREVENTIVO (read-only) ═══ -->
        <DataTemplate x:Key="BudgetGrid">
            <DataGrid AutoGenerateColumns="False" BorderThickness="0" CanUserAddRows="False"
                      CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserResizeRows="False"
                      CellStyle="{StaticResource BvaCell}" ColumnHeaderHeight="26"
                      ColumnHeaderStyle="{StaticResource BvaColumnHeader}" FontSize="11.5"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F3F4F6" IsReadOnly="True"
                      ItemsSource="{Binding BudgetResources}" RowHeight="28" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding ResourceName}" Header="RISORSA" />
                    <DataGridTextColumn Width="50" Binding="{Binding WorkDays, StringFormat=F0}" Header="GG" />
                    <DataGridTextColumn Width="50" Binding="{Binding HoursPerDay, StringFormat=F0}" Header="H/G" />
                    <DataGridTextColumn Width="55" Binding="{Binding TotalHours, StringFormat=F1}" Header="ORE" />
                    <DataGridTextColumn Width="55" Binding="{Binding HourlyCost, StringFormat=F2}" Header="€/H" />
                    <DataGridTextColumn Width="70" Binding="{Binding TotalCost, StringFormat=N2}" Header="COSTO €" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <!-- ═══ DataGrid CONSUNTIVO (read-only) ═══ -->
        <DataTemplate x:Key="ActualGrid">
            <DataGrid AutoGenerateColumns="False" BorderThickness="0" CanUserAddRows="False"
                      CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserResizeRows="False"
                      CellStyle="{StaticResource BvaCell}" ColumnHeaderHeight="26"
                      ColumnHeaderStyle="{StaticResource BvaColumnHeader}" FontSize="11.5"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F3F4F6" IsReadOnly="True"
                      ItemsSource="{Binding ActualEntries}" RowHeight="28" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding EmployeeName}" Header="DIPENDENTE" />
                    <DataGridTextColumn Width="*" Binding="{Binding PhaseName}" Header="CAUSALE (FASE)" />
                    <DataGridTextColumn Width="65" Binding="{Binding EntryType}" Header="TIPO" />
                    <DataGridTextColumn Width="55" Binding="{Binding Hours, StringFormat=F1}" Header="ORE" />
                    <DataGridTextColumn Width="70" Binding="{Binding TotalCost, StringFormat=N2}" Header="COSTO €" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Loading -->
        <TextBlock x:Name="txtLoading" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14" Foreground="#9CA3AF" Text="Caricamento..." />

        <!-- Content -->
        <DockPanel x:Name="pnlContent" Visibility="Collapsed">

            <!-- ═══ BARRA TOTALI GENERALI ═══ -->
            <Border DockPanel.Dock="Bottom" Background="#1A1D26" Padding="16,10" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Totale preventivo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="PREVENTIVO  " />
                        <TextBlock x:Name="txtTotalBudgetHours" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="  h   " />
                        <TextBlock x:Name="txtTotalBudgetCost" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="  €" />
                    </StackPanel>

                    <!-- Totale consuntivo -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="CONSUNTIVO  " />
                        <TextBlock x:Name="txtTotalActualHours" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="  h   " />
                        <TextBlock x:Name="txtTotalActualCost" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="  €   " />
                        <TextBlock x:Name="txtTotalDelta" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ SCROLL AREA ═══ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel x:Name="pnlGroups" />
            </ScrollViewer>

        </DockPanel>

        <!-- Nessun dato -->
        <TextBlock x:Name="txtEmpty" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="13" Foreground="#9CA3AF" Visibility="Collapsed"
                   Text="Nessun dato di preventivazione disponibile. Configurare prima la commessa." />
    </Grid>
</UserControl>
