<Page x:Class="ATEC.PM.Client.Views.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">

    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderSearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Page.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ Nuovo" Background="#4F6EF7" Foreground="White" Style="{StaticResource FlatBtn}" Click="BtnNew_Click"/>
                    <Button x:Name="btnEdit" Content="Modifica" Background="#F3F4F6" Foreground="#374151" Style="{StaticResource FlatBtn}" Margin="8,0" Click="BtnEdit_Click" IsEnabled="False"/>
                    <Button x:Name="btnDelete" Content="Elimina" Background="#FEE2E2" Foreground="#DC2626" Style="{StaticResource FlatBtn}" Click="BtnDelete_Click" IsEnabled="False"/>
                    <Button Content="📥 Importa Easyfatt" Background="#DBEAFE" Foreground="#1D4ED8" Style="{StaticResource FlatBtn}" Margin="8,0" Click="BtnImportEasyfatt_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Reset Filtri" Background="Transparent" Foreground="#6B7280" Style="{StaticResource FlatBtn}" Click="BtnClearFilters_Click" Margin="0,0,8,0"/>
                    <Button Content="Aggiorna" Background="#F3F4F6" Foreground="#374151" Style="{StaticResource FlatBtn}" Click="BtnRefresh_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock x:Name="txtStatus" Text="Caricamento..." FontSize="12" Foreground="#6B7280"/>
        </Border>

        <DataGrid x:Name="dgCatalog" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="Dg_SelectionChanged" MouseDoubleClick="Dg_DoubleClick"
                  Background="White" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                  RowHeight="40" ColumnHeaderHeight="65" FontSize="13">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Code}" Width="120">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Codice" Foreground="#6B7280" FontWeight="Bold"/>
                                <TextBox Grid.Row="1" Style="{StaticResource HeaderSearchBox}" Tag="Code" Loaded="Filter_Loaded" TextChanged="Filter_Changed" ToolTip="Cerca codice..."/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Description}" Width="*">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Descrizione" Foreground="#6B7280" FontWeight="Bold"/>
                                <TextBox Grid.Row="1" Style="{StaticResource HeaderSearchBox}" Tag="Desc" Loaded="Filter_Loaded" TextChanged="Filter_Changed" ToolTip="Cerca descrizione..."/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding SupplierName}" Width="180">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Fornitore" Foreground="#6B7280" FontWeight="Bold"/>
                                <TextBox Grid.Row="1" Style="{StaticResource HeaderSearchBox}" Tag="Supp" Loaded="Filter_Loaded" TextChanged="Filter_Changed" ToolTip="Filtra fornitore..."/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Manufacturer}" Width="150">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Produttore" Foreground="#6B7280" FontWeight="Bold"/>
                                <TextBox Grid.Row="1" Style="{StaticResource HeaderSearchBox}" Tag="Man" Loaded="Filter_Loaded" TextChanged="Filter_Changed" ToolTip="Cerca produttore..."/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="130"/>
                <DataGridTextColumn Header="UdM" Binding="{Binding Unit}" Width="50"/>
                <DataGridTextColumn Header="Acquisto" Binding="{Binding UnitCost, StringFormat='{}{0:N2} €'}" Width="90"/>
                <DataGridTextColumn Header="Listino" Binding="{Binding ListPrice, StringFormat='{}{0:N2} €'}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>