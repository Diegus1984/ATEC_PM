<Page
    x:Class="ATEC.PM.Client.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <DockPanel>
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Background="#2E90FA"
                        BorderThickness="0"
                        Click="BtnNew_Click"
                        Content="+ Nuovo"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnEdit"
                        Click="BtnEdit_Click"
                        Content="Modifica"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnDelete"
                        Background="#FEF3F2"
                        BorderBrush="#FECDCA"
                        Click="BtnDelete_Click"
                        Content="Elimina"
                        Foreground="#B42318"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                    <Separator
                        Width="1"
                        Margin="4,0"
                        Background="#E4E7EC" />
                    <Button
                        Background="#12B76A"
                        Click="BtnImportEasyfatt_Click"
                        Content="📥 Importa Easyfatt"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnClearFilters_Click"
                        Content="Reset Filtri"
                        Foreground="#667085"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#667085"
                Text="Pronto" />
        </Border>

        <DataGrid
            x:Name="dgCatalog"
            Margin="16"
            ColumnHeaderHeight="65"
            IsReadOnly="True"
            MouseDoubleClick="Dg_DoubleClick"
            SelectionChanged="Dg_SelectionChanged"
            SelectionMode="Single"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="120">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Codice" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Code"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Medium"
                                Text="{Binding Code}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Descrizione" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Desc"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{Binding Description}"
                                TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="180">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Fornitore" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Supp"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding SupplierName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="150">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Produttore" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Man"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Manufacturer}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="130"
                    Binding="{Binding Category}"
                    Header="Categoria" />
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding Unit}"
                    Header="UdM" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding UnitCost, StringFormat='{}{0:N2} €'}"
                    Header="Acquisto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding ListPrice, StringFormat='{}{0:N2} €'}"
                    Header="Listino">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>