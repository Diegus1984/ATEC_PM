<Page
    x:Class="ATEC.PM.Client.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderSearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,4,0,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <DockPanel>
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Background="#4F6EF7"
                        Click="BtnNew_Click"
                        Content="+ Nuovo"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnEdit"
                        Margin="8,0"
                        Background="#F3F4F6"
                        Click="BtnEdit_Click"
                        Content="Modifica"
                        Foreground="#374151"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnDelete"
                        Background="#FEE2E2"
                        Click="BtnDelete_Click"
                        Content="Elimina"
                        Foreground="#DC2626"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Margin="8,0"
                        Background="#DBEAFE"
                        Click="BtnImportEasyfatt_Click"
                        Content="📥 Importa Easyfatt"
                        Foreground="#1D4ED8"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Background="Transparent"
                        Click="BtnClearFilters_Click"
                        Content="Reset Filtri"
                        Foreground="#6B7280"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Background="#F3F4F6"
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#6B7280"
                Text="Caricamento..." />
        </Border>

        <DataGrid
            x:Name="dgCatalog"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            ColumnHeaderHeight="65"
            FontSize="13"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="True"
            MouseDoubleClick="Dg_DoubleClick"
            RowHeight="40"
            SelectionChanged="Dg_SelectionChanged"
            SelectionMode="Single">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="8,4" />
                    <Setter Property="Background" Value="#F9FAFB" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Width="120" Binding="{Binding Code}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#6B7280"
                                    Text="Codice" />
                                <TextBox
                                    Grid.Row="1"
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Code"
                                    TextChanged="Filter_Changed"
                                    ToolTip="Cerca codice..." />
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding Description}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#6B7280"
                                    Text="Descrizione" />
                                <TextBox
                                    Grid.Row="1"
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Desc"
                                    TextChanged="Filter_Changed"
                                    ToolTip="Cerca descrizione..." />
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Width="180" Binding="{Binding SupplierName}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#6B7280"
                                    Text="Fornitore" />
                                <TextBox
                                    Grid.Row="1"
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Supp"
                                    TextChanged="Filter_Changed"
                                    ToolTip="Filtra fornitore..." />
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Width="150" Binding="{Binding Manufacturer}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#6B7280"
                                    Text="Produttore" />
                                <TextBox
                                    Grid.Row="1"
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Man"
                                    TextChanged="Filter_Changed"
                                    ToolTip="Cerca produttore..." />
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="130"
                    Binding="{Binding Category}"
                    Header="Categoria" />
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding Unit}"
                    Header="UdM" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding UnitCost, StringFormat='{}{0:N2} €'}"
                    Header="Acquisto" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding ListPrice, StringFormat='{}{0:N2} €'}"
                    Header="Listino" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>