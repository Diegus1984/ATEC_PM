<Window
    x:Class="ATEC.PM.Client.Views.TimesheetEntryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Registra Ore"
    Width="420"
    Height="Auto"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="90"
                    Height="34"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand"
                    Foreground="#374151" />
                <Button
                    x:Name="btnSave"
                    Width="90"
                    Height="34"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </StackPanel>
        </Border>
        <StackPanel Margin="24,8,24,16">
            <TextBlock
                x:Name="lblRegistraPer"
                Style="{StaticResource Lbl}"
                Text="REGISTRA PER"
                Visibility="Collapsed" />
            <ComboBox
                x:Name="cmbEmployee"
                Height="34"
                DisplayMemberPath="Name"
                FontSize="13"
                SelectedValuePath="Id"
                SelectionChanged="CmbEmployee_SelectionChanged"
                Visibility="Collapsed" />

            <TextBlock Style="{StaticResource Lbl}" Text="COMMESSA *" />
            <ComboBox
                x:Name="cmbProject"
                Height="34"
                DisplayMemberPath="Display"
                FontSize="13"
                SelectedValuePath="ProjectId"
                SelectionChanged="CmbProject_SelectionChanged" />

            <TextBlock Style="{StaticResource Lbl}" Text="FASE *" />
            <ComboBox
                x:Name="cmbPhase"
                Height="34"
                DisplayMemberPath="Display"
                FontSize="13"
                SelectedValuePath="PhaseId" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Lbl}" Text="DATA *" />
                    <DatePicker
                        x:Name="dpDate"
                        Height="34"
                        FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Lbl}" Text="ORE *" />
                    <TextBox
                        x:Name="txtHours"
                        Height="34"
                        Padding="8,6"
                        BorderBrush="#E4E7EC"
                        FontSize="13"
                        Text="8" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Lbl}" Text="TIPO" />
            <ComboBox
                x:Name="cmbType"
                Height="34"
                FontSize="13">
                <ComboBoxItem Content="REGULAR" IsSelected="True" />
                <ComboBoxItem Content="OVERTIME" />
                <ComboBoxItem Content="TRAVEL" />
            </ComboBox>

            <TextBlock Style="{StaticResource Lbl}" Text="NOTE" />
            <TextBox
                x:Name="txtNotes"
                Height="50"
                Padding="8,6"
                AcceptsReturn="True"
                BorderBrush="#E4E7EC"
                FontSize="13"
                TextWrapping="Wrap" />

            <TextBlock
                x:Name="txtError"
                Margin="0,12,0,0"
                FontSize="12"
                Foreground="#EF4444"
                TextWrapping="Wrap" />
        </StackPanel>
    </DockPanel>
</Window>