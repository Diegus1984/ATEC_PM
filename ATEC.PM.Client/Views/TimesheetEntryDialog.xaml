<Window x:Class="ATEC.PM.Client.Views.TimesheetEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registra Ore" Width="420" Height="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F8FA">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/><Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" Width="90" Height="34" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button x:Name="btnSave" Content="Salva" Width="90" Height="34" Background="#4F6EF7" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
        <StackPanel Margin="24,8,24,16">
            <TextBlock Text="COMMESSA / FASE *" Style="{StaticResource Lbl}"/>
            <ComboBox x:Name="cmbPhase" Height="34" FontSize="13" DisplayMemberPath="Display" SelectedValuePath="PhaseId"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DATA *" Style="{StaticResource Lbl}"/>
                    <DatePicker x:Name="dpDate" Height="34" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ORE *" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="txtHours" Height="34" Padding="8,6" FontSize="13" BorderBrush="#E4E7EC" Text="8"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="TIPO" Style="{StaticResource Lbl}"/>
            <ComboBox x:Name="cmbType" Height="34" FontSize="13">
                <ComboBoxItem Content="REGULAR" IsSelected="True"/>
                <ComboBoxItem Content="OVERTIME"/>
                <ComboBoxItem Content="TRAVEL"/>
            </ComboBox>

            <TextBlock Text="NOTE" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="txtNotes" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" FontSize="13" BorderBrush="#E4E7EC"/>

            <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
        </StackPanel>
    </DockPanel>
</Window>
