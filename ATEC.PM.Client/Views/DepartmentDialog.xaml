<Window
    x:Class="ATEC.PM.Client.Views.DepartmentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Reparto"
    Width="420"
    Height="340"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>

        <!--  HEADER  -->
        <Border
            Padding="20,14"
            Background="#1A1D26"
            DockPanel.Dock="Top">
            <TextBlock
                x:Name="txtDialogTitle"
                FontSize="15"
                FontWeight="Bold"
                Foreground="White"
                Text="Nuovo Reparto" />
        </Border>

        <!--  BUTTONS  -->
        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="90"
                    Height="32"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand"
                    FontSize="13" />
                <Button
                    Width="90"
                    Height="32"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Cursor="Hand"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </StackPanel>
        </Border>

        <!--  FORM  -->
        <StackPanel Margin="20,16">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="CODICE *" />
            <TextBox
                x:Name="txtCode"
                Height="32"
                Margin="0,4,0,12"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                FontSize="13"
                CharacterCasing="Upper"
                MaxLength="10" />

            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="NOME *" />
            <TextBox
                x:Name="txtName"
                Height="32"
                Margin="0,4,0,12"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                FontSize="13" />

            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="COSTO ORARIO €" />
            <TextBox
                x:Name="txtHourlyCost"
                Height="32"
                Margin="0,4,0,12"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                FontSize="13"
                Text="0.00" />

            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="ORDINE" />
            <TextBox
                x:Name="txtSortOrder"
                Height="32"
                Margin="0,4,0,0"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                FontSize="13"
                Text="0" />
        </StackPanel>

    </DockPanel>
</Window>
