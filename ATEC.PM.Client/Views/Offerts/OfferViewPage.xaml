<Page
    x:Class="ATEC.PM.Client.Views.OfferViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:costing="clr-namespace:ATEC.PM.Client.Views.Costing"
    Background="#F7F8FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Offer Header -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Offer Header -->
                <Border
                    Padding="16,14"
                    Background="#1A1D26"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            x:Name="txtCode"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#F59E0B"
                            Text="" />
                        <TextBlock
                            x:Name="txtRevision"
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="#9CA3AF"
                            Text="" />
                        <TextBlock
                            x:Name="txtTitle"
                            Margin="0,6,0,0"
                            FontSize="12"
                            Foreground="#E5E7EB"
                            Text=""
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="txtCustomer"
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#9CA3AF"
                            Text="" />
                        <TextBlock
                            x:Name="txtCreatedBy"
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="#6B7280"
                            Text="" />
                        <Border
                            x:Name="brdStatus"
                            Margin="0,8,0,0"
                            Padding="8,3"
                            HorizontalAlignment="Left"
                            Background="#2A2D36">
                            <TextBlock
                                x:Name="txtStatus"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#F59E0B"
                                Text="" />
                        </Border>

                        <!-- Link commessa (se convertita) -->
                        <TextBlock
                            x:Name="txtConvertedLink"
                            Margin="0,6,0,0"
                            FontSize="11"
                            Foreground="#4F6EF7"
                            Text=""
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Azioni -->
                <Border
                    Padding="12,8"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#4A4D56"
                            Text="AZIONI" />
                        <Button
                            x:Name="btnSetInviata"
                            Height="28"
                            Margin="0,0,0,4"
                            Background="#3B82F6"
                            BorderThickness="0"
                            Click="BtnSetStatus_Click"
                            Content="Segna come INVIATA"
                            Cursor="Hand"
                            FontSize="11"
                            Foreground="White"
                            Tag="INVIATA" />
                        <Button
                            x:Name="btnSetAccettata"
                            Height="28"
                            Margin="0,0,0,4"
                            Background="#10B981"
                            BorderThickness="0"
                            Click="BtnSetStatus_Click"
                            Content="Segna come ACCETTATA"
                            Cursor="Hand"
                            FontSize="11"
                            Foreground="White"
                            Tag="ACCETTATA" />
                        <Button
                            x:Name="btnSetRifiutata"
                            Height="28"
                            Margin="0,0,0,4"
                            Background="#EF4444"
                            BorderThickness="0"
                            Click="BtnSetStatus_Click"
                            Content="Segna come RIFIUTATA"
                            Cursor="Hand"
                            FontSize="11"
                            Foreground="White"
                            Tag="RIFIUTATA" />
                        <Button
                            x:Name="btnSetPersa"
                            Height="28"
                            Margin="0,0,0,4"
                            Background="#6B7280"
                            BorderThickness="0"
                            Click="BtnSetStatus_Click"
                            Content="Segna come PERSA"
                            Cursor="Hand"
                            FontSize="11"
                            Foreground="White"
                            Tag="PERSA" />
                        <Border
                            Height="1"
                            Margin="0,4"
                            Background="#E4E7EC" />
                        <Button
                            x:Name="btnRevision"
                            Height="28"
                            Margin="0,4,0,4"
                            Background="#F59E0B"
                            BorderThickness="0"
                            Click="BtnRevision_Click"
                            Content="Crea Revisione"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White" />
                        <Button
                            x:Name="btnConvert"
                            Height="28"
                            Margin="0,0,0,4"
                            Background="#10B981"
                            BorderThickness="0"
                            Click="BtnConvert_Click"
                            Content="Converti in Commessa"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White" />
                    </StackPanel>
                </Border>

                <!-- Back button -->
                <Border
                    Padding="12,8"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <Button
                        Height="30"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnBack_Click"
                        Content="Torna alla lista"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#374151" />
                </Border>

                <!-- Spacer -->
                <Border />
            </DockPanel>
        </Border>

        <!-- RIGHT: Costing Control -->
        <costing:ProjectCostingControl
            x:Name="costingControl"
            Grid.Column="1" />
    </Grid>
</Page>
