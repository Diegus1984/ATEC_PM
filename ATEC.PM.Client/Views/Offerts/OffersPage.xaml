<Page
    x:Class="ATEC.PM.Client.Views.OffersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:costing="clr-namespace:ATEC.PM.Client.Views.Costing"
    Background="#F7F8FA"
    Loaded="Page_Loaded">

    <Page.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation
                Storyboard.TargetName="pnlOfferDetail"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation
                Storyboard.TargetName="pnlOfferDetail"
                Storyboard.TargetProperty="Margin"
                From="0,15,0,0"
                To="0,0,0,0"
                Duration="0:0:0.4">
                <ThicknessAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <Style x:Key="SmoothTreeItem" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border
                                x:Name="Bd"
                                Margin="0,1,0,1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Path
                                        x:Name="Expander"
                                        Grid.Column="0"
                                        Width="8"
                                        Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0,0 L 5,5 L 0,10"
                                        RenderTransformOrigin="0.5,0.5"
                                        Stroke="#9CA3AF"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.5">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="ExpanderRotation" Angle="0" />
                                        </Path.RenderTransform>
                                    </Path>

                                    <ContentPresenter
                                        x:Name="PART_Header"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        ContentSource="Header" />
                                </Grid>
                            </Border>

                            <ItemsPresenter
                                x:Name="ItemsHost"
                                Margin="16,4,0,0"
                                Opacity="0"
                                Visibility="Collapsed">
                                <ItemsPresenter.LayoutTransform>
                                    <ScaleTransform x:Name="ItemsScale" ScaleY="0" />
                                </ItemsPresenter.LayoutTransform>
                            </ItemsPresenter>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>

                            <Trigger Property="IsExpanded" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ItemsHost" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ExpanderRotation"
                                                Storyboard.TargetProperty="Angle"
                                                To="90"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsHost"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ExpanderRotation"
                                                Storyboard.TargetProperty="Angle"
                                                To="0"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsHost"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0"
                                                Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ItemsHost" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.35">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Collapsed</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEF2FF" />
                                <Setter TargetName="PART_Header" Property="TextElement.Foreground" Value="#4F6EF7" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E0E7FF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <Border
                    Style="{StaticResource ToolbarBorder}"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <Button
                            Background="#4F6EF7"
                            Click="BtnNew_Click"
                            Content="+ Nuova"
                            Foreground="White"
                            Style="{StaticResource PrimaryBtn}" />
                        <Button
                            HorizontalAlignment="Right"
                            Click="BtnRefresh_Click"
                            Content="Aggiorna"
                            DockPanel.Dock="Right"
                            Style="{StaticResource FlatBtn}" />
                    </DockPanel>
                </Border>

                <Border Padding="12,12,12,8" DockPanel.Dock="Top">
                    <Grid>
                        <TextBox
                            x:Name="txtSearch"
                            Height="36"
                            Padding="12,0,12,0"
                            VerticalContentAlignment="Center"
                            Background="#F9FAFB"
                            BorderBrush="#D1D5DB"
                            FontSize="13"
                            TextChanged="TxtSearch_Changed">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="18" />
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock
                            x:Name="txtSearchPlaceholder"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#9CA3AF"
                            IsHitTestVisible="False"
                            Text="Cerca offerta o cliente..." />
                    </Grid>
                </Border>

                <Border
                    Padding="12,6"
                    Background="#FAFBFC"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <TextBlock
                        x:Name="txtStatus"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="#9CA3AF"
                        Text="Caricamento..." />
                </Border>

                <TreeView
                    x:Name="treeOffers"
                    Padding="8,4"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectedItemChanged="Tree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <StaticResource ResourceKey="SmoothTreeItem" />
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>
        </Border>

        <Border Grid.Column="1">
            <DockPanel>
                <Border
                    Padding="30,16"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            x:Name="txtSectionTitle"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="Seleziona un'offerta" />
                        <StackPanel
                            x:Name="pnlActions"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Visibility="Collapsed">


                            <Button
                                x:Name="btnSetInviata"
                                Background="#3B82F6"
                                Click="BtnSetStatus_Click"
                                Content="Segna INVIATA"
                                Foreground="White"
                                Style="{StaticResource PrimaryBtn}"
                                Tag="INVIATA" />
                            <Button
                                x:Name="btnSetAccettata"
                                Margin="8,0,0,0"
                                Background="#10B981"
                                Click="BtnSetStatus_Click"
                                Content="Segna ACCETTATA"
                                Foreground="White"
                                Style="{StaticResource SuccessBtn}"
                                Tag="ACCETTATA" />
                            <Button
                                x:Name="btnSetRifiutata"
                                Margin="8,0,0,0"
                                Background="#EF4444"
                                Click="BtnSetStatus_Click"
                                Content="Rifiutata"
                                Foreground="White"
                                Style="{StaticResource DangerBtn}"
                                Tag="RIFIUTATA" />
                            <Button
                                x:Name="btnSetPersa"
                                Margin="8,0,0,0"
                                Background="#6B7280"
                                Click="BtnSetStatus_Click"
                                Content="Persa"
                                Foreground="White"
                                Style="{StaticResource FlatBtn}"
                                Tag="PERSA" />
                            <Border
                                Width="1"
                                Margin="12,4"
                                Background="#E4E7EC" />
                            <Button
                                x:Name="btnRevision"
                                Background="#F59E0B"
                                Click="BtnRevision_Click"
                                Content="Nuova Revisione"
                                Foreground="White"
                                Style="{StaticResource FlatBtn}" />
                            <Button
                                x:Name="btnConvert"
                                Margin="8,0,0,0"
                                Background="#10B981"
                                Click="BtnConvert_Click"
                                Content="Converti in Commessa"
                                Foreground="White"
                                Style="{StaticResource SuccessBtn}" />
                            <Button
                                x:Name="btnDelete"
                                Margin="8,0,0,0"
                                Background="#FEE2E2"
                                Click="BtnDelete_Click"
                                Content="Elimina"
                                Foreground="#DC2626"
                                Style="{StaticResource FlatBtn}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid>
                    <StackPanel
                        x:Name="pnlPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="48"
                            Foreground="#E4E7EC"
                            Text="📋" />
                        <TextBlock
                            Margin="0,16,0,0"
                            HorizontalAlignment="Center"
                            FontSize="15"
                            FontWeight="Medium"
                            Foreground="#9CA3AF"
                            Text="Seleziona un'offerta dall'albero per visualizzarne i dettagli" />
                    </StackPanel>

                    <DockPanel
                        x:Name="pnlOfferDetail"
                        Margin="0,15,0,0"
                        Visibility="Collapsed">
                        <Border
                            Padding="30,12"
                            Background="#FAFBFC"
                            BorderBrush="#E4E7EC"
                            BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    x:Name="brdStatusBadge"
                                    Padding="12,4"
                                    Background="#F3F4F6"
                                    CornerRadius="12">
                                    <TextBlock
                                        x:Name="txtOfferStatus"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="#374151" />
                                </Border>
                                <TextBlock
                                    x:Name="txtOfferCustomer"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Foreground="#4B5563" />
                                <TextBlock
                                    x:Name="txtOfferCreatedBy"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#9CA3AF" />
                                <TextBlock
                                    x:Name="txtOfferDate"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#9CA3AF" />
                                <TextBlock
                                    x:Name="txtConvertedLink"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="#4F6EF7"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <costing:ProjectCostingControl x:Name="costingControl" />
                    </DockPanel>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Page>