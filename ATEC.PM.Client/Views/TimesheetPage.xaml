<Page
    x:Class="ATEC.PM.Client.Views.TimesheetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">
    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <DockPanel>
        <!--  TOOLBAR  -->
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        Background="#F3F4F6"
                        Click="BtnPrevWeek_Click"
                        Content="&lt; Sett. Prec."
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                    <TextBlock
                        x:Name="txtWeekLabel"
                        Margin="16,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#1A1D26"
                        Text="" />
                    <Button
                        Background="#F3F4F6"
                        Click="BtnNextWeek_Click"
                        Content="Sett. Succ. &gt;"
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Margin="8,0,0,0"
                        Background="#F3F4F6"
                        Click="BtnToday_Click"
                        Content="Oggi"
                        Foreground="#374151"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Background="#4F6EF7"
                        Click="BtnAdd_Click"
                        Content="+ Aggiungi Ore"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  STATUS  -->
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#6B7280"
                Text="" />
        </Border>

        <!--  ENTRIES GRID  -->
        <DataGrid
            x:Name="dgEntries"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            ColumnHeaderHeight="38"
            FontSize="13"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="True"
            RowHeight="38"
            SelectionMode="Single">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F9FAFB" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderBrush" Value="#E4E7EC" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EEF2FF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F9FAFB" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#1A1D26" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding WorkDate, StringFormat='{}{0:ddd dd/MM}'}"
                    Header="Data" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding PhaseDisplay}"
                    Header="Commessa / Fase" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding Hours, StringFormat='{}{0:N1}'}"
                    Header="Ore" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding EntryType}"
                    Header="Tipo" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding Notes}"
                    Header="Note" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
