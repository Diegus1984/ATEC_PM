<Page
    x:Class="ATEC.PM.Client.Views.SuppliersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uc="clr-namespace:ATEC.PM.Client.UserControls"
    MinWidth="800"
    Background="#F7F8FA">

    <DockPanel>
        <Border
            Style="{StaticResource ToolbarBorder}"
            DockPanel.Dock="Top">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="btnNew"
                        Click="BtnNew_Click"
                        Content="+ Nuovo Fornitore"
                        Style="{StaticResource PrimaryBtn}" />

                    <Button
                        Click="BtnClearFilters_Click"
                        Content="Pulisci Filtri"
                        Style="{StaticResource FlatBtn}" />

                    <Button
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>

                <Button
                    HorizontalAlignment="Right"
                    Background="#12B76A"
                    Click="BtnImportEasyfatt_Click"
                    Content="Importa da Easyfatt"
                    Foreground="White"
                    Style="{StaticResource SuccessBtn}" />
            </Grid>
        </Border>

        <uc:DaneaSyncBar x:Name="syncBar" DockPanel.Dock="Top" />

        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <Grid>
                <TextBlock
                    x:Name="txtStatus"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Foreground="#667085"
                    Text="Pronto" />
                <TextBlock
                    HorizontalAlignment="Right"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="#9CA3AF"
                    Text="Filtri: abc = contiene  |  abc* = inizia con  |  *abc = finisce con" />
            </Grid>
        </Border>

        <DataGrid
            x:Name="dgSuppliers"
            Margin="20"
            IsReadOnly="True"
            MouseDoubleClick="Dg_DoubleClick"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Ragione Sociale" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Name"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Medium"
                                Text="{Binding CompanyName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="160">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Referente" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Contact"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding ContactName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="140">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="P.IVA" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Vat"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding VatNumber}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="180"
                    Binding="{Binding Email}"
                    Header="Email" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Phone}"
                    Header="Telefono" />
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding FiscalCode}"
                    Header="C.F." />

                <DataGridTemplateColumn Width="80" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Click="BtnEdit_Click"
                                    Style="{StaticResource RowEditBtn}" />
                                <Button
                                    Margin="4,0,0,0"
                                    Click="BtnDelete_Click"
                                    Style="{StaticResource RowDeleteBtn}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>