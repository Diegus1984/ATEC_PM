<Window
    x:Class="ATEC.PM.Client.Views.DdpDestinationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Destinazione DDP"
    Width="400"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Background="#F7F8FA">

    <StackPanel Margin="24">
        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#667085" Text="NOME DESTINAZIONE" />
        <TextBox x:Name="txtName" Margin="0,4,0,16" Padding="8,6" FontSize="14" />

        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#667085" Text="ORDINE" />
        <TextBox x:Name="txtSortOrder" Margin="0,4,0,16" Padding="8,6" FontSize="14" Text="0" />

        <CheckBox x:Name="chkActive" Margin="0,0,0,20" Content="Attiva" FontSize="13" IsChecked="True" />

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button
                Width="100"
                Height="34"
                Margin="0,0,8,0"
                Click="BtnCancel_Click"
                Content="Annulla"
                Style="{StaticResource FlatBtn}" />
            <Button
                Width="100"
                Height="34"
                Background="#4F6EF7"
                Click="BtnSave_Click"
                Content="Salva"
                Foreground="White"
                Style="{StaticResource FlatBtn}" />
        </StackPanel>

        <Button
            x:Name="btnDelete"
            Margin="0,16,0,0"
            HorizontalAlignment="Left"
            Background="#FEF3F2"
            BorderBrush="#FECDCA"
            Click="BtnDelete_Click"
            Content="Elimina"
            Foreground="#B42318"
            Style="{StaticResource FlatBtn}"
            Visibility="Collapsed" />
    </StackPanel>
</Window>
