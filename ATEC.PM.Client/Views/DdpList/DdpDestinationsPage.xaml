<Page
    x:Class="ATEC.PM.Client.Views.DdpDestinationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">
    <DockPanel>

        <!-- TOOLBAR -->
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#1A1D26"
                        Text="Destinazioni DDP" />
                    <TextBlock
                        x:Name="txtCount"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#6B7280" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Background="#2E90FA"
                        Click="BtnAdd_Click"
                        Content="+ Nuova Destinazione"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- STATUS BAR -->
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="12"
                Foreground="#667085"
                Text="Pronto" />
        </Border>

        <!-- DATAGRID -->
        <DataGrid
            x:Name="dgDestinations"
            Margin="16"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True"
            MouseDoubleClick="Dg_DoubleClick"
            SelectionChanged="Dg_SelectionChanged"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding Id}"
                    Header="ID" />
                <DataGridTextColumn
                    Width="*"
                    MinWidth="200"
                    Binding="{Binding Name}"
                    Header="Destinazione" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding SortOrder}"
                    Header="Ordine" />
                <DataGridTemplateColumn Width="80" Header="Attiva">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="#12B76A">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="Text" Value="✗" />
                                                <Setter Property="Foreground" Value="#DC2626" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
