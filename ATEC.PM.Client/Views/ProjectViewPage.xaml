<Page x:Class="ATEC.PM.Client.Views.ProjectViewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Project Header + TreeView -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Project Header -->
                <Border DockPanel.Dock="Top" Background="#1A1D26" Padding="16,14">
                    <StackPanel>
                        <TextBlock x:Name="txtCode" Text="" FontSize="16" FontWeight="Bold" Foreground="#4F6EF7"/>
                        <TextBlock x:Name="txtTitle" Text="" FontSize="12" Foreground="#E5E7EB" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <TextBlock x:Name="txtCustomer" Text="" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                        <Border Background="#2A2D36" Padding="6,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                            <TextBlock x:Name="txtStatus" Text="" FontSize="11" FontWeight="SemiBold" Foreground="#4F6EF7"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Back button -->
                <Border DockPanel.Dock="Bottom" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="12,8">
                    <Button Content="Torna alla lista" Background="#F3F4F6" Foreground="#374151" Height="30"
                            FontSize="12" BorderThickness="0" Cursor="Hand" Click="BtnBack_Click"/>
                </Border>

                <!-- TreeView -->
                <TreeView x:Name="treeNav" Margin="0,8,0,0" BorderThickness="0" Background="White"
                          SelectedItemChanged="TreeNav_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,6"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeViewItem Header="Dettagli" Tag="details" IsSelected="True"/>
                    <TreeViewItem Header="Fasi e Avanzamento" Tag="phases"/>
                    <TreeViewItem Header="Timesheet" Tag="timesheet"/>
                    <TreeViewItem Header="Documenti" Tag="documents">
                        <!-- Sub-folders will be populated dynamically -->
                    </TreeViewItem>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- RIGHT: Content Area -->
        <Border Grid.Column="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" Padding="24,12">
                    <DockPanel>
                        <TextBlock x:Name="txtSectionTitle" Text="Dettagli" FontSize="18" FontWeight="Bold" Foreground="#1A1D26"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="btnSectionAction" Content="" Visibility="Collapsed" Height="32" Padding="16,0"
                                    Background="#4F6EF7" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand" Click="BtnSectionAction_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ContentControl x:Name="SectionContent" Margin="24,16"/>
            </DockPanel>
        </Border>
    </Grid>
</Page>
