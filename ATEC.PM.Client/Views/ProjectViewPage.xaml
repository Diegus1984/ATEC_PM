<Page
    x:Class="ATEC.PM.Client.Views.ProjectViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  LEFT: Project Header + TreeView  -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <!--  Project Header  -->
                <Border
                    Padding="16,14"
                    Background="#1A1D26"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            x:Name="txtCode"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#4F6EF7"
                            Text="" />
                        <TextBlock
                            x:Name="txtTitle"
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#E5E7EB"
                            Text=""
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="txtCustomer"
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#9CA3AF"
                            Text="" />
                        <Border
                            Margin="0,8,0,0"
                            Padding="6,3"
                            HorizontalAlignment="Left"
                            Background="#2A2D36">
                            <TextBlock
                                x:Name="txtStatus"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#4F6EF7"
                                Text="" />
                        </Border>
                    </StackPanel>
                </Border>

                <!--  Back button  -->
                <Border
                    Padding="12,8"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <Button
                        Height="30"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnBack_Click"
                        Content="Torna alla lista"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#374151" />
                </Border>

                <!--  TreeView  -->
                <TreeView
                    x:Name="treeNav"
                    Margin="0,8,0,0"
                    Background="White"
                    BorderThickness="0"
                    SelectedItemChanged="TreeNav_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,6" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="IsExpanded" Value="True" />
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeViewItem
                        Header="Dettagli"
                        IsSelected="True"
                        Tag="details" />
                    <TreeViewItem Header="Configura Commessa" Tag="costing" />
                    <TreeViewItem Header="Fasi e Avanzamento" Tag="phases" />
                    <TreeViewItem Header="Timesheet" Tag="timesheet" />
                    <TreeViewItem Header="Documenti" Tag="documents">
                        <!--  Sub-folders will be populated dynamically  -->
                    </TreeViewItem>
                </TreeView>
            </DockPanel>
        </Border>

        <!--  RIGHT: Content Area  -->
        <Border Grid.Column="1">
            <DockPanel>
                <Border
                    Padding="24,12"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            x:Name="txtSectionTitle"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="Dettagli" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnSectionAction"
                                Height="32"
                                Padding="16,0"
                                Background="#4F6EF7"
                                BorderThickness="0"
                                Click="BtnSectionAction_Click"
                                Content=""
                                Cursor="Hand"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ContentControl x:Name="SectionContent" Margin="24,16" />
            </DockPanel>
        </Border>
    </Grid>
</Page>
