<Window
    x:Class="ATEC.PM.Client.Views.Preventivi.ConvertPreventivoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Converti in Commessa"
    Width="400"
    Height="250"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="#1A1D26"
                Text="Seleziona il Project Manager per la commessa" />
            <ComboBox
                x:Name="cmbPm"
                Height="32"
                Margin="0,12,0,0"
                DisplayMemberPath="Name"
                FontSize="13"
                SelectedValuePath="Id" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Height="32"
                Padding="20,0"
                Background="#F3F4F6"
                BorderThickness="0"
                Click="BtnCancel_Click"
                Content="Annulla"
                Cursor="Hand"
                FontSize="13"
                Foreground="#374151" />
            <Button
                Height="32"
                Margin="8,0,0,0"
                Padding="20,0"
                Background="#10B981"
                BorderThickness="0"
                Click="BtnConvert_Click"
                Content="Converti"
                Cursor="Hand"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
