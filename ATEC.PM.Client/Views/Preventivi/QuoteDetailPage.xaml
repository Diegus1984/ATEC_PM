<Page
    x:Class="ATEC.PM.Client.Views.Preventivi.QuoteDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:costing="clr-namespace:ATEC.PM.Client.Views.Costing"
    xmlns:prev="clr-namespace:ATEC.PM.Client.Views.Preventivi"
    Background="#F7F8FA"
    Loaded="Page_Loaded">

    <Page.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation
                Storyboard.TargetName="pnlQuoteDetail"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation
                Storyboard.TargetName="pnlQuoteDetail"
                Storyboard.TargetProperty="Margin"
                From="0,15,0,0"
                To="0,0,0,0"
                Duration="0:0:0.4">
                <ThicknessAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Page.Resources>

    <DockPanel>
                <!-- Bottone Indietro -->
                <Button DockPanel.Dock="Top" Content="&#x2190; Indietro"
                        Click="BtnBack_Click" Cursor="Hand"
                        FontSize="13" Foreground="#6B7280"
                        Background="Transparent" BorderThickness="0"
                        Padding="16,8" HorizontalAlignment="Left" />

                <!-- Header bar -->
                <Border
                    Padding="30,16"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            x:Name="txtSectionTitle"
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{StaticResource Gray900Brush}"
                            Text="Seleziona un preventivo" />
                        <StackPanel
                            x:Name="pnlActions"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Visibility="Collapsed">

                            <Button
                                x:Name="btnPdf"
                                Click="BtnPdf_Click"
                                Foreground="{StaticResource Gray500Brush}"
                                Style="{StaticResource FlatBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEA90;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="PDF" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid>

                    <!-- Detail panel -->
                    <DockPanel
                        x:Name="pnlQuoteDetail"
                        Margin="0,15,0,0"
                        Visibility="Collapsed">

                        <!-- Info strip -->
                        <Border
                            Padding="30,12"
                            Background="{StaticResource Gray50Brush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    x:Name="brdStatusBadge"
                                    Padding="12,4"
                                    Background="{StaticResource Gray100Brush}"
                                    CornerRadius="12">
                                    <TextBlock
                                        x:Name="txtQuoteStatus"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Gray700Brush}" />
                                </Border>
                                <TextBlock
                                    x:Name="txtQuoteCustomer"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Foreground="{StaticResource Gray600Brush}" />
                                <TextBlock
                                    x:Name="txtQuoteCreatedBy"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{StaticResource Gray400Brush}" />
                                <TextBlock
                                    x:Name="txtQuoteDate"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{StaticResource Gray400Brush}" />
                                <Border
                                    x:Name="brdTypeBadge"
                                    Margin="16,0,0,0"
                                    Padding="10,3"
                                    CornerRadius="10"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="txtQuoteType"
                                        FontSize="11"
                                        FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- CONTENT AREA -->
                        <Grid>
                            <!-- ═══ INFO HEADER condiviso SERVICE + IMPIANTO ═══ -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border x:Name="pnlInfoHeader" Grid.Row="0" Margin="20,16,20,0" Padding="20" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                                <RowDefinition />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>

                                            <!-- Row 0: Titolo, Cliente, Template -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Titolo *" />
                                                <TextBox x:Name="txtEditTitle" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,12">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Cliente" />
                                                <TextBlock x:Name="txtInfoCliente" Padding="0,8" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Template" />
                                                <TextBlock x:Name="txtInfoTipo" Padding="0,8" FontSize="13" Foreground="{StaticResource Gray700Brush}" />
                                            </StackPanel>

                                            <!-- Row 1: Referente 1, 2, 3 -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Referente 1" />
                                                <TextBox x:Name="txtEditContact1" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,12">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Referente 2" />
                                                <TextBox x:Name="txtEditContact2" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Referente 3" />
                                                <TextBox x:Name="txtEditContact3" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>

                                            <!-- Row 2: Tempi consegna, Validità, Tipo pagamento -->
                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Tempi consegna (gg)" />
                                                <TextBox x:Name="txtEditDeliveryDays" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Validit&#224; offerta (gg)" />
                                                <TextBox x:Name="txtEditValidityDays" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,0">
                                                <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" Text="Tipo pagamento" />
                                                <TextBox x:Name="txtEditPaymentType" FontSize="13" Padding="8,6" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                        </Grid>
                            </Border>

                            <!-- Pannelli IMPIANTO / SERVICE sotto l'header info -->
                            <Grid Grid.Row="1">

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- IMPIANTO: Full-width vertical layout       -->
                            <!-- ═══════════════════════════════════════════ -->
                            <ScrollViewer x:Name="pnlImpiantoLayout" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                                <StackPanel Margin="20,16,20,20">

                                    <!-- COSTI PERSONE (CostingTreeControl) -->
                                    <Border Margin="0,0,0,16" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                        <prev:CostingTreeControl x:Name="costingTreeControl" />
                                    </Border>

                                    <!-- CONTENUTI AUTOMATICI -->
                                    <Border Margin="0,0,0,16" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                        <StackPanel>
                                            <Border Padding="16,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                                <DockPanel>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" Text="CONTENUTI AUTOMATICI" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="txtImpAutoCount" FontSize="11" Foreground="{StaticResource Gray400Brush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                            Click="BtnReloadAutoIncludes_Click" Content="Ricarica dal catalogo"
                                                            Cursor="Hand" FontSize="11" Padding="10,4"
                                                            Background="#EFF6FF" Foreground="{StaticResource PrimaryBrush}" BorderBrush="#BFDBFE" BorderThickness="1"
                                                            Style="{StaticResource FlatBtn}" />
                                                </DockPanel>
                                            </Border>

                                            <ItemsControl x:Name="icImpAutoIncludes" Padding="4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="4,2" Padding="10,8" Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                            <DockPanel>
                                                                <Button DockPanel.Dock="Right" Content="X" Width="22" Height="22"
                                                                        FontSize="10" Cursor="Hand" Padding="0"
                                                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource DangerBrush}"
                                                                        Click="BtnRemoveImpAutoInclude_Click" Tag="{Binding ParentId}"
                                                                        ToolTip="Rimuovi" />
                                                                <Button DockPanel.Dock="Right" Content="&#x270E;" Width="22" Height="22"
                                                                        FontSize="12" Cursor="Hand" Padding="0" Margin="0,0,4,0"
                                                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray500Brush}"
                                                                        Click="BtnEditAutoIncludeRtf_Click" Tag="{Binding}"
                                                                        ToolTip="Modifica contenuto" />
                                                                <TextBlock Text="{Binding ParentName}" FontSize="12" Foreground="{StaticResource Gray700Brush}"
                                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock x:Name="txtImpNoAutoIncludes" Text="Nessun contenuto automatico."
                                                       FontSize="12" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Center" Margin="0,12,0,12"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>

                                    <!-- RIEPILOGO ECONOMICO -->
                                    <Border Margin="0,0,0,16" Padding="20" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="300" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: PDF Options -->
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <CheckBox x:Name="chkShowItemPrices" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                                    <TextBlock Text="Visualizza prezzi sulle pagine dei singoli articoli" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <CheckBox x:Name="chkShowSummary" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                                    <TextBlock Text="Attiva il riepilogo finale" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <CheckBox x:Name="chkShowSummaryPrices" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                                    <TextBlock Text="Visualizza prezzi dei singoli articoli sul riepilogo" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <CheckBox x:Name="chkHideQuantities" Style="{StaticResource ToggleSwitchStyle}" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                                    <TextBlock Text="Nascondi dettagli (costo, qtà, sconto) dal riepilogo" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right: Riepilogo offerta -->
                                            <StackPanel Grid.Column="1">
                                                <ItemsControl x:Name="icRiepilogo">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="120" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Name}" HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Gray700Brush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="1" Text="{Binding TotalFormatted}" HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Gray700Brush}" FontWeight="SemiBold" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Border BorderBrush="#059669" BorderThickness="0,2,0,0" Margin="0,8,0,4" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               FontSize="15" FontWeight="Bold" Foreground="#059669" Text="TOTALE OFFERTA" />
                                                    <TextBlock x:Name="txtSumFinal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               FontSize="15" FontWeight="Bold" Foreground="#059669" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- NOTE PREVENTIVO -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Padding="16" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray500Brush}" Text="NOTE AD USO INTERNO" />
                                                <TextBox x:Name="txtEditNotesInternal" FontSize="12" Padding="8,6" Height="120"
                                                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                         Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Padding="16" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray500Brush}" Text="NOTE SU PREVENTIVO" />
                                                <TextBox x:Name="txtEditNotesQuote" FontSize="12" Padding="8,6" Height="120"
                                                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                         Background="{StaticResource Gray50Brush}" BorderBrush="{StaticResource Gray300Brush}"
                                                         LostFocus="InfoField_LostFocus">
                                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- SERVICE: Catalogo prodotti (unchanged)      -->
                            <!-- ═══════════════════════════════════════════ -->
                            <Border
                                x:Name="pnlServiceCatalog"
                                Background="{StaticResource Gray50Brush}"
                                Visibility="Collapsed">
                                <DockPanel>
                                    <!-- Toolbar -->
                                    <Border Padding="20,10" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" DockPanel.Dock="Top">
                                        <DockPanel>
                                            <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" Text="Prodotti &amp; Contenuti" VerticalAlignment="Center" />
                                            <Button
                                                x:Name="btnServiceAddProduct"
                                                HorizontalAlignment="Right"
                                                DockPanel.Dock="Right"
                                                Background="{StaticResource SuccessBrush}"
                                                Click="BtnServiceAddProduct_Click"
                                                Content="+ Aggiungi Prodotto"
                                                Cursor="Hand"
                                                FontSize="12"
                                                Foreground="White"
                                                Style="{StaticResource PrimaryBtn}" />
                                        </DockPanel>
                                    </Border>

                                    <!-- ═══ NOTE ═══ -->
                                    <Border x:Name="pnlServiceNotes" Padding="20,16" Background="White"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                            DockPanel.Dock="Bottom" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="NOTE AD USO INTERNO" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray500Brush}" Margin="0,0,0,6" />
                                                <TextBox x:Name="txtServiceNotesInternal" AcceptsReturn="True" TextWrapping="Wrap"
                                                         Height="120" FontSize="12" VerticalScrollBarVisibility="Auto"
                                                         LostFocus="ServiceNotes_LostFocus" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="NOTE SU PREVENTIVO" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray500Brush}" Margin="0,0,0,6" />
                                                <TextBox x:Name="txtServiceNotesQuote" AcceptsReturn="True" TextWrapping="Wrap"
                                                         Height="120" FontSize="12" VerticalScrollBarVisibility="Auto"
                                                         LostFocus="ServiceNotes_LostFocus" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Footer: sconto + checkbox a sinistra, riepilogo a destra -->
                                    <Border Padding="20,12" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
                                        <DockPanel>
                                            <!-- Sinistra: sconto + checkbox opzioni PDF -->
                                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Top" Width="380">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="Sconto sul TOTALE:" FontSize="12" Foreground="{StaticResource Gray700Brush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBox x:Name="txtServiceDiscountPct" Width="60" Height="26" FontSize="11" TextAlignment="Right"
                                                             LostFocus="ServiceDiscountPct_LostFocus" />
                                                    <TextBlock Text="%" FontSize="12" Foreground="{StaticResource Gray500Brush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <CheckBox x:Name="chkServiceShowItemPrices" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" />
                                                    <TextBlock Text="Visualizza prezzi sulle pagine dei singoli articoli" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <CheckBox x:Name="chkServiceShowSummary" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" />
                                                    <TextBlock Text="Attiva il riepilogo finale" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <CheckBox x:Name="chkServiceShowSummaryPrices" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" />
                                                    <TextBlock Text="Visualizza prezzi dei singoli articoli sul riepilogo" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <CheckBox x:Name="chkServiceHideQuantities" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False" />
                                                    <TextBlock Text="Nascondi dettagli (costo, qtà, sconto) dal riepilogo" FontSize="12" Foreground="#374151" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Destra: riepilogo economico completo -->
                                            <Grid HorizontalAlignment="Right" Width="320">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="24" />
                                                    <RowDefinition Height="24" />
                                                    <RowDefinition Height="24" />
                                                    <RowDefinition Height="2" />
                                                    <RowDefinition Height="28" />
                                                    <RowDefinition Height="24" />
                                                    <RowDefinition Height="2" />
                                                    <RowDefinition Height="24" />
                                                    <RowDefinition Height="24" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray500Brush}" Text="TOTALE" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceSubtotal" Grid.Row="0" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray700Brush}" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray500Brush}" Text="TOTALE IVA" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceVat" Grid.Row="1" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray700Brush}" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray500Brush}" Text="SCONTO" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceDiscount" Grid.Row="2" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource DangerBrush}" />

                                                <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" />

                                                <TextBlock Grid.Row="4" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="14" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" Text="TOTALE IMPONIBILE" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceTotal" Grid.Row="4" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="14" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" />

                                                <TextBlock Grid.Row="5" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray500Brush}" Text="TOTALE IVA INCLUSA" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceTotalVat" Grid.Row="5" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="{StaticResource Gray700Brush}" />

                                                <Border Grid.Row="6" Grid.ColumnSpan="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" />

                                                <TextBlock Grid.Row="7" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Text="TOTALE COSTI AZIENDALI" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceCost" Grid.Row="7" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />

                                                <TextBlock Grid.Row="8" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Text="UTILE" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceProfit" Grid.Row="8" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                                            </Grid>
                                        </DockPanel>
                                    </Border>

                                    <!-- Product list -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <ItemsControl x:Name="icServiceProducts" Padding="8,4,8,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Background="White">
                                                            <StackPanel>
                                                                <!-- Product header -->
                                                                <Border Padding="12,10" Background="{StaticResource Gray50Brush}" CornerRadius="6,6,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                                                    <DockPanel>
                                                                        <Border Padding="6,3" Margin="0,0,10,0" VerticalAlignment="Center" CornerRadius="4"
                                                                                Background="{Binding TypeBadgeColor}">
                                                                            <TextBlock Text="{Binding TypeBadgeLabel}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                                        </Border>

                                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding TotalDisplay}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}"
                                                                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                                                                            <!-- + Variante -->
                                                                            <Button Content="+" ToolTip="Aggiungi variante" Width="28" Height="28"
                                                                                    FontSize="14" FontWeight="Bold" Cursor="Hand"
                                                                                    Background="#EFF6FF" Foreground="{StaticResource PrimaryBrush}" BorderBrush="#BFDBFE" BorderThickness="1"
                                                                                    Click="BtnServiceAddVariant_Click" Tag="{Binding ParentId}" Padding="0" />
                                                                            <!-- Refresh da catalogo -->
                                                                            <Button ToolTip="Aggiorna da catalogo" Width="28" Height="28" Margin="4,0,0,0"
                                                                                    FontSize="12" Cursor="Hand" Content="&#x21BB;"
                                                                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryBrush}"
                                                                                    Click="BtnServiceRefreshProduct_Click" Tag="{Binding ParentId}" Padding="0" />
                                                                            <!-- Edit RTF -->
                                                                            <Button ToolTip="Modifica descrizione" Width="28" Height="28" Margin="4,0,0,0"
                                                                                    FontSize="12" Cursor="Hand" Content="&#x270E;"
                                                                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray500Brush}"
                                                                                    Click="BtnServiceEditRtf_Click" Tag="{Binding}" Padding="0" />
                                                                            <!-- Clona -->
                                                                            <Button ToolTip="Duplica prodotto" Width="28" Height="28" Margin="4,0,0,0"
                                                                                    FontSize="12" Cursor="Hand" Content="&#x2398;"
                                                                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray500Brush}"
                                                                                    Click="BtnServiceCloneProduct_Click" Tag="{Binding ParentId}" Padding="0" />
                                                                            <!-- Elimina -->
                                                                            <Button Content="X" Width="28" Height="28" Margin="4,0,0,0"
                                                                                    FontSize="11" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource DangerBrush}"
                                                                                    Click="BtnServiceRemoveProduct_Click" Tag="{Binding ParentId}"
                                                                                    ToolTip="Rimuovi prodotto" Padding="0" />
                                                                            <!-- Expand/Collapse -->
                                                                            <Button Width="28" Height="28" Margin="4,0,0,0"
                                                                                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                                                    Click="BtnServiceToggleExpand_Click" Tag="{Binding}">
                                                                                <TextBlock Text="▼" FontSize="10" Foreground="{StaticResource Gray400Brush}"
                                                                                           RenderTransformOrigin="0.5,0.5">
                                                                                    <TextBlock.RenderTransform>
                                                                                        <RotateTransform Angle="0" />
                                                                                    </TextBlock.RenderTransform>
                                                                                </TextBlock>
                                                                            </Button>
                                                                        </StackPanel>

                                                                        <TextBox Text="{Binding ParentName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                 FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray900Brush}"
                                                                                 VerticalAlignment="Center" BorderThickness="0" Background="Transparent"
                                                                                 Padding="2,0" LostFocus="ServiceProductName_LostFocus" Tag="{Binding ParentId}" />
                                                                    </DockPanel>
                                                                </Border>

                                                                <!-- Header colonne varianti -->
                                                                <Border Padding="12,4" Background="{StaticResource Gray50Brush}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="56" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="65" />
                                                                            <ColumnDefinition Width="100" />
                                                                            <ColumnDefinition Width="100" />
                                                                            <ColumnDefinition Width="70" />
                                                                            <ColumnDefinition Width="110" />
                                                                            <ColumnDefinition Width="30" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="1" Text="DESCRIZIONE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400Brush}" />
                                                                        <TextBlock Grid.Column="2" Text="QTA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Right" />
                                                                        <TextBlock Grid.Column="3" Text="COSTO UNIT." FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Right" Margin="6,0,0,0" />
                                                                        <TextBlock Grid.Column="4" Text="COSTO TOT." FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Right" Margin="8,0" />
                                                                        <TextBlock Grid.Column="5" Text="K" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Center" Margin="4,0,0,0" />
                                                                        <TextBlock Grid.Column="6" Text="VENDITA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Right" Margin="8,0" />
                                                                    </Grid>
                                                                </Border>

                                                                <!-- Variants -->
                                                                <ItemsControl ItemsSource="{Binding Variants}"
                                                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Padding="12,6" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                                <Setter Property="Background" Value="#F9FAFB" />
                                                                                                <Setter Property="Opacity" Value="0.5" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="56" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="65" />
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="70" />
                                                                                        <ColumnDefinition Width="110" />
                                                                                        <ColumnDefinition Width="30" />
                                                                                    </Grid.ColumnDefinitions>

                                                                                    <!-- Toggle -->
                                                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                                                              Style="{StaticResource ToggleSwitchStyle}"
                                                                                              VerticalAlignment="Center"
                                                                                              Checked="ServiceVariantToggle_Changed"
                                                                                              Unchecked="ServiceVariantToggle_Changed" />

                                                                                    <!-- Descrizione -->
                                                                                    <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                             FontSize="12" Foreground="{StaticResource Gray700Brush}"
                                                                                             VerticalAlignment="Center" Margin="0,0,8,0"
                                                                                             Background="Transparent" BorderThickness="0" Padding="2,4"
                                                                                             LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />

                                                                                    <!-- Qtà -->
                                                                                    <TextBox Grid.Column="2" Text="{Binding QuantityText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                             Height="26" FontSize="11" TextAlignment="Right"
                                                                                             LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />

                                                                                    <!-- Costo Unit. -->
                                                                                    <TextBox Grid.Column="3" Text="{Binding CostPriceText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                             Height="26" FontSize="11" TextAlignment="Right" Margin="6,0,0,0"
                                                                                             LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />

                                                                                    <!-- Costo Tot. (read-only) -->
                                                                                    <TextBlock Grid.Column="4" Text="{Binding CostTotalDisplay}" FontSize="11"
                                                                                               Foreground="{StaticResource Gray500Brush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0" />

                                                                                    <!-- K -->
                                                                                    <TextBox Grid.Column="5" Text="{Binding MarkupText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                             Height="26" FontSize="11" TextAlignment="Center" Margin="4,0,0,0"
                                                                                             LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />

                                                                                    <!-- Vendita -->
                                                                                    <TextBlock Grid.Column="6" FontSize="12" FontWeight="SemiBold"
                                                                                               Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"
                                                                                               VerticalAlignment="Center" Margin="8,0"
                                                                                               Text="{Binding LineTotalDisplay}" />

                                                                                    <!-- Rimuovi -->
                                                                                    <Button Grid.Column="7" Content="x" Width="22" Height="22"
                                                                                            FontSize="10" Cursor="Hand"
                                                                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource DangerBrush}"
                                                                                            Click="BtnServiceRemoveVariant_Click" Tag="{Binding Id}"
                                                                                            ToolTip="Rimuovi variante" Padding="0" />
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- ═══ CONTENUTI AUTOMATICI ═══ -->
                                            <Border x:Name="pnlServiceAutoIncludes" Margin="8,8,8,0" Background="White"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Visibility="Collapsed">
                                                <StackPanel>
                                                    <Border Padding="12,8" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="0,0,0,1">
                                                        <DockPanel>
                                                            <Button DockPanel.Dock="Right" Content="Ricarica dal catalogo"
                                                                    FontSize="11" Cursor="Hand" Padding="8,4"
                                                                    Background="White" Foreground="{StaticResource SuccessBrush}" BorderBrush="#BBF7D0" BorderThickness="1"
                                                                    Click="BtnServiceReloadAutoIncludes_Click" />
                                                            <TextBlock VerticalAlignment="Center">
                                                                <Run Text="CONTENUTI AUTOMATICI" FontWeight="Bold" FontSize="12" Foreground="#166534" />
                                                                <Run x:Name="txtServiceAutoCount" Text="" FontSize="11" Foreground="{StaticResource Gray500Brush}" />
                                                            </TextBlock>
                                                        </DockPanel>
                                                    </Border>
                                                    <ItemsControl x:Name="icServiceAutoIncludes" Padding="4">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="8,6" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                                                                    <DockPanel>
                                                                        <Button DockPanel.Dock="Right" Content="x" Width="22" Height="22"
                                                                                FontSize="10" Cursor="Hand"
                                                                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource DangerBrush}"
                                                                                Click="BtnServiceRemoveAutoInclude_Click" Tag="{Binding ParentId}"
                                                                                ToolTip="Rimuovi" Padding="0" />
                                                                        <Button DockPanel.Dock="Right" Content="&#x270E;" Width="22" Height="22"
                                                                                FontSize="12" Cursor="Hand" Margin="0,0,4,0"
                                                                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray500Brush}"
                                                                                Click="BtnServiceEditAutoIncludeRtf_Click" Tag="{Binding}"
                                                                                ToolTip="Modifica contenuto" Padding="0" />
                                                                        <TextBlock Text="{Binding ParentName}" FontSize="12" Foreground="{StaticResource Gray700Brush}"
                                                                                   VerticalAlignment="Center" FontStyle="Italic" />
                                                                    </DockPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Bottone aggiungi centrato -->
                                            <Button Background="{StaticResource SuccessBrush}" Foreground="White" FontSize="12" Cursor="Hand"
                                                    Content="+ Aggiungi al preventivo" Padding="16,8" Margin="0,12"
                                                    HorizontalAlignment="Center"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Click="BtnServiceAddProduct_Click" />

                                            <!-- Empty placeholder -->
                                            <TextBlock x:Name="txtServiceNoProducts"
                                                       Text="Nessun prodotto aggiunto. Clicca '+ Aggiungi Prodotto' per iniziare."
                                                       FontSize="12" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Center" Margin="0,30,0,30"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            </Grid> <!-- chiude Grid Row="1" pannelli -->
                        </Grid> <!-- chiude CONTENT AREA -->
                    </DockPanel>
                </Grid>
    </DockPanel>
</Page>
