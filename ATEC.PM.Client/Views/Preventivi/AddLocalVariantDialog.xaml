<Window
    x:Class="ATEC.PM.Client.Views.Preventivi.AddLocalVariantDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi variante locale"
    Width="420"
    Height="340"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">
        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#374151" Text="{Binding ProductName}" Margin="0,0,0,16" />

        <TextBlock FontSize="11" Foreground="#6B7280" Text="Nome variante *" Margin="0,0,0,4" />
        <TextBox x:Name="txtName" Height="30" FontSize="12" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10" />

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="Codice" Margin="0,0,0,4" />
                <TextBox x:Name="txtCode" Height="30" FontSize="12" Style="{StaticResource ModernTextBox}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="UdM" Margin="0,0,0,4" />
                <TextBox x:Name="txtUnit" Height="30" FontSize="12" Style="{StaticResource ModernTextBox}" Text="nr." />
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="Prezzo vendita €" Margin="0,0,0,4" />
                <TextBox x:Name="txtPrice" Height="30" FontSize="12" TextAlignment="Right" Style="{StaticResource ModernTextBox}" Text="0" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="Costo aziendale €" Margin="0,0,0,4" />
                <TextBox x:Name="txtCost" Height="30" FontSize="12" TextAlignment="Right" Style="{StaticResource ModernTextBox}" Text="0" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="Qtà" Margin="0,0,0,4" />
                <TextBox x:Name="txtQty" Height="30" FontSize="12" TextAlignment="Right" Style="{StaticResource ModernTextBox}" Text="1" />
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annulla" Width="80" Click="BtnCancel_Click" Style="{StaticResource FlatBtn}" Margin="0,0,8,0" />
            <Button Content="Aggiungi" Width="100" Click="BtnAdd_Click" Style="{StaticResource PrimaryBtn}" />
        </StackPanel>
    </StackPanel>
</Window>
