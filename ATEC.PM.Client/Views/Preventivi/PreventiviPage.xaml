<Page
    x:Class="ATEC.PM.Client.Views.Preventivi.PreventiviPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:costing="clr-namespace:ATEC.PM.Client.Views.Costing"
    xmlns:prev="clr-namespace:ATEC.PM.Client.Views.Preventivi"
    Background="#F7F8FA"
    Loaded="Page_Loaded">

    <Page.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation
                Storyboard.TargetName="pnlQuoteDetail"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation
                Storyboard.TargetName="pnlQuoteDetail"
                Storyboard.TargetProperty="Margin"
                From="0,15,0,0"
                To="0,0,0,0"
                Duration="0:0:0.4">
                <ThicknessAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <Style x:Key="SmoothTreeItem" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border
                                x:Name="Bd"
                                Margin="0,1,0,1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Path
                                        x:Name="Expander"
                                        Grid.Column="0"
                                        Width="8"
                                        Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0,0 L 5,5 L 0,10"
                                        RenderTransformOrigin="0.5,0.5"
                                        Stroke="#9CA3AF"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.5">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="ExpanderRotation" Angle="0" />
                                        </Path.RenderTransform>
                                    </Path>

                                    <ContentPresenter
                                        x:Name="PART_Header"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        ContentSource="Header" />
                                </Grid>
                            </Border>

                            <ItemsPresenter
                                x:Name="ItemsHost"
                                Margin="16,4,0,0"
                                Opacity="0"
                                Visibility="Collapsed">
                                <ItemsPresenter.LayoutTransform>
                                    <ScaleTransform x:Name="ItemsScale" ScaleY="0" />
                                </ItemsPresenter.LayoutTransform>
                            </ItemsPresenter>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>

                            <Trigger Property="IsExpanded" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ItemsHost" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ExpanderRotation"
                                                Storyboard.TargetProperty="Angle"
                                                To="90"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsHost"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ExpanderRotation"
                                                Storyboard.TargetProperty="Angle"
                                                To="0"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemsHost"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0"
                                                Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ItemsHost" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.35">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Collapsed</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEF2FF" />
                                <Setter TargetName="PART_Header" Property="TextElement.Foreground" Value="#4F6EF7" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E0E7FF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Tree -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <Border
                    Style="{StaticResource ToolbarBorder}"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <Button
                            Background="#4F6EF7"
                            Click="BtnNew_Click"
                            Content="+ Nuovo"
                            Foreground="White"
                            Style="{StaticResource PrimaryBtn}" />
                        <Button
                            HorizontalAlignment="Right"
                            Click="BtnRefresh_Click"
                            Content="Aggiorna"
                            DockPanel.Dock="Right"
                            Style="{StaticResource FlatBtn}" />
                    </DockPanel>
                </Border>

                <Border Padding="12,12,12,8" DockPanel.Dock="Top">
                    <Grid>
                        <TextBox
                            x:Name="txtSearch"
                            Height="36"
                            Padding="12,0,12,0"
                            VerticalContentAlignment="Center"
                            Background="#F9FAFB"
                            BorderBrush="#D1D5DB"
                            FontSize="13"
                            TextChanged="TxtSearch_Changed">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="18" />
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock
                            x:Name="txtSearchPlaceholder"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#9CA3AF"
                            IsHitTestVisible="False"
                            Text="Cerca preventivo o cliente..." />
                    </Grid>
                </Border>

                <Border
                    Padding="12,6"
                    Background="#FAFBFC"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <TextBlock
                        x:Name="txtStatus"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="#9CA3AF"
                        Text="Caricamento..." />
                </Border>

                <TreeView
                    x:Name="tree"
                    Padding="8,4"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectedItemChanged="Tree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <StaticResource ResourceKey="SmoothTreeItem" />
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- RIGHT PANEL: Detail -->
        <Border Grid.Column="1">
            <DockPanel>
                <!-- Header bar -->
                <Border
                    Padding="30,16"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            x:Name="txtSectionTitle"
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="Seleziona un preventivo" />
                        <StackPanel
                            x:Name="pnlActions"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Visibility="Collapsed">

                            <Button
                                x:Name="btnSetSent"
                                Background="#3B82F6"
                                Click="BtnSetSent_Click"
                                Content="Invia"
                                Foreground="White"
                                Style="{StaticResource PrimaryBtn}" />
                            <Button
                                x:Name="btnSetAccepted"
                                Margin="8,0,0,0"
                                Background="#10B981"
                                Click="BtnSetAccepted_Click"
                                Content="Accetta"
                                Foreground="White"
                                Style="{StaticResource SuccessBtn}" />
                            <Button
                                x:Name="btnSetRejected"
                                Margin="8,0,0,0"
                                Background="#EF4444"
                                Click="BtnSetRejected_Click"
                                Content="Rifiuta"
                                Foreground="White"
                                Style="{StaticResource DangerBtn}" />
                            <Button
                                x:Name="btnConvert"
                                Margin="8,0,0,0"
                                Background="#10B981"
                                Click="BtnConvert_Click"
                                Content="Converti in Commessa"
                                Foreground="White"
                                Style="{StaticResource SuccessBtn}" />
                            <Border
                                Width="1"
                                Margin="12,4"
                                Background="#E4E7EC" />
                            <Button
                                x:Name="btnPdf"
                                Click="BtnPdf_Click"
                                Content="PDF"
                                Foreground="#6B7280"
                                Style="{StaticResource FlatBtn}" />
                            <Button
                                x:Name="btnDelete"
                                Margin="8,0,0,0"
                                Background="#FEE2E2"
                                Click="BtnDelete_Click"
                                Content="Elimina"
                                Foreground="#DC2626"
                                Style="{StaticResource FlatBtn}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid>
                    <!-- Placeholder -->
                    <StackPanel
                        x:Name="pnlPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="48"
                            Foreground="#E4E7EC"
                            Text="&#x1F4CB;" />
                        <TextBlock
                            Margin="0,16,0,0"
                            HorizontalAlignment="Center"
                            FontSize="15"
                            FontWeight="Medium"
                            Foreground="#9CA3AF"
                            Text="Seleziona un preventivo dall'albero per visualizzarne i dettagli" />
                    </StackPanel>

                    <!-- Detail panel -->
                    <DockPanel
                        x:Name="pnlQuoteDetail"
                        Margin="0,15,0,0"
                        Visibility="Collapsed">

                        <!-- Info strip -->
                        <Border
                            Padding="30,12"
                            Background="#FAFBFC"
                            BorderBrush="#E4E7EC"
                            BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    x:Name="brdStatusBadge"
                                    Padding="12,4"
                                    Background="#F3F4F6"
                                    CornerRadius="12">
                                    <TextBlock
                                        x:Name="txtQuoteStatus"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="#374151" />
                                </Border>
                                <TextBlock
                                    x:Name="txtQuoteCustomer"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Foreground="#4B5563" />
                                <TextBlock
                                    x:Name="txtQuoteCreatedBy"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#9CA3AF" />
                                <TextBlock
                                    x:Name="txtQuoteDate"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#9CA3AF" />
                                <Border
                                    x:Name="brdTypeBadge"
                                    Margin="16,0,0,0"
                                    Padding="10,3"
                                    CornerRadius="10"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="txtQuoteType"
                                        FontSize="11"
                                        FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Two-panel layout: Info sx + Contenuto dx -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Editable info panel -->
                            <Border Grid.Column="0" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,1,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="16,16,16,16">

                                        <!-- TITOLO -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Titolo" Margin="0,0,0,4" />
                                        <TextBox x:Name="txtEditTitle" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- READ-ONLY: Numero -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Numero" Margin="0,14,0,4" />
                                        <TextBlock x:Name="txtInfoNumero" FontSize="13" Foreground="#374151" Padding="8,6" />

                                        <!-- READ-ONLY: Cliente -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Cliente" Margin="0,10,0,4" />
                                        <TextBlock x:Name="txtInfoCliente" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB" Padding="8,6" />

                                        <!-- READ-ONLY: Creato da -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Creato da" Margin="0,10,0,4" />
                                        <TextBlock x:Name="txtInfoCreatoDa" FontSize="13" Foreground="#374151" Padding="8,6" />

                                        <!-- READ-ONLY: Data -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Data" Margin="0,10,0,4" />
                                        <TextBlock x:Name="txtInfoData" FontSize="13" Foreground="#374151" Padding="8,6" />

                                        <!-- READ-ONLY: Tipo -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Tipo" Margin="0,10,0,4" />
                                        <TextBlock x:Name="txtInfoTipo" FontSize="13" Foreground="#374151" Padding="8,6" />

                                        <!-- Separator -->
                                        <Border Height="1" Background="#E4E7EC" Margin="0,16,0,12" />

                                        <!-- CONTATTO: Nome -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Referente 1" Margin="0,0,0,4" />
                                        <TextBox x:Name="txtEditContact1" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- CONTATTO: Email -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Referente 2" Margin="0,10,0,4" />
                                        <TextBox x:Name="txtEditContact2" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- CONTATTO: Telefono -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Referente 3" Margin="0,10,0,4" />
                                        <TextBox x:Name="txtEditContact3" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- Separator -->
                                        <Border Height="1" Background="#E4E7EC" Margin="0,16,0,12" />

                                        <!-- Tipo pagamento -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Tipo pagamento" Margin="0,0,0,4" />
                                        <TextBox x:Name="txtEditPaymentType" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- Validita (gg) -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Validit&#224; offerta (gg)" Margin="0,10,0,4" />
                                        <TextBox x:Name="txtEditValidityDays" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- Tempi consegna (gg) -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Tempi consegna (gg)" Margin="0,10,0,4" />
                                        <TextBox x:Name="txtEditDeliveryDays" FontSize="13" Padding="8,6" Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- Separator -->
                                        <Border Height="1" Background="#E4E7EC" Margin="0,16,0,12" />

                                        <!-- Note interne -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Note interne" Margin="0,0,0,4" />
                                        <TextBox x:Name="txtEditNotesInternal" FontSize="12" Padding="8,6" Height="80"
                                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                 Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- Note preventivo -->
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Note preventivo" Margin="0,10,0,4" />
                                        <TextBox x:Name="txtEditNotesQuote" FontSize="12" Padding="8,6" Height="80"
                                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                 Background="#F9FAFB" BorderBrush="#D1D5DB"
                                                 LostFocus="InfoField_LostFocus">
                                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></TextBox.Resources>
                                        </TextBox>

                                        <!-- Separator -->
                                        <Border Height="1" Background="#E4E7EC" Margin="0,16,0,12" />

                                        <!-- PDF Options -->
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#6B7280" Text="OPZIONI PDF" Margin="0,0,0,8" />
                                        <CheckBox x:Name="chkShowItemPrices" Content="Prezzi su articoli" FontSize="12" Margin="0,0,0,6"
                                                  IsChecked="True" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                        <CheckBox x:Name="chkShowSummary" Content="Riepilogo finale" FontSize="12" Margin="0,0,0,6"
                                                  IsChecked="True" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                        <CheckBox x:Name="chkShowSummaryPrices" Content="Prezzi su riepilogo" FontSize="12" Margin="0,0,0,6"
                                                  IsChecked="True" Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />
                                        <CheckBox x:Name="chkHideQuantities" Content="Nascondi quantit&#224;" FontSize="12" Margin="0,0,0,6"
                                                  Checked="InfoCheckBox_Changed" Unchecked="InfoCheckBox_Changed" />

                                        <!-- Separator -->
                                        <Border Height="1" Background="#E4E7EC" Margin="0,16,0,12" />

                                        <!-- TOTALS (read-only) -->
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#6B7280" Text="TOTALI" Margin="0,0,0,8" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24" />
                                                <RowDefinition Height="24" />
                                                <RowDefinition Height="2" />
                                                <RowDefinition Height="28" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Foreground="#6B7280" Text="Subtotale" VerticalAlignment="Center" />
                                            <TextBlock x:Name="txtInfoSubtotal" Grid.Row="0" Grid.Column="1" FontSize="12" Foreground="#374151" HorizontalAlignment="Right" VerticalAlignment="Center" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" Foreground="#6B7280" Text="Sconto" VerticalAlignment="Center" />
                                            <TextBlock x:Name="txtInfoDiscount" Grid.Row="1" Grid.Column="1" FontSize="12" Foreground="#DC2626" HorizontalAlignment="Right" VerticalAlignment="Center" />

                                            <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" />

                                            <TextBlock Grid.Row="3" Grid.Column="0" FontSize="13" FontWeight="Bold" Foreground="#111827" Text="Totale" VerticalAlignment="Center" />
                                            <TextBlock x:Name="txtInfoTotal" Grid.Row="3" Grid.Column="1" FontSize="13" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- RIGHT: Contenuto principale -->
                            <Grid Grid.Column="1">
                                <!-- IMPIANTO: CostingTreeControl (SfTreeGrid) -->
                                <prev:CostingTreeControl
                                    x:Name="costingTreeControl"
                                    Visibility="Collapsed" />

                                <!-- SERVICE: Catalogo prodotti -->
                                <Border
                                    x:Name="pnlServiceCatalog"
                                    Background="#FAFBFC"
                                    Visibility="Collapsed">
                                    <DockPanel>
                                        <!-- Toolbar -->
                                        <Border Padding="20,10" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" DockPanel.Dock="Top">
                                            <DockPanel>
                                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#1A1D26" Text="Prodotti &amp; Contenuti" VerticalAlignment="Center" />
                                                <Button
                                                    x:Name="btnServiceAddProduct"
                                                    HorizontalAlignment="Right"
                                                    DockPanel.Dock="Right"
                                                    Background="#16A34A"
                                                    Click="BtnServiceAddProduct_Click"
                                                    Content="+ Aggiungi Prodotto"
                                                    Cursor="Hand"
                                                    FontSize="12"
                                                    Foreground="White"
                                                    Style="{StaticResource PrimaryBtn}" />
                                            </DockPanel>
                                        </Border>

                                        <!-- Totals footer -->
                                        <Border Padding="20,12" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="180" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="26" />
                                                    <RowDefinition Height="26" />
                                                    <RowDefinition Height="2" />
                                                    <RowDefinition Height="30" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="#6B7280" Text="Subtotale" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceSubtotal" Grid.Row="0" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="#374151" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="#6B7280" Text="Sconto" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceDiscount" Grid.Row="1" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="12" Foreground="#DC2626" />

                                                <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="14" FontWeight="Bold" Foreground="#111827" Text="Totale" Margin="0,0,12,0" />
                                                <TextBlock x:Name="txtServiceTotal" Grid.Row="3" Grid.Column="1"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="14" FontWeight="Bold" Foreground="#111827" />
                                            </Grid>
                                        </Border>

                                        <!-- Product list -->
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <ItemsControl x:Name="icServiceProducts" Padding="8,4,8,4">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,4" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="6" Background="White">
                                                                <StackPanel>
                                                                    <!-- Product header -->
                                                                    <Border Padding="12,10" Background="#F8FAFC" CornerRadius="6,6,0,0" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                                                                        <DockPanel>
                                                                            <Border Padding="6,3" Margin="0,0,10,0" VerticalAlignment="Center" CornerRadius="4"
                                                                                    Background="{Binding TypeBadgeColor}">
                                                                                <TextBlock Text="{Binding TypeBadgeLabel}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                                            </Border>

                                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding TotalDisplay}" FontSize="13" FontWeight="Bold" Foreground="#111827"
                                                                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                                                                <Button Content="+" ToolTip="Aggiungi variante" Width="28" Height="28"
                                                                                        FontSize="14" FontWeight="Bold" Cursor="Hand"
                                                                                        Background="#EFF6FF" Foreground="#2563EB" BorderBrush="#BFDBFE" BorderThickness="1"
                                                                                        Click="BtnServiceAddVariant_Click" Tag="{Binding ParentId}" Padding="0" />
                                                                                <Button Content="X" Width="28" Height="28" Margin="4,0,0,0"
                                                                                        FontSize="11" Cursor="Hand"
                                                                                        Background="Transparent" BorderThickness="0" Foreground="#DC2626"
                                                                                        Click="BtnServiceRemoveProduct_Click" Tag="{Binding ParentId}"
                                                                                        ToolTip="Rimuovi prodotto" Padding="0" />
                                                                            </StackPanel>

                                                                            <TextBlock Text="{Binding ParentName}" FontSize="13" FontWeight="SemiBold"
                                                                                       Foreground="#1A1D26" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                        </DockPanel>
                                                                    </Border>

                                                                    <!-- Variants -->
                                                                    <ItemsControl ItemsSource="{Binding Variants}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="12,6" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                                                                    <DockPanel>
                                                                                        <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                                                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                                                                                  Checked="ServiceVariantToggle_Changed"
                                                                                                  Unchecked="ServiceVariantToggle_Changed" />

                                                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                            <TextBlock Text="{Binding LineTotalDisplay}" FontSize="12" FontWeight="SemiBold"
                                                                                                       Foreground="{Binding TotalColor}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                                            <Button Content="X" Width="22" Height="22"
                                                                                                    FontSize="10" Cursor="Hand"
                                                                                                    Background="Transparent" BorderThickness="0" Foreground="#9CA3AF"
                                                                                                    Click="BtnServiceRemoveVariant_Click" Tag="{Binding Id}"
                                                                                                    ToolTip="Rimuovi variante" Padding="0" />
                                                                                        </StackPanel>

                                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#374151"
                                                                                                       Width="250" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                                            <TextBox Text="{Binding QuantityText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                                     Width="55" Height="26" FontSize="11" TextAlignment="Right" Margin="8,0"
                                                                                                     LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />
                                                                                            <TextBlock Text="{Binding Unit}" FontSize="11" Foreground="#6B7280"
                                                                                                       Width="35" VerticalAlignment="Center" />
                                                                                            <TextBox Text="{Binding SellPriceText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                                     Width="85" Height="26" FontSize="11" TextAlignment="Right" Margin="4,0"
                                                                                                     LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />
                                                                                            <TextBlock Text="&#8364;" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                                            <TextBox Text="{Binding DiscountPctText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                                                     Width="45" Height="26" FontSize="11" TextAlignment="Right" Margin="4,0"
                                                                                                     LostFocus="ServiceVariantField_LostFocus" Tag="{Binding Id}" />
                                                                                            <TextBlock Text="%" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" />
                                                                                        </StackPanel>
                                                                                    </DockPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Empty placeholder -->
                                                <TextBlock x:Name="txtServiceNoProducts"
                                                           Text="Nessun prodotto aggiunto. Clicca '+ Aggiungi Prodotto' per iniziare."
                                                           FontSize="12" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,30,0,30"
                                                           Visibility="Collapsed" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </DockPanel>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Page>
