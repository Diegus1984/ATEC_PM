<Page
    x:Class="ATEC.PM.Client.Views.Preventivi.QuotesListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <DockPanel>
        <!-- TOOLBAR -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ToolbarBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnNew" Content="+ Crea Preventivo"
                            Style="{StaticResource PrimaryBtn}" Margin="0,0,12,0"
                            Click="BtnNew_Click" />
                    <Rectangle Width="1" Fill="#E4E7EC" Margin="12,2" />
                    <Button Content="Aggiorna" Style="{StaticResource FlatBtn}"
                            Click="BtnRefresh_Click" />
                </StackPanel>

                <!-- Filtri a destra -->
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <TextBlock Text="Tipo:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#6B7280" Margin="0,0,6,0" />
                    <ComboBox x:Name="cmbTypeFilter" Width="120" Height="32" FontSize="12"
                              SelectionChanged="TypeFilter_Changed">
                        <ComboBoxItem Content="Tutti" Tag="" IsSelected="True" />
                        <ComboBoxItem Content="Servizio" Tag="SERVICE" />
                        <ComboBoxItem Content="Impianto" Tag="IMPIANTO" />
                    </ComboBox>

                    <TextBlock Text="Stato:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#6B7280" Margin="12,0,6,0" />
                    <ComboBox x:Name="cmbStatusFilter" Width="140" Height="32" FontSize="12"
                              SelectionChanged="StatusFilter_Changed">
                        <ComboBoxItem Content="Tutti" Tag="" IsSelected="True" />
                        <ComboBoxItem Content="In preparazione" Tag="draft" />
                        <ComboBoxItem Content="Preventivo inviato" Tag="sent" />
                        <ComboBoxItem Content="In trattativa" Tag="negotiation" />
                        <ComboBoxItem Content="Il cliente ha confermato" Tag="accepted" />
                        <ComboBoxItem Content="Cliente non interessato" Tag="rejected" />
                        <ComboBoxItem Content="Scaduto" Tag="expired" />
                        <ComboBoxItem Content="Convertito" Tag="converted" />
                    </ComboBox>
                    <TextBox x:Name="txtSearch" Width="200" Height="32" FontSize="12"
                             Margin="12,0,0,0" Style="{StaticResource ModernTextBox}"
                             TextChanged="TxtSearch_Changed" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- STATUS BAR -->
        <Border DockPanel.Dock="Bottom" Background="White"
                BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,6">
            <Grid>
                <TextBlock x:Name="txtStatus" Text="Caricamento..."
                           HorizontalAlignment="Left"
                           FontSize="11" Foreground="#6B7280" />
                <TextBlock HorizontalAlignment="Right"
                           FontSize="11" FontStyle="Italic" Foreground="#9CA3AF"
                           Text="Filtri: abc = contiene  |  abc* = inizia con  |  *abc = finisce con" />
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <DataGrid x:Name="dgQuotes"
                  Style="{StaticResource ModernDataGrid}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgQuotes_SelectionChanged"
                  MouseDoubleClick="DgQuotes_DoubleClick">
            <DataGrid.Columns>
                <!-- Numero -->
                <DataGridTemplateColumn Width="140" SortMemberPath="QuoteNumber">
                    <DataGridTemplateColumn.Header>
                        <StackPanel>
                            <TextBlock Text="NUMERO" Style="{StaticResource DgHeaderText}" />
                            <TextBox Tag="QuoteNumber" Style="{StaticResource HeaderSearchBox}"
                                     TextChanged="Filter_Changed" Loaded="Filter_Loaded" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding QuoteNumber}" Style="{StaticResource DgCellText}"
                                       FontWeight="SemiBold" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Tipo -->
                <DataGridTemplateColumn Header="TIPO" Width="80" SortMemberPath="QuoteType">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="4,2" HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F0FDF4" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QuoteType}" Value="IMPIANTO">
                                                <Setter Property="Background" Value="#FFF7ED" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="10" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="SRV" />
                                            <Setter Property="Foreground" Value="#059669" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding QuoteType}" Value="IMPIANTO">
                                                    <Setter Property="Text" Value="IMP" />
                                                    <Setter Property="Foreground" Value="#EA580C" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Data -->
                <DataGridTemplateColumn Width="90" SortMemberPath="CreatedAt">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="DATA" Style="{StaticResource DgHeaderText}" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CreatedAt, StringFormat=dd/MM/yyyy}"
                                       Style="{StaticResource DgCellText}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cliente -->
                <DataGridTemplateColumn Width="*" MinWidth="160" SortMemberPath="CustomerName">
                    <DataGridTemplateColumn.Header>
                        <StackPanel>
                            <TextBlock Text="CLIENTE" Style="{StaticResource DgHeaderText}" />
                            <TextBox Tag="CustomerName" Style="{StaticResource HeaderSearchBox}"
                                     TextChanged="Filter_Changed" Loaded="Filter_Loaded" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CustomerName}" Style="{StaticResource DgCellText}"
                                       Foreground="#2563EB" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Titolo -->
                <DataGridTemplateColumn Width="*" MinWidth="200" SortMemberPath="Title">
                    <DataGridTemplateColumn.Header>
                        <StackPanel>
                            <TextBlock Text="TITOLO" Style="{StaticResource DgHeaderText}" />
                            <TextBox Tag="Title" Style="{StaticResource HeaderSearchBox}"
                                     TextChanged="Filter_Changed" Loaded="Filter_Loaded" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource DgCellText}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Totale -->
                <DataGridTemplateColumn Width="110" SortMemberPath="Total">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="TOTALE" Style="{StaticResource DgHeaderText}" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Total, StringFormat='{}{0:N2}€'}"
                                       Style="{StaticResource DgCellText}" FontWeight="SemiBold" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Utile -->
                <DataGridTemplateColumn Width="110" SortMemberPath="Profit">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="UTILE" Style="{StaticResource DgHeaderText}" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Profit, StringFormat='{}{0:N2}€'}"
                                       Style="{StaticResource DgCellText}" FontWeight="Bold"
                                       Foreground="#16A34A" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Stato (ComboBox inline con colori) -->
                <DataGridTemplateColumn Width="180" SortMemberPath="Status">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="STATO" Style="{StaticResource DgHeaderText}" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox x:Name="cmbStatus" Tag="{Binding Id}"
                                      SelectedValue="{Binding Status, Mode=OneWay}"
                                      SelectedValuePath="Tag"
                                      SelectionChanged="StatusCombo_Changed"
                                      FontSize="11" FontWeight="SemiBold" Height="28"
                                      HorizontalAlignment="Left" MinWidth="160"
                                      Background="{Binding Status, Converter={StaticResource QuoteStatusToBgConverter}}"
                                      Foreground="{Binding Status, Converter={StaticResource QuoteStatusToFgConverter}}"
                                      BorderBrush="{Binding Status, Converter={StaticResource QuoteStatusToBgConverter}}">
                                <ComboBoxItem Tag="draft">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#9CA3AF" Margin="0,0,8,0" />
                                        <TextBlock Text="In preparazione" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="sent">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="0,0,8,0" />
                                        <TextBlock Text="Preventivo inviato" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="negotiation">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,8,0" />
                                        <TextBlock Text="In trattativa" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="accepted">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,8,0" />
                                        <TextBlock Text="Il cliente ha confermato" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="rejected">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0" />
                                        <TextBlock Text="Cliente non interessato" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="expired">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#6B7280" Margin="0,0,8,0" />
                                        <TextBlock Text="Scaduto" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="converted">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#059669" Margin="0,0,8,0" />
                                        <TextBlock Text="Convertito" />
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Agente -->
                <DataGridTemplateColumn Width="120" SortMemberPath="CreatedByName">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="AGENTE" Style="{StaticResource DgHeaderText}" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CreatedByName}" Style="{StaticResource DgCellText}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Azioni -->
                <DataGridTemplateColumn Width="200" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="4,0">
                                <!-- Visualizza PDF -->
                                <Button Tag="{Binding Id}" Click="RowBtnPreview_Click"
                                        ToolTip="Visualizza PDF" Cursor="Hand"
                                        Width="30" Height="26" Margin="1,0"
                                        Background="#10B981" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="4,2">
                                                <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Scarica PDF -->
                                <Button Tag="{Binding Id}" Click="RowBtnDownload_Click"
                                        ToolTip="Scarica PDF" Cursor="Hand"
                                        Width="30" Height="26" Margin="1,0"
                                        Background="#3B82F6" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="4,2">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Invia email (placeholder) -->
                                <Button Tag="{Binding Id}" Click="RowBtnSend_Click"
                                        ToolTip="Invia al cliente" Cursor="Hand"
                                        Width="30" Height="26" Margin="1,0"
                                        Background="#8B5CF6" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="4,2">
                                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Duplica -->
                                <Button Tag="{Binding Id}" Click="RowBtnDuplicate_Click"
                                        ToolTip="Duplica preventivo" Cursor="Hand"
                                        Width="30" Height="26" Margin="1,0"
                                        Background="#F59E0B" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="4,2">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Modifica -->
                                <Button Tag="{Binding Id}" Click="RowBtnEdit_Click"
                                        ToolTip="Modifica preventivo" Cursor="Hand"
                                        Width="30" Height="26" Margin="1,0"
                                        Background="#06B6D4" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="4,2">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Cancella -->
                                <Button Tag="{Binding Id}" Click="RowBtnDelete_Click"
                                        ToolTip="Elimina preventivo" Cursor="Hand"
                                        Width="30" Height="26" Margin="1,0"
                                        Background="#EF4444" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="4,2">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
