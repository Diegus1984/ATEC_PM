<Window
    x:Class="ATEC.PM.Client.Views.Preventivi.AddMaterialVariantDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi variante materiale"
    Width="420"
    Height="310"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">
        <TextBlock x:Name="txtHeader" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,16" />

        <TextBlock FontSize="11" Foreground="#6B7280" Text="Descrizione *" Margin="0,0,0,4" />
        <TextBox x:Name="txtDescription" Height="30" FontSize="12" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="Costo unitario &#x20AC;" Margin="0,0,0,4" />
                <TextBox x:Name="txtUnitCost" Height="30" FontSize="12" TextAlignment="Right" Style="{StaticResource ModernTextBox}" Text="0" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="K (markup)" Margin="0,0,0,4" />
                <TextBox x:Name="txtMarkup" Height="30" FontSize="12" TextAlignment="Right" Style="{StaticResource ModernTextBox}" Text="1,300" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock FontSize="11" Foreground="#6B7280" Text="Qtà" Margin="0,0,0,4" />
                <TextBox x:Name="txtQty" Height="30" FontSize="12" TextAlignment="Right" Style="{StaticResource ModernTextBox}" Text="1" />
            </StackPanel>
        </Grid>

        <Border Background="#F0FDF4" CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
            <TextBlock x:Name="txtPreview" FontSize="12" FontWeight="SemiBold" Foreground="#059669" HorizontalAlignment="Right" />
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Width="80" Click="BtnCancel_Click" Style="{StaticResource FlatBtn}" Margin="0,0,8,0" />
            <Button Content="Aggiungi" Width="100" Click="BtnAdd_Click" Style="{StaticResource PrimaryBtn}" />
        </StackPanel>
    </StackPanel>
</Window>
