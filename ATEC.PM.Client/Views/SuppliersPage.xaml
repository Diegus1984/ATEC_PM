<Page x:Class="ATEC.PM.Client.Views.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <Page.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/><Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="+ Nuovo" Background="#4F6EF7" Foreground="White" Style="{StaticResource FlatBtn}" Click="BtnNew_Click"/>
                    <Button x:Name="btnEdit" Content="Modifica" Background="#F3F4F6" Foreground="#374151" Style="{StaticResource FlatBtn}" Margin="8,0,0,0" Click="BtnEdit_Click" IsEnabled="False"/>
                    <Button x:Name="btnDelete" Content="Elimina" Background="#FEE2E2" Foreground="#DC2626" Style="{StaticResource FlatBtn}" Margin="8,0,0,0" Click="BtnDelete_Click" IsEnabled="False"/>
                </StackPanel>
                <Button Content="Aggiorna" Background="#F3F4F6" Foreground="#374151" Style="{StaticResource FlatBtn}" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="BtnRefresh_Click"/>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock x:Name="txtStatus" Text="Caricamento..." FontSize="12" Foreground="#6B7280"/>
        </Border>
        <DataGrid x:Name="dgSuppliers" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="Dg_SelectionChanged" MouseDoubleClick="Dg_DoubleClick"
                  Background="White" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                  RowHeight="40" ColumnHeaderHeight="40" FontSize="13">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F9FAFB"/><Setter Property="Foreground" Value="#6B7280"/>
                    <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,0"/><Setter Property="BorderBrush" Value="#E4E7EC"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#EEF2FF"/></Trigger>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F9FAFB"/></Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="12,0"/><Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True"><Setter Property="Foreground" Value="#1A1D26"/></Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ragione Sociale" Binding="{Binding CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Referente" Binding="{Binding ContactName}" Width="160"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                <DataGridTextColumn Header="Telefono" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="P.IVA" Binding="{Binding VatNumber}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
