<Window
    x:Class="ATEC.PM.Client.Views.PhasesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fasi Commessa"
    Width="700"
    Height="500"
    Background="#F7F8FA"
    WindowStartupLocation="CenterOwner">

    <DockPanel>
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtStatus"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#6B7280"
                    Text="" />
                <Button
                    Width="90"
                    Height="34"
                    HorizontalAlignment="Right"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnClose_Click"
                    Content="Chiudi"
                    Cursor="Hand"
                    DockPanel.Dock="Right"
                    Foreground="#374151" />
            </DockPanel>
        </Border>

        <DataGrid
            x:Name="dgPhases"
            Margin="0"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            ColumnHeaderHeight="38"
            FontSize="13"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="True"
            RowHeight="38">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F9FAFB" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderBrush" Value="#E4E7EC" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EEF2FF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F9FAFB" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#1A1D26" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Fase" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding BudgetHours}"
                    Header="Ore Prev." />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding HoursWorked, StringFormat='{}{0:N1}'}"
                    Header="Ore Fatte" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Status}"
                    Header="Stato" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding ProgressPct, StringFormat='{}{0}%'}"
                    Header="Progresso" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
