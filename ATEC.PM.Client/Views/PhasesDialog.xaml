<Window
    x:Class="ATEC.PM.Client.Views.PhasesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Gestione Fase"
    Width="600"
    Height="650"
    Background="#F7F8FA"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ExpHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#374151" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <!--  BOTTOM BUTTONS  -->
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtError"
                    MaxWidth="340"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="12"
                    Foreground="#EF4444"
                    TextWrapping="Wrap" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Height="34"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Cursor="Hand"
                        Foreground="#374151" />
                    <Button
                        x:Name="btnSave"
                        Width="110"
                        Height="34"
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnSave_Click"
                        Content="Salva"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Padding="16,12,16,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  FASE  -->
                <Expander Margin="0,0,0,8" IsExpanded="True">
                    <Expander.Header>
                        <Border Padding="0,6" Background="Transparent">
                            <TextBlock Style="{StaticResource ExpHeader}" Text="📋  FASE" />
                        </Border>
                    </Expander.Header>
                    <Border
                        Margin="0,0,0,8"
                        Padding="16,4,16,12"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="TIPO FASE *" />
                            <ComboBox
                                x:Name="cmbTemplate"
                                Height="32"
                                Padding="8,5"
                                BorderBrush="#E4E7EC"
                                FontSize="13"
                                SelectionChanged="CmbTemplate_SelectionChanged" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="NOME PERSONALIZZATO (opzionale)" />
                            <TextBox
                                x:Name="txtCustomName"
                                Style="{StaticResource FieldInput}"
                                ToolTip="Lascia vuoto per usare il nome del template" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="REPARTO" />
                            <ComboBox
                                x:Name="cmbDepartment"
                                Height="32"
                                Padding="8,5"
                                BorderBrush="#E4E7EC"
                                FontSize="13"
                                SelectionChanged="CmbDepartment_SelectionChanged" />

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="ORE BUDGET" />
                                    <TextBox
                                        x:Name="txtBudgetHours"
                                        Style="{StaticResource FieldInput}"
                                        Text="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="COSTO BUDGET (€)" />
                                    <TextBox
                                        x:Name="txtBudgetCost"
                                        Style="{StaticResource FieldInput}"
                                        Text="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="AVANZAMENTO %" />
                                    <TextBox
                                        x:Name="txtProgress"
                                        Style="{StaticResource FieldInput}"
                                        Text="0" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="STATO" />
                                    <ComboBox
                                        x:Name="cmbStatus"
                                        Height="32"
                                        Padding="8,5"
                                        BorderBrush="#E4E7EC"
                                        FontSize="13">
                                        <ComboBoxItem Content="NOT_STARTED" IsSelected="True" />
                                        <ComboBoxItem Content="IN_PROGRESS" />
                                        <ComboBoxItem Content="COMPLETED" />
                                        <ComboBoxItem Content="ON_HOLD" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="ORDINAMENTO" />
                                    <TextBox
                                        x:Name="txtSortOrder"
                                        Style="{StaticResource FieldInput}"
                                        Text="0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!--  TECNICI ASSEGNATI  -->
                <Expander Margin="0,0,0,8" IsExpanded="True">
                    <Expander.Header>
                        <Border Padding="0,6" Background="Transparent">
                            <TextBlock Style="{StaticResource ExpHeader}" Text="👷  TECNICI ASSEGNATI" />
                        </Border>
                    </Expander.Header>
                    <Border
                        Margin="0,0,0,8"
                        Padding="16,8,16,12"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    x:Name="cmbEmployee"
                                    Grid.Column="0"
                                    Height="32"
                                    Padding="8,5"
                                    BorderBrush="#E4E7EC"
                                    DisplayMemberPath="Name"
                                    FontSize="13" />
                                <ComboBox
                                    x:Name="cmbAssignRole"
                                    Grid.Column="2"
                                    Height="32"
                                    Padding="8,5"
                                    BorderBrush="#E4E7EC"
                                    FontSize="13">
                                    <ComboBoxItem Content="MEMBER" IsSelected="True" />
                                    <ComboBoxItem Content="LEAD" />
                                </ComboBox>
                                <TextBox
                                    x:Name="txtPlannedHours"
                                    Grid.Column="4"
                                    Height="32"
                                    Padding="8,5"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="1"
                                    FontSize="13"
                                    Text="0"
                                    ToolTip="Ore pianificate" />
                                <Button
                                    Grid.Column="6"
                                    Height="32"
                                    Padding="12,0"
                                    Background="#4F6EF7"
                                    BorderThickness="0"
                                    Click="BtnAddAssignment_Click"
                                    Content="+ Aggiungi"
                                    Cursor="Hand"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="White" />
                            </Grid>

                            <DataGrid
                                x:Name="dgAssignments"
                                MaxHeight="200"
                                AutoGenerateColumns="False"
                                Background="White"
                                BorderBrush="#E4E7EC"
                                BorderThickness="1"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                HorizontalGridLinesBrush="#F3F4F6"
                                IsReadOnly="True"
                                RowHeight="36"
                                SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding EmployeeName}"
                                        Header="Tecnico" />
                                    <DataGridTextColumn
                                        Width="80"
                                        Binding="{Binding AssignRole}"
                                        Header="Ruolo" />
                                    <DataGridTextColumn
                                        Width="80"
                                        Binding="{Binding PlannedHours}"
                                        Header="Ore pian." />
                                    <DataGridTemplateColumn Width="60" Header="">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="BtnRemoveAssignment_Click"
                                                    Content="✕"
                                                    Cursor="Hand"
                                                    FontSize="12"
                                                    Foreground="#EF4444"
                                                    Tag="{Binding}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
