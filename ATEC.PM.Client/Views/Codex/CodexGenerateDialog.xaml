<Window
    x:Class="ATEC.PM.Client.Views.CodexGenerateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Genera Nuovo Codice Codex"
    Width="500"
    Height="280"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="SingleBorderWindow">
    <DockPanel>
        <!--  HEADER  -->
        <Border
            Padding="20,15"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="#1A1D26"
                Text="Genera un nuovo articolo Codex" />
        </Border>

        <!--  FOOTER  -->
        <Border
            Padding="20,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    x:Name="btnCancel"
                    Padding="16,8"
                    Background="Transparent"
                    BorderBrush="#D0D5DD"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Foreground="#344054"
                    Style="{StaticResource FlatBtn}" />
                <Button
                    x:Name="btnSave"
                    Margin="12,0,0,0"
                    Padding="16,8"
                    Background="#12B76A"
                    Click="BtnSave_Click"
                    Content="Genera"
                    Foreground="White"
                    Style="{StaticResource FlatBtn}" />
            </StackPanel>
        </Border>

        <!--  CONTENT  -->
        <StackPanel Margin="20" DockPanel.Dock="Top">
            <!--  PREFISSO  -->
            <TextBlock
                Margin="0,0,0,6"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#667085"
                Text="Prefisso *" />
            <ComboBox
                x:Name="cmbPrefisso"
                Height="40"
                Padding="12,8"
                Background="White"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                FontSize="12"
                Foreground="#1A1D26" />

            <!--  DESCRIZIONE  -->
            <TextBlock
                Margin="0,16,0,6"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#667085"
                Text="Descrizione *" />
            <TextBox
                x:Name="txtDescrizione"
                Height="60"
                Padding="12,8"
                Background="White"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                FontSize="12"
                Foreground="#1A1D26"
                TextWrapping="Wrap"
                VerticalAlignment="Top" />

            <!--  ERRORE  -->
            <TextBlock
                x:Name="txtError"
                Margin="0,12,0,0"
                FontSize="11"
                Foreground="#F04438"
                Text="" />
        </StackPanel>
    </DockPanel>
</Window>
