<Page
    x:Class="ATEC.PM.Client.Views.CodexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="800"
    Background="#F7F8FA">
    <DockPanel>
        <!--  TOOLBAR  -->
        <Border
            Padding="20,15"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="btnGenerate"
                        Background="#4F6EF7"
                        Click="BtnGenerate_Click"
                        Content="✚ Genera Codice"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />

                    <Separator
                        Width="1"
                        Margin="5,0"
                        Background="#E4E7EC" />

                    <Button
                        x:Name="btnSync"
                        Background="#12B76A"
                        Click="BtnSync_Click"
                        Content="⟳ Sincronizza"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />

                    <Separator
                        Width="1"
                        Margin="5,0"
                        Background="#E4E7EC" />

                    <Button
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnClearFilters_Click"
                        Content="Pulisci Filtri"
                        Foreground="#667085"
                        Style="{StaticResource FlatBtn}" />

                    <Button
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock
                        x:Name="txtSyncStatus"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#667085"
                        Text="" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  GENERA CODICE INLINE PANEL  -->
        <Border
            x:Name="pnlGenerate"
            Padding="20,12"
            Background="#F0F4FF"
            BorderBrush="#4F6EF7"
            BorderThickness="0,0,0,2"
            DockPanel.Dock="Top"
            Visibility="Collapsed">
            <StackPanel>
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#1A1D26"
                        Text="Genera un nuovo articolo Codex" />
                    <Button
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnGenerateCancel_Click"
                        Content="✕"
                        FontSize="14"
                        Foreground="#667085"
                        Style="{StaticResource FlatBtn}" />
                </Grid>
                <!--  RIGA 1: Prefisso + Descrizione (due colonne uguali)  -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#667085"
                            Text="Prefisso" />
                        <ComboBox
                            x:Name="cmbPrefisso"
                            Height="34"
                            Margin="0,4,0,0"
                            Padding="10,6"
                            Background="White"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="#1A1D26"
                            SelectionChanged="CmbPrefisso_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#667085"
                            Text="Descrizione" />
                        <TextBox
                            x:Name="txtDescrizione"
                            Height="34"
                            Margin="0,4,0,0"
                            Padding="10,6"
                            VerticalContentAlignment="Center"
                            Background="White"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="#1A1D26" />
                    </StackPanel>
                </Grid>

                <!--  RIGA 2: Riferimenti 201/401 (solo per 101, due colonne uguali)  -->
                <Grid
                    x:Name="pnlReferences"
                    Margin="0,10,0,0"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="pnlRef201" Grid.Column="0">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#667085"
                            Text="Rif. Commerciale (201) — opzionale, digitare per cercare" />
                        <ComboBox
                            x:Name="cmbRef201"
                            Height="34"
                            Margin="0,4,0,0"
                            Padding="10,6"
                            Background="White"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            DisplayMemberPath="Display"
                            FontSize="12"
                            Foreground="#1A1D26"
                            IsEditable="True"
                            IsTextSearchEnabled="False" />
                    </StackPanel>
                    <StackPanel x:Name="pnlRef401" Grid.Column="2">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#667085"
                            Text="Rif. Materia Prima (401) — opzionale, digitare per cercare" />
                        <ComboBox
                            x:Name="cmbRef401"
                            Height="34"
                            Margin="0,4,0,0"
                            Padding="10,6"
                            Background="White"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            DisplayMemberPath="Display"
                            FontSize="12"
                            Foreground="#1A1D26"
                            IsEditable="True"
                            IsTextSearchEnabled="False" />
                    </StackPanel>
                </Grid>

                <!--  RIGA 3: Codice generato (centrato)  -->
                <Border
                    x:Name="brdPreview"
                    Margin="0,10,0,0"
                    Padding="16,6"
                    HorizontalAlignment="Center"
                    Background="White"
                    BorderBrush="#4F6EF7"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#667085"
                            Text="Codice assegnato: " />
                        <TextBlock
                            x:Name="txtPreviewCode"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#4F6EF7" />
                    </StackPanel>
                </Border>

                <!--  RIGA 4: Bottoni (centrati)  -->
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnGenerateConfirm"
                        Margin="0,0,8,0"
                        Padding="20,8"
                        Background="#12B76A"
                        Click="BtnGenerateConfirm_Click"
                        Content="Genera"
                        Foreground="White"
                        IsEnabled="False"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Padding="20,8"
                        Background="Transparent"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1"
                        Click="BtnGenerateCancel_Click"
                        Content="Annulla"
                        Foreground="#344054"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
                <!--  ERRORE  -->
                <TextBlock
                    x:Name="txtGenerateError"
                    Margin="0,6,0,0"
                    FontSize="11"
                    Foreground="#F04438" />
            </StackPanel>
        </Border>

        <!--  MODIFICA INLINE PANEL  -->
        <Border
            x:Name="pnlEdit"
            Padding="20,12"
            Background="#FFFBEB"
            BorderBrush="#F59E0B"
            BorderThickness="0,0,0,2"
            DockPanel.Dock="Top"
            Visibility="Collapsed">
            <StackPanel>
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#1A1D26"
                        Text="Modifica articolo" />
                    <Button
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnCancelEdit_Click"
                        Content="✕"
                        FontSize="14"
                        Foreground="#667085"
                        Style="{StaticResource FlatBtn}" />
                </Grid>
                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                    <!--  CODICE (readonly)  -->
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#667085"
                            Text="Codice" />
                        <TextBlock
                            x:Name="txtEditCode"
                            Margin="0,6,0,0"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="#4F6EF7" />
                    </StackPanel>
                    <!--  DESCRIZIONE  -->
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#667085"
                            Text="Descrizione" />
                        <TextBox
                            x:Name="txtEditDescr"
                            Width="500"
                            Height="34"
                            Margin="0,4,0,0"
                            Padding="10,6"
                            VerticalContentAlignment="Center"
                            Background="White"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="#1A1D26" />
                    </StackPanel>
                    <!--  BUTTONS  -->
                    <Button
                        x:Name="btnSaveEdit"
                        Margin="0,0,8,0"
                        Padding="16,8"
                        VerticalAlignment="Bottom"
                        Background="#4F6EF7"
                        Click="BtnSaveEdit_Click"
                        Content="Salva"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Padding="16,8"
                        VerticalAlignment="Bottom"
                        Background="Transparent"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1"
                        Click="BtnCancelEdit_Click"
                        Content="Annulla"
                        Foreground="#344054"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
                <!--  ERRORE  -->
                <TextBlock
                    x:Name="txtEditError"
                    Margin="0,6,0,0"
                    FontSize="11"
                    Foreground="#F04438" />
            </StackPanel>
        </Border>

        <!--  COLUMN VISIBILITY PANEL  -->
        <Border
            Padding="20,8"
            Background="#F9FAFB"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#667085"
                    Text="Colonne:" />
                <ToggleButton x:Name="btnColumnToggle" Style="{StaticResource ColumnSelectorToggle}" />
                <Popup
                    x:Name="popColumns"
                    AllowsTransparency="True"
                    IsOpen="{Binding IsChecked, ElementName=btnColumnToggle}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=btnColumnToggle}"
                    StaysOpen="False">
                    <Border
                        x:Name="popBorder"
                        RenderTransformOrigin="0.5,0"
                        Style="{StaticResource ColumnSelectorPopup}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="popTranslate" Y="-8" />
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="popBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            From="0"
                                            To="1"
                                            Duration="0:0:1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="popTranslate"
                                            Storyboard.TargetProperty="Y"
                                            From="-8"
                                            To="0"
                                            Duration="0:0:1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <StackPanel x:Name="wpColumns" />
                    </Border>
                </Popup>
            </StackPanel>
        </Border>

        <!--  STATUS BAR  -->
        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <Grid>
                <TextBlock
                    x:Name="txtStatus"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Foreground="#667085"
                    Text="Pronto" />
                <TextBlock
                    HorizontalAlignment="Right"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="#9CA3AF"
                    Text="Filtri: abc = contiene  |  abc* = inizia con  |  *abc = finisce con" />
            </Grid>
        </Border>

        <!--  DATAGRID  -->
        <DataGrid
            x:Name="dgCodex"
            Margin="20"
            IsReadOnly="True"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="6,4" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>

                <DataGridTemplateColumn
                    x:Name="colCodice"
                    Width="110"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Codice" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Codice"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Medium"
                                Text="{Binding Codice}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colDescr"
                    Width="*"
                    MinWidth="180">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Descrizione" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Descr"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Descr}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colCodeForn"
                    Width="140"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Cod. Forn." />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="CodeForn"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding CodeForn}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colFornitore"
                    Width="140"
                    MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Fornitore" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Fornitore"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Fornitore}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colPrezzoForn"
                    Width="90"
                    MinWidth="70">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Prezzo €" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="PrezzoForn"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{Binding PrezzoForn, StringFormat=N2}"
                                TextAlignment="Right" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colIva"
                    Width="60"
                    MinWidth="40">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="IVA" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Iva"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Iva}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colProduttore"
                    Width="140"
                    MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Produttore" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Produttore"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Produttore}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colData"
                    Width="90"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Data" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Data"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Data, StringFormat=dd/MM/yyyy}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colCategoria"
                    Width="140"
                    MinWidth="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Categoria" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Categoria"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Categoria}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colBarcode"
                    Width="130"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Barcode" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Barcode"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Barcode}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colTipologia"
                    Width="130"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Tipologia" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Tipologia"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Tipologia}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colExtra1"
                    Width="120"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Extra1" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Extra1"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Extra1}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colExtra2"
                    Width="120"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Extra2" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Extra2"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Extra2}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colExtra3"
                    Width="120"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Extra3" />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="Extra3"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Extra3}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    x:Name="colCodeProd"
                    Width="130"
                    MinWidth="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="#667085"
                                    Text="Cod. Prod." />
                                <TextBox
                                    Loaded="Filter_Loaded"
                                    Style="{StaticResource HeaderSearchBox}"
                                    Tag="CodeProd"
                                    TextChanged="Filter_Changed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding CodeProd}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

