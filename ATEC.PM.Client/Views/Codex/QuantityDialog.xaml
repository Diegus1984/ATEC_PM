<Window
    x:Class="ATEC.PM.Client.Views.QuantityDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Quantità"
    Width="320"
    Height="300"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>

        <!--  HEADER  -->
        <Border
            Padding="20,14"
            Background="#1A1D26"
            DockPanel.Dock="Top">
            <TextBlock
                FontSize="15"
                FontWeight="Bold"
                Foreground="White"
                Text="Inserisci quantità" />
        </Border>

        <!--  BUTTONS  -->
        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="90"
                    Height="32"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand"
                    FontSize="13" />
                <Button
                    Width="90"
                    Height="32"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnOk_Click"
                    Content="OK"
                    Cursor="Hand"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </StackPanel>
        </Border>

        <!--  FORM  -->
        <StackPanel Margin="20,16">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="QUANTITÀ *" />
            <TextBox
                x:Name="txtQuantity"
                Height="32"
                Margin="0,4,0,0"
                Padding="8,4"
                BorderBrush="#E4E7EC"
                FontSize="13"
                Text="1" />
        </StackPanel>

    </DockPanel>
</Window>
