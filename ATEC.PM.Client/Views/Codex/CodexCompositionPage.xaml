<Page
    x:Class="ATEC.PM.Client.Views.CodexCompositionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <Page.Resources>
        <!--  Stile per nodi TreeView  -->
        <Style x:Key="TreeNodeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <DockPanel>

        <!--  ═══ TOOLBAR ═══  -->
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal">

                <!--  Tipo  -->
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="#667085"
                    Text="Tipo:" />
                <ComboBox
                    x:Name="cmbType"
                    Width="220"
                    Height="32"
                    Padding="8,4"
                    FontSize="13"
                    DisplayMemberPath="Display"
                    SelectionChanged="CmbType_SelectionChanged" />

                <!--  Articolo  -->
                <TextBlock
                    Margin="20,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="#667085"
                    Text="Articolo:" />
                <ComboBox
                    x:Name="cmbParent"
                    Width="320"
                    Height="32"
                    Padding="8,4"
                    FontSize="13"
                    IsEditable="True"
                    DisplayMemberPath="Display"
                    SelectionChanged="CmbParent_SelectionChanged" />

                <!--  Refresh  -->
                <Button
                    Width="32"
                    Height="32"
                    Margin="12,0,0,0"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnRefresh_Click"
                    Content="⟳"
                    Cursor="Hand"
                    FontSize="14"
                    ToolTip="Aggiorna" />
            </StackPanel>
        </Border>

        <!--  ═══ STATUS BAR ═══  -->
        <Border
            Padding="16,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <Grid>
                <TextBlock
                    x:Name="txtStatus"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Foreground="#6B7280"
                    Text="Seleziona un tipo e un articolo" />
                <TextBlock
                    HorizontalAlignment="Right"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="#9CA3AF"
                    Text="Filtri: abc = contiene  |  abc* = inizia con  |  *abc = finisce con    —    Trascina da sinistra nell'albero a destra" />
            </Grid>
        </Border>

        <!--  ═══ CONTENUTO PRINCIPALE (split)  ═══  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!--  ── SINISTRA: Articoli disponibili ──  -->
            <DockPanel Grid.Column="0">

                <!--  Header + Search  -->
                <Border
                    Padding="12,8"
                    Background="#F0F4FF"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#4F6EF7"
                                Text="ARTICOLI DISPONIBILI"
                                VerticalAlignment="Center" />
                            <ComboBox
                                x:Name="cmbSource"
                                Width="120"
                                Height="26"
                                Margin="12,0,0,0"
                                Padding="6,2"
                                FontSize="12"
                                HorizontalAlignment="Left"
                                SelectionChanged="CmbSource_SelectionChanged">
                                <ComboBoxItem Content="Codex" IsSelected="True" />
                                <ComboBoxItem Content="Catalogo" />
                            </ComboBox>
                        </DockPanel>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="txtSearchCodice"
                                Grid.Column="0"
                                Height="28"
                                Padding="6,3"
                                BorderBrush="#D0D5DD"
                                FontSize="12"
                                Tag="Codice"
                                TextChanged="TxtSearch_TextChanged" />
                            <TextBox
                                x:Name="txtSearchDescr"
                                Grid.Column="2"
                                Height="28"
                                Padding="6,3"
                                BorderBrush="#D0D5DD"
                                FontSize="12"
                                Tag="Descrizione"
                                TextChanged="TxtSearch_TextChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  DataGrid articoli  -->
                <DataGrid
                    x:Name="dgAvailable"
                    AutoGenerateColumns="False"
                    Background="White"
                    MouseDoubleClick="DgAvailable_MouseDoubleClick"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#F2F4F7"
                    IsReadOnly="True"
                    PreviewMouseLeftButtonDown="DgAvailable_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="DgAvailable_PreviewMouseMove"
                    RowHeight="32"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding Codice}"
                            FontSize="12"
                            Header="Codice" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Descr}"
                            FontSize="12"
                            Header="Descrizione" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!--  SPLITTER  -->
            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Background="#E4E7EC" />

            <!--  ── DESTRA: Composizione (TreeView) ──  -->
            <DockPanel Grid.Column="2">

                <!--  Header  -->
                <Border
                    Padding="12,8"
                    Background="#F0FFF4"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <TextBlock
                        x:Name="txtTreeHeader"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#12B76A"
                        Text="COMPOSIZIONE" />
                </Border>

                <!--  TreeView  -->
                <TreeView
                    x:Name="tvComposition"
                    Background="White"
                    BorderThickness="0"
                    AllowDrop="True"
                    DragOver="TvComposition_DragOver"
                    Drop="TvComposition_Drop"
                    FontSize="13"
                    Padding="8">

                    <TreeView.Resources>
                        <!--  Highlight per drop target  -->
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="IsExpanded" Value="True" />
                        </Style>
                    </TreeView.Resources>

                </TreeView>
            </DockPanel>

        </Grid>

    </DockPanel>
</Page>
