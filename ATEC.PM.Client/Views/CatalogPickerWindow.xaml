<Window x:Class="ATEC.PM.Client.Views.CatalogPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleziona Articolo dal Catalogo" 
        Width="1100" Height="650"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA">

    <DockPanel Margin="16">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Doppio click per aggiungere alla DDP (Qtà = 1)"
                   FontSize="13" Foreground="Gray" Margin="0,0,0,12"/>

        <!-- Filtri -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E7EC" 
                BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Tag="Code" Loaded="Filter_Loaded" TextChanged="Filter_Changed"
                         ToolTip="Filtra per codice" FontSize="13"/>
                <TextBox Grid.Column="2" Tag="Desc" Loaded="Filter_Loaded" TextChanged="Filter_Changed"
                         ToolTip="Filtra per descrizione" FontSize="13"/>
                <TextBox Grid.Column="4" Tag="Supp" Loaded="Filter_Loaded" TextChanged="Filter_Changed"
                         ToolTip="Filtra per fornitore" FontSize="13"/>
                <TextBox Grid.Column="6" Tag="Man" Loaded="Filter_Loaded" TextChanged="Filter_Changed"
                         ToolTip="Filtra per produttore" FontSize="13"/>
                <Button Grid.Column="8" Content="✕" Width="32" Height="28" 
                        Click="BtnClearFilters_Click" ToolTip="Pulisci filtri"
                        Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Intestazioni filtri -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CODICE" FontSize="10" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBlock Grid.Column="2" Text="DESCRIZIONE" FontSize="10" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBlock Grid.Column="4" Text="FORNITORE" FontSize="10" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBlock Grid.Column="6" Text="PRODUTTORE" FontSize="10" FontWeight="SemiBold" Foreground="Gray"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" FontSize="12" Foreground="Gray"/>
                <TextBlock Grid.Column="1" x:Name="txtAdded" FontSize="12" Foreground="#4F6EF7" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="dgCatalog" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="White" BorderBrush="#E4E7EC" BorderThickness="1"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                  RowHeight="32" ColumnHeaderHeight="34" FontSize="13"
                  SelectionMode="Single" CanUserSortColumns="True"
                  MouseDoubleClick="Dg_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Codice" Binding="{Binding Code}" Width="120"/>
                <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="UM" Binding="{Binding Unit}" Width="50"/>
                <DataGridTextColumn Header="Fornitore" Binding="{Binding SupplierName}" Width="160"/>
                <DataGridTextColumn Header="Produttore" Binding="{Binding Manufacturer}" Width="140"/>
                <DataGridTextColumn Header="Costo" Binding="{Binding UnitCost, StringFormat=N2}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>