<UserControl
    x:Class="ATEC.PM.Client.UserControls.ProjectDashboardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:oxy="http://oxyplot.org/wpf"
    Background="#F7F8FA">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1A1D26" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <DataTemplate x:Key="KpiTemplate">
            <Border Margin="0,0,8,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="{Binding Label}" />
                    <TextBlock
                        Margin="0,4,0,2"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{Binding AccentColor}"
                        Text="{Binding Value}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="#9CA3AF"
                        Text="{Binding Subtitle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TechnicianRowTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{Binding EmployeeName}" />
                <Border
                    Grid.Column="1"
                    Padding="8,2"
                    HorizontalAlignment="Left"
                    Background="{Binding DeptBrush}">
                    <TextBlock
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding DepartmentCode}" />
                </Border>
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="{Binding PhaseCount}" />
                <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="{Binding TotalHours, StringFormat={}{0:N1} h}"
                    TextAlignment="Right" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TimesheetRowTemplate">
            <Border
                Padding="0,6"
                BorderBrush="#F3F4F6"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Foreground="#6B7280"
                        Text="{Binding WorkDate, StringFormat=dd/MM}" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{Binding EmployeeName}" />
                    <StackPanel
                        Grid.Column="2"
                        Margin="8,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="11"
                            FontWeight="Medium"
                            Text="{Binding PhaseName}" />
                        <TextBlock
                            FontSize="10"
                            Foreground="#9CA3AF"
                            Text="{Binding Notes}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Text="{Binding Hours, StringFormat={}{0:N1}}"
                        TextAlignment="Right" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DeadlineRowTemplate">
            <Border
                Padding="0,6"
                BorderBrush="#F3F4F6"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="55" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="{Binding Icon}" />
                    <Border
                        Grid.Column="1"
                        Padding="6,2"
                        HorizontalAlignment="Left"
                        Background="{Binding DeptBrush}">
                        <TextBlock
                            FontSize="9"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding DepartmentCode}" />
                    </Border>
                    <TextBlock
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Text="{Binding PhaseName}" />
                    <TextBlock
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="#6B7280"
                        Text="{Binding DeadlineText}" />
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{Binding UrgencyBrush}"
                        Text="{Binding RemainingText}"
                        TextAlignment="Right" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DeptBarTemplate">
            <StackPanel Margin="0,6">
                <DockPanel>
                    <Border
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Background="{Binding DeptBrush}">
                        <TextBlock
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding DepartmentCode}" />
                    </Border>
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#374151"
                        Text="{Binding Summary}" />
                </DockPanel>
                <Grid Height="8" Margin="0,4,0,0">
                    <Border Background="#F3F4F6" />
                    <Border
                        Width="{Binding BudgetBarWidth}"
                        HorizontalAlignment="Left"
                        Background="{Binding BudgetBarBrush}" />
                    <Border
                        Width="{Binding AssignedBarWidth}"
                        HorizontalAlignment="Left"
                        Background="{Binding AssignedBarBrush}" />
                    <Border
                        Width="{Binding WorkedBarWidth}"
                        HorizontalAlignment="Left"
                        Background="{Binding DeptBrush}" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer Padding="16,0,16,0" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="pnlContent" Margin="0,0,0,20" />
    </ScrollViewer>
</UserControl>
