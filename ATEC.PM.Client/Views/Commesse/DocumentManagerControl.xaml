<UserControl
    x:Class="ATEC.PM.Client.UserControls.DocumentManagerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowDrop="True"
    Background="#F7F8FA"
    DragOver="OnDragOver"
    Drop="OnDrop">

    <DockPanel>
        <!--  TOOLBAR  -->
        <Border
            Padding="12,8"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <!--  Breadcrumb  -->
                <StackPanel
                    x:Name="pnlBreadcrumb"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    Orientation="Horizontal" />

                <!--  Azioni  -->
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Height="30"
                        Margin="0,0,4,0"
                        Padding="10,0"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnNewFolder_Click"
                        Content="📁 Nuova Cartella"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#374151" />
                    <Button
                        Height="30"
                        Margin="0,0,4,0"
                        Padding="10,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnUpload_Click"
                        Content="📤 Carica File"
                        Cursor="Hand"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="White" />
                    <Button
                        Height="30"
                        Padding="10,0"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnOpenExplorer_Click"
                        Content="📂 Apri in Explorer"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#374151" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  DROP ZONE OVERLAY  -->
        <Border
            x:Name="brdDropZone"
            Padding="0,20"
            Background="#4F6EF720"
            BorderBrush="#4F6EF7"
            BorderThickness="2"
            DockPanel.Dock="Top"
            Visibility="Collapsed">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="#4F6EF7"
                Text="Rilascia i file qui per caricarli" />
        </Border>

        <!--  STATUS  -->
        <Border
            Padding="12,6"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtStatus"
                FontSize="11"
                Foreground="#6B7280" />
        </Border>

        <!--  FILE LIST  -->
        <DataGrid
            x:Name="dgFiles"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            ColumnHeaderHeight="36"
            FontSize="13"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="True"
            MouseDoubleClick="DgFiles_DoubleClick"
            RowHeight="36"
            SelectionMode="Single">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F9FAFB" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="BorderBrush" Value="#E4E7EC" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F9FAFB" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EEF2FF" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Click="CtxDownload_Click" Header="Scarica" />
                    <MenuItem Click="CtxRename_Click" Header="Rinomina" />
                    <MenuItem Click="CtxMove_Click" Header="Sposta..." />
                    <Separator />
                    <MenuItem
                        Click="CtxDelete_Click"
                        Foreground="#EF4444"
                        Header="Elimina" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="40"
                    Binding="{Binding TypeIcon}"
                    Header="" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Nome" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding SizeDisplay}"
                    Header="Dimensione" />
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding ModifiedDisplay}"
                    Header="Modificato" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
