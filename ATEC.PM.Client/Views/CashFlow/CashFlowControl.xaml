<UserControl
    x:Class="ATEC.PM.Client.Views.CashFlow.CashFlowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ATEC.PM.Client.Views.CashFlow"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    Background="#F7F8FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:NegativeToBrushConverter x:Key="NegToBrush" />
        <local:RowTypeToBgConverter x:Key="RowTypeToBg" />
        <local:CellForegroundConverter x:Key="CellForegroundConverter" />
        <local:SeparatorValueConverter x:Key="SepValueConv" />
        <local:IntegerAmountConverter x:Key="IntAmount" />
        <local:InvertBoolConverter x:Key="InvertBool" />
    </UserControl.Resources>

    <Grid>
        <TextBlock
            x:Name="txtLoading"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="#9CA3AF"
            Text="Caricamento..." />

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding ShowInit, Converter={StaticResource BoolToVis}}">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="16"
                Foreground="#6B7280"
                Text="Flusso di cassa non ancora configurato." />
            <Button
                Width="220"
                Height="36"
                Margin="0,16,0,0"
                Background="#4F6EF7"
                BorderThickness="0"
                Click="BtnInit_Click"
                Content="Inizializza Flusso Cassa"
                Cursor="Hand"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="White" />
        </StackPanel>

        <Grid Visibility="{Binding ShowContent, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="0.5*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="16,10"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="IMPONIBILE" />
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#1A1D26">
                            <Run Text="{Binding ProjectRevenue, StringFormat=N0, Mode=OneWay}" /><Run Text=" €" /></TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="PAGAMENTO CLIENTE" />
                        <TextBox
                            Width="150"
                            Padding="0,2"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderBrush="#E4E7EC"
                            BorderThickness="0,0,0,2"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#4F6EF7"
                            KeyDown="PaymentAmount_KeyDown"
                            LostFocus="PaymentAmount_LostFocus"
                            Text="{Binding PaymentAmount, Converter={StaticResource IntAmount}, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="MESI" />
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="{Binding MonthCount}" />
                    </StackPanel>

                    <StackPanel Grid.Column="6" Orientation="Horizontal">
                        <Button
                            Height="26"
                            Margin="0,0,8,0"
                            Padding="10,0"
                            Background="#DC262620"
                            BorderThickness="0"
                            Click="BtnAddCategory_Click"
                            Content="+ Categoria"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#DC2626" />
                        <Button
                            Height="26"
                            Padding="10,0"
                            Background="#05966920"
                            BorderThickness="0"
                            Click="BtnRemoveCategory_Click"
                            Content="- Categoria"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#059669" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Padding="12,6"
                Background="#F9FAFB"
                BorderBrush="#E4E7EC"
                BorderThickness="0,0,0,1">
                <TextBlock
                    FontSize="12"
                    Foreground="#6B7280"
                    Text="{Binding StatusText}" />
            </Border>

            <DataGrid
                x:Name="dgMain"
                Grid.Row="2"
                AutoGenerateColumns="False"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                ColumnHeaderHeight="50"
                FontSize="12"
                FrozenColumnCount="2"
                GridLinesVisibility="All"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#E4E7EC"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding Rows}"
                RowHeight="25"
                SelectionMode="Single"
                SelectionUnit="Cell"
                VerticalGridLinesBrush="#E4E7EC"
                VerticalScrollBarVisibility="Auto">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A1D26" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="10" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="BorderBrush" Value="#374151" />
                        <Setter Property="BorderThickness" Value="0,0,1,0" />
                        <Setter Property="MinHeight" Value="45" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="160"
                        Binding="{Binding Label}"
                        Header=""
                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#1A1D26" />
                                <Setter Property="Padding" Value="6,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Background" Value="#F9FAFB" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="100" Header="IMPORTO">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="4,0" Background="#F9FAFB">
                                    <TextBox
                                        Padding="0"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="#F9FAFB"
                                        BorderThickness="0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#1A1D26"
                                        IsReadOnly="{Binding IsAmountEditable, Converter={StaticResource InvertBool}}"
                                        KeyDown="AmountTextBox_KeyDown"
                                        LostFocus="AmountTextBox_LostFocus"
                                        Text="{Binding TotalAmount, StringFormat=N0, UpdateSourceTrigger=LostFocus}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border
                Grid.Row="3"
                Padding="16,8"
                Background="#1A1D26">
                <TextBlock
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="{Binding StatusText}" />
            </Border>

            <Border
                Grid.Row="4"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="0,1,0,0">
                <lvc:CartesianChart
                    x:Name="chartContainer"
                    LegendPosition="Bottom"
                    Series="{Binding Series}"
                    TooltipPosition="Top"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
