<Window
    x:Class="ATEC.PM.Client.UserControls.CostMaterialItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi Voce Materiale"
    Width="420"
    Height="280"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border Padding="16,12" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock x:Name="txtError" VerticalAlignment="Center" FontSize="12" Foreground="#EF4444" />
                <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="90" Height="34" Background="#F3F4F6" BorderThickness="0" Click="BtnCancel_Click" Content="Annulla" Cursor="Hand" Foreground="#374151" />
                    <Button Width="90" Height="34" Margin="8,0,0,0" Background="#4F6EF7" BorderThickness="0" Click="BtnSave_Click" Content="Salva" Cursor="Hand" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>
        <StackPanel Margin="24,16,24,8">
            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="DESCRIZIONE *" />
            <TextBox x:Name="txtDescription" Height="32" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="QUANTITÀ" />
                    <TextBox x:Name="txtQuantity" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="1" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="COSTO UNITARIO €" />
                    <TextBox x:Name="txtUnitCost" Height="32" Margin="0,4,0,0" Padding="8,5" BorderBrush="#E4E7EC" FontSize="13" Text="0" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
