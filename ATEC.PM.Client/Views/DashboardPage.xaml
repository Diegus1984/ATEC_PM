<Page
    x:Class="ATEC.PM.Client.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ATEC.PM.Client.Views"
    Background="#F7F8FA">

    <Page.Resources>
        <local:SeverityIconConverter x:Key="SeverityIconConverter" />
        <local:NotifTypeConverter x:Key="NotifTypeConverter" />
        <local:ReadCheckConverter x:Key="ReadCheckConverter" />
    </Page.Resources>

    <ScrollViewer Padding="0,0,0,16">
        <StackPanel>
            <!--  STAT CARDS  -->
            <UniformGrid Margin="0,0,0,24" Columns="4">
                <Border Margin="0,0,12,0" Padding="20" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Text="COMMESSE ATTIVE" />
                        <TextBlock x:Name="txtActiveProjects" Margin="0,4,0,0" FontSize="28" FontWeight="Bold" Foreground="#1A1D26" Text="-" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" Padding="20" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Text="ORE QUESTA SETTIMANA" />
                        <TextBlock x:Name="txtHoursWeek" Margin="0,4,0,0" FontSize="28" FontWeight="Bold" Foreground="#4F6EF7" Text="-" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" Padding="20" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Text="ORE QUESTO MESE" />
                        <TextBlock x:Name="txtHoursMonth" Margin="0,4,0,0" FontSize="28" FontWeight="Bold" Foreground="#1A1D26" Text="-" />
                    </StackPanel>
                </Border>
                <Border Padding="20" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Text="RICAVO TOTALE" />
                        <TextBlock x:Name="txtRevenue" Margin="0,4,0,0" FontSize="28" FontWeight="Bold" Foreground="#10B981" Text="-" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!--  NOTIFICATIONS HEADER  -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#1A1D26"
                    Text="Notifiche"
                    DockPanel.Dock="Left" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button
                        x:Name="btnMarkAllRead"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnMarkAllRead_Click"
                        Content="Segna tutte lette"
                        Foreground="#667085"
                        Style="{StaticResource FlatBtn}" />
                    <CheckBox
                        x:Name="chkUnreadOnly"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Checked="ChkUnreadOnly_Changed"
                        Content="Solo non lette"
                        FontSize="12"
                        Foreground="#667085"
                        Unchecked="ChkUnreadOnly_Changed" />
                </StackPanel>
            </DockPanel>

            <!--  ALARM LIST  -->
            <DataGrid
                x:Name="dgNotifications"
                MinHeight="200"
                MaxHeight="400"
                AutoGenerateColumns="False"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                CanUserAddRows="False"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="#F3F4F6"
                IsReadOnly="True"
                MouseDoubleClick="DgNotifications_DoubleClick"
                RowHeight="36"
                SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F9FAFB" />
                        <Setter Property="Foreground" Value="#6B7280" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="BorderBrush" Value="#E4E7EC" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <!--  ICONA SEVERITA  -->
                    <DataGridTemplateColumn Width="40" Header="" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Text="{Binding Severity, Converter={StaticResource SeverityIconConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  TIMESTAMP  -->
                    <DataGridTemplateColumn Width="110" Header="Data/Ora" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding CreatedAt, StringFormat=dd/MM HH:mm}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  COMMESSA  -->
                    <DataGridTemplateColumn Width="100" Header="Commessa" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" FontWeight="Medium" Text="{Binding ProjectCode}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  TIPO  -->
                    <DataGridTemplateColumn Width="80" Header="Tipo" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding NotificationType, Converter={StaticResource NotifTypeConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  TITOLO  -->
                    <DataGridTemplateColumn Width="200" Header="Titolo" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  MESSAGGIO  -->
                    <DataGridTemplateColumn Width="*" Header="Messaggio" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Message}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  LETTO  -->
                    <DataGridTemplateColumn Width="40" Header="✓" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="#12B76A"
                                    Text="{Binding IsRead, Converter={StaticResource ReadCheckConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!--  RECENT PROJECTS  -->
            <TextBlock
                Margin="0,24,0,12"
                FontSize="16"
                FontWeight="Bold"
                Foreground="#1A1D26"
                Text="Commesse Recenti" />
            <DataGrid
                x:Name="dgRecent"
                AutoGenerateColumns="False"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                ColumnHeaderHeight="38"
                FontSize="13"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="#F3F4F6"
                IsReadOnly="True"
                RowHeight="38">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F9FAFB" />
                        <Setter Property="Foreground" Value="#6B7280" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="12,0" />
                        <Setter Property="BorderBrush" Value="#E4E7EC" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="100" Binding="{Binding Code}" Header="Codice" />
                    <DataGridTextColumn Width="*" Binding="{Binding Title}" Header="Titolo" />
                    <DataGridTextColumn Width="160" Binding="{Binding CustomerName}" Header="Cliente" />
                    <DataGridTextColumn Width="90" Binding="{Binding Status}" Header="Stato" />
                    <DataGridTextColumn Width="80" Binding="{Binding HoursWorked, StringFormat='{}{0:N1}'}" Header="Ore Fatte" />
                    <DataGridTextColumn Width="80" Binding="{Binding BudgetHours}" Header="Ore Prev." />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
