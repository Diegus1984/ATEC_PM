<Window
    x:Class="ATEC.PM.Client.Views.PhaseTemplateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nuovo Template Fase"
    Width="420" Height="360"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border Padding="16,12" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock x:Name="txtError" FontSize="12" Foreground="#EF4444" VerticalAlignment="Center" />
                <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="90" Height="34" Background="#F3F4F6" BorderThickness="0"
                            Click="BtnCancel_Click" Content="Annulla" Cursor="Hand" Foreground="#374151" />
                    <Button Width="90" Height="34" Margin="8,0,0,0" Background="#4F6EF7" BorderThickness="0"
                            Click="BtnSave_Click" Content="Salva" Cursor="Hand" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>
        <StackPanel Margin="24,16,24,8">
            <TextBlock Text="NOME FASE *" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,4" />
            <TextBox x:Name="txtName" Height="32" Padding="8,5" FontSize="13" BorderBrush="#E4E7EC" />

            <TextBlock Text="REPARTO" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,12,0,4" />
            <ComboBox x:Name="cmbDepartment" Height="32" Padding="8,5" FontSize="13" BorderBrush="#E4E7EC" />

            <TextBlock Text="CATEGORIA" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,12,0,4" />
            <TextBox x:Name="txtCategory" Height="32" Padding="8,5" FontSize="13" BorderBrush="#E4E7EC" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ORDINAMENTO" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,4" />
                    <TextBox x:Name="txtSortOrder" Height="32" Padding="8,5" FontSize="13" BorderBrush="#E4E7EC" Text="0" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="DEFAULT" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,4" />
                    <CheckBox x:Name="chkDefault" Content="Inserisci di default" FontSize="13" VerticalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
