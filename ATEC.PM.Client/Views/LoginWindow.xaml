<Window x:Class="ATEC.PM.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ATEC PM - Login" MinWidth="400" MinHeight="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F7F8FA">
    <Grid>
        <Border Background="White" BorderBrush="#E4E7EC" BorderThickness="1" Margin="40" Padding="32">
            <StackPanel VerticalAlignment="Center">
                <Border Background="#1A1D26" Width="48" Height="48" Margin="0,0,0,16" HorizontalAlignment="Center">
                    <TextBlock Text="A" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="ATEC PM" FontSize="22" FontWeight="Bold" Foreground="#1A1D26" HorizontalAlignment="Center"/>
                <TextBlock Text="Gestione Commesse" FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,4,0,28"/>

                <TextBlock Text="SERVER" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                <TextBox x:Name="txtServer" Text="http://localhost:5100" Height="36" Padding="8,6" BorderBrush="#E4E7EC"/>

                <TextBlock Text="UTENTE" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,16,0,6"/>
                <TextBox x:Name="txtUsername" Height="36" Padding="8,6" BorderBrush="#E4E7EC"/>

                <TextBlock Text="PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,16,0,6"/>
                <PasswordBox x:Name="txtPassword" Height="36" Padding="8,6" BorderBrush="#E4E7EC"/>

                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>

                <Button x:Name="btnLogin" Content="Accedi" Height="40" Margin="0,20,0,0"
                        Background="#4F6EF7" Foreground="White" FontSize="15" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
