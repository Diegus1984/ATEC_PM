<Window
    x:Class="ATEC.PM.Client.Views.Quotes.NewQuoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nuovo Preventivo" Width="550" SizeToContent="Height"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
    Background="#F7F8FA">

    <Border Margin="24" Background="White" BorderBrush="#E4E7EC"
            BorderThickness="1" CornerRadius="6" Padding="24">
        <StackPanel>
            <!-- Titolo -->
            <TextBlock Text="Titolo preventivo *" FontSize="11" FontWeight="SemiBold"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16" />

            <!-- Cliente -->
            <TextBlock Text="Cliente *" FontSize="11" FontWeight="SemiBold"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <ComboBox x:Name="cmbCustomer" Height="36" FontSize="13"
                      IsEditable="True" IsTextSearchEnabled="True"
                      DisplayMemberPath="CompanyName" SelectedValuePath="Id"
                      Margin="0,0,0,16" />

            <!-- Template (Gruppo) -->
            <TextBlock Text="Template (Gruppo) *" FontSize="11" FontWeight="SemiBold"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <ComboBox x:Name="cmbGroup" Height="36" FontSize="13"
                      DisplayMemberPath="Name" SelectedValuePath="Id"
                      Margin="0,0,0,4" />
            <TextBlock x:Name="txtGroupHint" Text="Le voci auto-include verranno aggiunte automaticamente"
                       FontSize="10" Foreground="#9CA3AF" Margin="0,0,0,16" />

            <!-- Row: Consegna + Validità -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tempi consegna (gg)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="0,0,0,4" />
                    <TextBox x:Name="txtDeliveryDays" Text="90"
                             Style="{StaticResource ModernTextBox}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Validità offerta (gg)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="0,0,0,4" />
                    <TextBox x:Name="txtValidityDays" Text="30"
                             Style="{StaticResource ModernTextBox}" />
                </StackPanel>
            </Grid>

            <!-- Tipo pagamento -->
            <TextBlock Text="Tipo pagamento" FontSize="11" FontWeight="SemiBold"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <ComboBox x:Name="cmbPayment" Height="36" FontSize="13"
                      IsEditable="True" Margin="0,0,0,16">
                <ComboBoxItem Content="30 gg DFFM" />
                <ComboBoxItem Content="30/60 gg DFFM" />
                <ComboBoxItem Content="30/60/90 gg DFFM" />
                <ComboBoxItem Content="Bonifico anticipato" />
                <ComboBoxItem Content="50% anticipo + 50% a consegna" />
                <ComboBoxItem Content="Da concordare" />
            </ComboBox>

            <!-- Pulsanti -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Annulla" Style="{StaticResource FlatBtn}"
                        Width="100" Margin="0,0,8,0" Click="BtnCancel_Click" />
                <Button Content="Crea" Style="{StaticResource PrimaryBtn}"
                        Width="120" Click="BtnCreate_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
