<Page
    x:Class="ATEC.PM.Client.Views.Quotes.QuoteCatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ══════════════════════════════════════════════  -->
        <!--  LEFT: Tree Gruppi → Categorie  -->
        <!--  ══════════════════════════════════════════════  -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,1,0">
            <DockPanel>

                <!--  Selezione Listino  -->
                <Border
                    Padding="8,8"
                    Background="#F0F4FF"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            Margin="4,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#4F6EF7"
                            Text="LISTINO:" />
                        <ComboBox
                            x:Name="cmbPriceList"
                            Height="28"
                            Padding="6,3"
                            DisplayMemberPath="Name"
                            FontSize="12"
                            SelectionChanged="CmbPriceList_SelectionChanged" />
                    </DockPanel>
                </Border>

                <!--  Toolbar albero  -->
                <Border
                    Style="{StaticResource ToolbarBorder}"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <Button
                            Click="BtnNewGroup_Click"
                            Content="+ Gruppo"
                            Style="{StaticResource PrimaryBtn}" />
                        <Button
                            Background="#16A34A"
                            Click="BtnNewCategory_Click"
                            Content="+ Categoria"
                            Foreground="White"
                            Style="{StaticResource SuccessBtn}" />
                        <Button
                            HorizontalAlignment="Right"
                            Background="#F3F4F6"
                            Click="BtnRefreshTree_Click"
                            Content="⟳"
                            DockPanel.Dock="Right"
                            Foreground="#374151"
                            Style="{StaticResource FlatBtn}"
                            ToolTip="Aggiorna" />
                    </DockPanel>
                </Border>

                <!--  Ricerca  -->
                <Border
                    Padding="12,8"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <Grid>
                        <TextBox
                            x:Name="txtTreeSearch"
                            Height="32"
                            Padding="8,5"
                            BorderBrush="#E4E7EC"
                            FontSize="13"
                            TextChanged="TxtTreeSearch_TextChanged" />
                        <TextBlock
                            x:Name="txtTreeSearchPlaceholder"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#9CA3AF"
                            IsHitTestVisible="False"
                            Text="Cerca gruppo o categoria..." />
                    </Grid>
                </Border>

                <!--  Status  -->
                <Border
                    Padding="12,6"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <TextBlock
                        x:Name="txtTreeStatus"
                        FontSize="11"
                        Foreground="#9CA3AF"
                        Text="Caricamento..." />
                </Border>

                <!--  TreeView  -->
                <TreeView
                    x:Name="treeGroups"
                    Padding="4"
                    Background="White"
                    BorderThickness="0"
                    SelectedItemChanged="Tree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,4" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <ContextMenu x:Key="GroupContextMenu">
                            <MenuItem Click="BtnEditGroup_Click" Header="Modifica gruppo" />
                            <MenuItem Click="BtnDeleteGroup_Click" Header="Elimina gruppo" />
                        </ContextMenu>
                        <ContextMenu x:Key="CategoryContextMenu">
                            <MenuItem Click="BtnEditCategory_Click" Header="Modifica categoria" />
                            <MenuItem Click="BtnDeleteCategory_Click" Header="Elimina categoria" />
                        </ContextMenu>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>
        </Border>

        <!--  ══════════════════════════════════════════════  -->
        <!--  RIGHT: Prodotti della categoria selezionata  -->
        <!--  ══════════════════════════════════════════════  -->
        <Border Grid.Column="1">
            <DockPanel>
                <!--  Header destro  -->
                <Border
                    Padding="20,10"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock
                            x:Name="txtSectionTitle"
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#1A1D26"
                            Text="Seleziona un gruppo o categoria" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnNewProduct"
                                Click="BtnNewProduct_Click"
                                Content="+ Nuovo Prodotto"
                                Style="{StaticResource PrimaryBtn}"
                                Visibility="Collapsed" />
                            <Border
                                Width="1"
                                Margin="12,4"
                                Background="#E4E7EC" />
                            <Button
                                Background="#F59E0B"
                                Click="BtnImportExcel_Click"
                                Content="📥 Importa Excel"
                                Foreground="White"
                                Style="{StaticResource FlatBtn}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!--  Status bar prodotti  -->
                <Border
                    Padding="16,6"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <Grid>
                        <TextBlock
                            x:Name="txtProductStatus"
                            HorizontalAlignment="Left"
                            FontSize="11"
                            Foreground="#6B7280"
                            Text="Pronto" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontSize="11"
                            FontStyle="Italic"
                            Foreground="#9CA3AF"
                            Text="Filtri: abc = contiene  |  abc* = inizia con  |  *abc = finisce con" />
                    </Grid>
                </Border>

                <!--  DataGrid Prodotti  -->
                <DataGrid
                    x:Name="dgProducts"
                    Margin="0"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    MouseDoubleClick="DgProducts_DoubleClick"
                    SelectionChanged="DgProducts_SelectionChanged"
                    SelectionMode="Single"
                    RowDetailsVisibilityMode="Collapsed"
                    Style="{StaticResource ModernDataGrid}">
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="40,8,16,8">
                                <StackPanel>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,6"
                                               Text="{Binding VariantCount, StringFormat='VARIANTI ({0}):'}" />
                                    <!-- Header varianti -->
                                    <Border Margin="0,0,0,2" Padding="8,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Codice" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" />
                                            <TextBlock Grid.Column="1" Text="Nome" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" />
                                            <TextBlock Grid.Column="2" Text="Prezzo cl." FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Column="3" Text="Costo az." FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Column="4" Text="Sconto" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="5" Text="IVA" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="6" Text="Qtà" FontSize="10" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Variants}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,3" Padding="8,5" Background="White"
                                                        BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="80" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Code}" FontSize="12"
                                                                   Foreground="#6B7280" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                                   FontWeight="Medium" Foreground="#1A1D26" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="{Binding SellPriceFormatted}" FontSize="12"
                                                                   FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Grid.Column="3" Text="{Binding CostPriceFormatted}" FontSize="12"
                                                                   Foreground="#16A34A" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Grid.Column="4" Text="{Binding DiscountFormatted}" FontSize="12"
                                                                   Foreground="#9CA3AF" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Grid.Column="5" Text="{Binding VatFormatted}" FontSize="12"
                                                                   Foreground="#9CA3AF" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Grid.Column="6" Text="{Binding QtyFormatted}" FontSize="12"
                                                                   Foreground="#6B7280" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                    <DataGrid.Columns>
                        <!--  Expander freccia  -->
                        <DataGridTemplateColumn Width="32" MinWidth="32" CanUserResize="False">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernCell}">
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="btnExpand"
                                            Background="Transparent" BorderThickness="0"
                                            Click="BtnExpandRow_Click" Cursor="Hand"
                                            Content="▶" FontSize="10" Foreground="#9CA3AF"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            ToolTip="Mostra varianti" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Tipo  -->
                        <DataGridTemplateColumn Width="60" SortMemberPath="ItemType">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Style="{StaticResource DgHeaderText}" Text="TIPO" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="4,2"
                                        HorizontalAlignment="Center"
                                        Background="{Binding ItemType, Converter={StaticResource ItemTypeToBgConverter}}"
                                        CornerRadius="3">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding ItemType, Converter={StaticResource ItemTypeToLabelConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Codice  -->
                        <DataGridTemplateColumn Width="120" SortMemberPath="Code">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DgHeaderText}" Text="CODICE" />
                                    <TextBox
                                        Loaded="ProductFilter_Loaded"
                                        Style="{StaticResource HeaderSearchBox}"
                                        Tag="Code"
                                        TextChanged="ProductFilter_Changed" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource DgCellText}" Text="{Binding Code}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Nome  -->
                        <DataGridTemplateColumn
                            Width="*"
                            MinWidth="200"
                            SortMemberPath="Name">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DgHeaderText}" Text="NOME" />
                                    <TextBox
                                        Loaded="ProductFilter_Loaded"
                                        Style="{StaticResource HeaderSearchBox}"
                                        Tag="Name"
                                        TextChanged="ProductFilter_Changed" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Style="{StaticResource DgCellText}"
                                        Text="{Binding Name}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Varianti (conteggio)  -->
                        <DataGridTemplateColumn Width="80" SortMemberPath="VariantCount">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Style="{StaticResource DgHeaderText}" Text="VARIANTI" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource DgCellText}"
                                        Text="{Binding VariantCount}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Prezzo min-max  -->
                        <DataGridTemplateColumn Width="160" SortMemberPath="PriceRange">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Style="{StaticResource DgHeaderText}" Text="PREZZO CLIENTE" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="#111827"
                                        Style="{StaticResource DgCellText}"
                                        Text="{Binding PriceRange}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Costo min-max  -->
                        <DataGridTemplateColumn Width="160" SortMemberPath="CostRange">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Style="{StaticResource DgHeaderText}" Text="COSTO AZIENDALE" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Foreground="#16A34A"
                                        Style="{StaticResource DgCellText}"
                                        Text="{Binding CostRange}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Auto-include  -->
                        <DataGridTemplateColumn Width="70">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Style="{StaticResource DgHeaderText}" Text="AUTO" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource DgCellText}"
                                        Text="{Binding AutoIncludeLabel}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  AZIONI inline  -->
                        <DataGridTemplateColumn Width="110" MinWidth="110">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Style="{StaticResource DgHeaderText}" Text="" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            Click="BtnEditProductRow_Click"
                                            Style="{StaticResource RowEditBtn}"
                                            Tag="{Binding Id}" />
                                        <Button
                                            Width="26" Height="26"
                                            Margin="4,0,0,0"
                                            Background="#16A34A1A"
                                            BorderThickness="0"
                                            Click="BtnDuplicateProductRow_Click"
                                            Content="📋" Cursor="Hand"
                                            FontSize="11" Foreground="#16A34A"
                                            Tag="{Binding Id}" ToolTip="Duplica" />
                                        <Button
                                            Margin="4,0,0,0"
                                            Click="BtnDeleteProductRow_Click"
                                            Style="{StaticResource RowDeleteBtn}"
                                            Tag="{Binding Id}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Page>
