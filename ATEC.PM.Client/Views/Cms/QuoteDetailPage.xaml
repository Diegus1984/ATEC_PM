<Page
    x:Class="ATEC.PM.Client.Views.Quotes.QuoteDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <DockPanel>
        <!--  TOP BAR  -->
        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Margin="0,0,16,0"
                        Click="BtnBack_Click"
                        Content="← Lista"
                        Style="{StaticResource GhostBtn}" />
                    <TextBlock
                        x:Name="txtQuoteNumber"
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#1A1D26" />
                    <Border
                        x:Name="brdStatus"
                        Margin="12,0,0,0"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        CornerRadius="4">
                        <TextBlock
                            x:Name="txtStatus"
                            FontSize="11"
                            FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnSave"
                        Margin="0,0,8,0"
                        Click="BtnSave_Click"
                        Content="💾 Salva"
                        Style="{StaticResource PrimaryBtn}" />
                    <Button
                        x:Name="btnPdfPreview"
                        Margin="0,0,8,0"
                        Background="#7C3AED"
                        Click="BtnPdfPreview_Click"
                        Content="👁 Anteprima PDF"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnPdfDownload"
                        Margin="0,0,8,0"
                        Click="BtnPdfDownload_Click"
                        Content="📥 Scarica PDF"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        x:Name="btnAddItem"
                        Margin="0,0,8,0"
                        Background="#16A34A"
                        Click="BtnAddItem_Click"
                        Content="+ Aggiungi al preventivo"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                    <ComboBox
                        x:Name="cmbChangeStatus"
                        Width="140"
                        Height="32"
                        FontSize="12"
                        SelectionChanged="CmbChangeStatus_Changed">
                        <ComboBoxItem
                            Content="Cambia stato..."
                            IsSelected="True"
                            Tag="" />
                        <ComboBoxItem Content="→ Inviato" Tag="sent" />
                        <ComboBoxItem Content="→ In trattativa" Tag="negotiation" />
                        <ComboBoxItem Content="→ Accettato" Tag="accepted" />
                        <ComboBoxItem Content="→ Rifiutato" Tag="rejected" />
                        <ComboBoxItem Content="→ Bozza" Tag="draft" />
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  MAIN CONTENT  -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!--  ══════════════════════════════════════  -->
                <!--  HEADER PREVENTIVO  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <!--  Row 0  -->
                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Titolo *" />
                            <TextBox
                                x:Name="txtTitle"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Cliente" />
                            <TextBlock
                                x:Name="txtCustomer"
                                Padding="0,8"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#2563EB" />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,0,0,12">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Template" />
                            <TextBlock
                                x:Name="txtGroupName"
                                Padding="0,8"
                                FontSize="13"
                                Foreground="#374151" />
                        </StackPanel>

                        <!--  Row 1  -->
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Referente 1" />
                            <TextBox
                                x:Name="txtContact1"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Referente 2" />
                            <TextBox
                                x:Name="txtContact2"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,0,12">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Referente 3" />
                            <TextBox
                                x:Name="txtContact3"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>

                        <!--  Row 2  -->
                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,12,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Tempi consegna (gg)" />
                            <TextBox
                                x:Name="txtDeliveryDays"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,0,12,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Validità offerta (gg)" />
                            <TextBox
                                x:Name="txtValidityDays"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="0,0,0,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#6B7280"
                                Text="Tipo pagamento" />
                            <TextBox
                                x:Name="txtPaymentType"
                                Style="{StaticResource ModernTextBox}"
                                 />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  PRODOTTI & CONTENUTI  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="0"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <DockPanel>
                        <Border
                            Padding="16,10"
                            BorderBrush="#E4E7EC"
                            BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                            <TextBlock
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="#1A1D26"
                                Text="PRODOTTI &amp; CONTENUTI" />
                        </Border>

                        <DataGrid
                            x:Name="dgItems"
                            MinHeight="100"
                            AutoGenerateColumns="False"
                            Background="White"
                            BorderThickness="0"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            ColumnHeaderHeight="34"
                            FontSize="13"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            HorizontalGridLinesBrush="#F3F4F6"
                            RowHeight="38"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.Header>
                                        <TextBlock Text="" />
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="4,2"
                                                HorizontalAlignment="Center"
                                                Background="{Binding ItemType, Converter={StaticResource QuoteItemTypeToBgConverter}}"
                                                CornerRadius="3">
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding ItemTypeLabel}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  Toggle Attiva  -->
                                <DataGridTemplateColumn Width="45" Header="Attiva">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Checked="ItemToggle_Changed"
                                                IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Unchecked="ItemToggle_Changed"
                                                Visibility="{Binding IsVariantRow, Converter={StaticResource BoolToVis}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  Toggle Conferma  -->
                                <DataGridTemplateColumn Width="55" Header="Conf.">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Checked="ItemToggle_Changed"
                                                IsChecked="{Binding IsConfirmed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Unchecked="ItemToggle_Changed"
                                                Visibility="{Binding IsVariantRow, Converter={StaticResource BoolToVis}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding Code}"
                                    Header="Codice"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="*"
                                    MinWidth="200"
                                    Binding="{Binding Name}"
                                    FontWeight="SemiBold"
                                    Header="Nome"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="55"
                                    Binding="{Binding Unit}"
                                    Header="UdM"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="65"
                                    Binding="{Binding Quantity, StringFormat=N2}"
                                    Header="Qtà" />
                                <DataGridTextColumn
                                    Width="95"
                                    Binding="{Binding CostPrice, StringFormat=N2}"
                                    Header="Costo az. €" />
                                <DataGridTextColumn
                                    Width="95"
                                    Binding="{Binding SellPrice, StringFormat=N2}"
                                    Header="Prezzo cl. €" />
                                <DataGridTextColumn
                                    Width="70"
                                    Binding="{Binding DiscountPct}"
                                    Header="Sconto %" />
                                <DataGridTextColumn
                                    Width="55"
                                    Binding="{Binding VatPct}"
                                    Header="IVA %"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding LineTotal, StringFormat=N2}"
                                    FontWeight="Bold"
                                    Header="TOTALE"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="90"
                                    Binding="{Binding LineProfit, StringFormat=N2}"
                                    Foreground="Green"
                                    Header="UTILE"
                                    IsReadOnly="True" />
                                <DataGridTemplateColumn Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="BtnRemoveItem_Click"
                                                Content="✕"
                                                Cursor="Hand"
                                                FontSize="12"
                                                Foreground="#DC2626"
                                                Tag="{Binding Id}"
                                                ToolTip="Rimuovi voce" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  RIEPILOGO ECONOMICO  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <!--  Sinistra: sconto globale + toggle PDF  -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#374151"
                                    Text="Sconto sul TOTALE:" />
                                <TextBox
                                    x:Name="txtDiscountPct"
                                    Width="60"
                                    Height="30"
                                    FontSize="12"
                                    Text="0"
                                    TextAlignment="Right"
                                     />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="%" />
                            </StackPanel>
                            <CheckBox
                                x:Name="chkShowItemPrices"
                                Margin="0,0,0,6"
                                Content="Visualizza prezzi sulle pagine dei singoli articoli"
                                FontSize="12"
                                IsChecked="True" />
                            <CheckBox
                                x:Name="chkShowSummary"
                                Margin="0,0,0,6"
                                Content="Attiva il riepilogo finale"
                                FontSize="12"
                                IsChecked="True" />
                            <CheckBox
                                x:Name="chkShowSummaryPrices"
                                Content="Visualizza prezzi dei singoli articoli sul riepilogo"
                                FontSize="12"
                                IsChecked="True" />
                        </StackPanel>

                        <!--  Destra: totali  -->
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#374151"
                                    Text="TOTALE" />
                                <TextBlock
                                    x:Name="txtSubtotal"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#111827" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#374151"
                                    Text="TOTALE IVA" />
                                <TextBlock
                                    x:Name="txtVatTotal"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#111827" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#374151"
                                    Text="SCONTO" />
                                <TextBlock
                                    x:Name="txtDiscount"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#DC2626" />

                                <!--  Separator  -->
                                <Border
                                    Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="0,1,0,0" />

                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="#111827"
                                    Text="TOTALE IMPONIBILE" />
                                <TextBlock
                                    x:Name="txtTotal"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="#111827" />

                                <TextBlock
                                    Grid.Row="5"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#374151"
                                    Text="TOTALE IVA INCLUSA" />
                                <TextBlock
                                    x:Name="txtTotalWithVat"
                                    Grid.Row="5"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#374151" />

                                <!--  Separator  -->
                                <Border
                                    Grid.Row="6"
                                    Grid.ColumnSpan="2"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="0,1,0,0" />

                                <TextBlock
                                    Grid.Row="7"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="#16A34A"
                                    Text="TOTALE COSTI AZIENDALI" />
                                <TextBlock
                                    x:Name="txtCostTotal"
                                    Grid.Row="7"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="#16A34A" />

                                <TextBlock
                                    Grid.Row="8"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#16A34A"
                                    Text="UTILE" />
                                <TextBlock
                                    x:Name="txtProfit"
                                    Grid.Row="8"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#16A34A" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  NOTE PREVENTIVO  -->
                <!--  ══════════════════════════════════════  -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="16"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="#6B7280"
                                Text="NOTE AD USO INTERNO" />
                            <TextBox
                                x:Name="txtNotesInternal"
                                Height="120"
                                AcceptsReturn="True"
                                Style="{StaticResource ModernTextBox}"
                                
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="#6B7280"
                                Text="NOTE SU PREVENTIVO" />
                            <TextBox
                                x:Name="txtNotesQuote"
                                Height="120"
                                AcceptsReturn="True"
                                Style="{StaticResource ModernTextBox}"
                                
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
