<Page
    x:Class="ATEC.PM.Client.Views.Quotes.QuoteDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F7F8FA">

    <DockPanel>
        <!--  TOP BAR  -->
        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Margin="0,0,16,0"
                        Click="BtnBack_Click"
                        Content="← Lista"
                        Style="{StaticResource FlatBtn}" />
                    <TextBlock
                        x:Name="txtQuoteNumber"
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#1A1D26" />
                    <Border
                        x:Name="brdStatus"
                        Margin="12,0,0,0"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        CornerRadius="4">
                        <TextBlock
                            x:Name="txtStatus"
                            FontSize="11"
                            FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnSave"
                        Margin="0,0,8,0"
                        Click="BtnSave_Click"
                        Content="Salva"
                        Style="{StaticResource PrimaryBtn}" />
                    <Button
                        x:Name="btnPdfPreview"
                        Margin="0,0,8,0"
                        Background="#7C3AED"
                        Click="BtnPdfPreview_Click"
                        Content="Anteprima PDF"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  MAIN CONTENT  -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!--  ══════════════════════════════════════  -->
                <!--  HEADER PREVENTIVO  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Titolo *" />
                            <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,12">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Cliente" />
                            <TextBlock x:Name="txtCustomer" Padding="0,8" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Template" />
                            <TextBlock x:Name="txtGroupName" Padding="0,8" FontSize="13" Foreground="#374151" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Referente 1" />
                            <TextBox x:Name="txtContact1" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,12">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Referente 2" />
                            <TextBox x:Name="txtContact2" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Referente 3" />
                            <TextBox x:Name="txtContact3" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Tempi consegna (gg)" />
                            <TextBox x:Name="txtDeliveryDays" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Validità offerta (gg)" />
                            <TextBox x:Name="txtValidityDays" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,0">
                            <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Tipo pagamento" />
                            <TextBox x:Name="txtPaymentType" Style="{StaticResource ModernTextBox}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  PRODOTTI & CONTENUTI  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <Border Padding="16,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                            <TextBlock FontSize="13" FontWeight="Bold" Foreground="#1A1D26" Text="PRODOTTI &amp; CONTENUTI" />
                        </Border>

                        <!-- Lista prodotti con ItemsControl -->
                        <ItemsControl x:Name="icProducts" Padding="0,4,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8,4" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="6" Background="White">
                                        <StackPanel>
                                            <!-- HEADER PRODOTTO -->
                                            <Border Padding="12,10" Background="#F8FAFC" CornerRadius="6,6,0,0" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                                                <DockPanel>
                                                    <!-- Badge tipo -->
                                                    <Border Padding="6,3" Margin="0,0,10,0" VerticalAlignment="Center" CornerRadius="4"
                                                            Background="{Binding TypeBadgeColor}">
                                                        <TextBlock Text="{Binding TypeBadgeLabel}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                    </Border>

                                                    <!-- Pulsanti destra -->
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TotalDisplay}" FontSize="13" FontWeight="Bold" Foreground="#111827"
                                                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                                                        <Button Content="+" ToolTip="Aggiungi variante locale" Width="28" Height="28"
                                                                FontSize="14" FontWeight="Bold" Cursor="Hand"
                                                                Background="#EFF6FF" Foreground="#2563EB" BorderBrush="#BFDBFE" BorderThickness="1"
                                                                Click="BtnAddLocalVariant_Click" Tag="{Binding ParentId}" Padding="0" />
                                                        <Button Content="▼" Width="28" Height="28" Margin="4,0,0,0"
                                                                FontSize="10" Cursor="Hand"
                                                                Background="Transparent" BorderThickness="0" Foreground="#6B7280"
                                                                Click="BtnToggleExpand_Click" Tag="{Binding ParentId}" Padding="0"
                                                                x:Name="btnExpand" />
                                                        <Button Content="X" Width="28" Height="28" Margin="4,0,0,0"
                                                                FontSize="11" Cursor="Hand"
                                                                Background="Transparent" BorderThickness="0" Foreground="#DC2626"
                                                                Click="BtnRemoveProduct_Click" Tag="{Binding ParentId}"
                                                                ToolTip="Rimuovi prodotto" Padding="0" />
                                                    </StackPanel>

                                                    <!-- Nome prodotto -->
                                                    <TextBlock Text="{Binding ParentName}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#1A1D26" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </Border>

                                            <!-- VARIANTI (espandibili) -->
                                            <ItemsControl ItemsSource="{Binding Variants}" x:Name="icVariants">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,6" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                                            <DockPanel>
                                                                <!-- Toggle attiva -->
                                                                <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                                          VerticalAlignment="Center" Margin="0,0,8,0"
                                                                          Checked="VariantToggle_Changed"
                                                                          Unchecked="VariantToggle_Changed" />

                                                                <!-- Pulsanti destra -->
                                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding LineTotalDisplay}" FontSize="12" FontWeight="SemiBold"
                                                                               Foreground="{Binding TotalColor}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                    <Button Content="X" Width="22" Height="22"
                                                                            FontSize="10" Cursor="Hand"
                                                                            Background="Transparent" BorderThickness="0" Foreground="#9CA3AF"
                                                                            Click="BtnRemoveVariant_Click" Tag="{Binding Id}"
                                                                            ToolTip="Rimuovi variante" Padding="0" />
                                                                </StackPanel>

                                                                <!-- Campi variante -->
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#374151"
                                                                               Width="280" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                    <TextBox Text="{Binding QuantityText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                             Width="55" Height="26" FontSize="11" TextAlignment="Right" Margin="8,0"
                                                                             LostFocus="VariantField_LostFocus" Tag="{Binding Id}" />
                                                                    <TextBlock Text="{Binding Unit}" FontSize="11" Foreground="#6B7280"
                                                                               Width="35" VerticalAlignment="Center" />
                                                                    <TextBox Text="{Binding SellPriceText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                             Width="85" Height="26" FontSize="11" TextAlignment="Right" Margin="4,0"
                                                                             LostFocus="VariantField_LostFocus" Tag="{Binding Id}" />
                                                                    <TextBlock Text="€" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                    <TextBox Text="{Binding DiscountPctText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                             Width="45" Height="26" FontSize="11" TextAlignment="Right" Margin="4,0"
                                                                             LostFocus="VariantField_LostFocus" Tag="{Binding Id}" />
                                                                    <TextBlock Text="%" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Placeholder vuoto -->
                        <TextBlock x:Name="txtNoProducts" Text="Nessun prodotto aggiunto. Clicca '+ Aggiungi al preventivo' per iniziare."
                                   FontSize="12" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,20,0,20"
                                   Visibility="Collapsed" />

                        <!-- Pulsante aggiungi -->
                        <Button
                            x:Name="btnAddItem"
                            Margin="0,8,0,4"
                            Padding="12,6"
                            HorizontalAlignment="Center"
                            Background="#16A34A"
                            Click="BtnAddItem_Click"
                            Content="+ Aggiungi al preventivo"
                            Cursor="Hand"
                            FontSize="12"
                            Foreground="White"
                            Style="{StaticResource FlatBtn}" />
                    </StackPanel>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  CONTENUTI AUTOMATICI (auto-include)  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <Border Padding="16,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="#1A1D26" Text="CONTENUTI AUTOMATICI"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="txtAutoCount" FontSize="11" Foreground="#9CA3AF" Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <ListBox x:Name="lbAutoIncludes" Padding="4" BorderThickness="0" Background="Transparent"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="AutoInclude_PreviewMouseDown"
                                 PreviewMouseMove="AutoInclude_PreviewMouseMove"
                                 Drop="AutoInclude_Drop">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="4,2" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Padding="10,8" Background="#FAFBFC" BorderBrush="#E4E7EC"
                                                        BorderThickness="1" CornerRadius="4" AllowDrop="True">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F0F4FF" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#EFF6FF" />
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#BFDBFE" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <TextBlock Text="≡" FontSize="16" Foreground="#9CA3AF" Cursor="SizeAll"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" />
                                        <Button DockPanel.Dock="Right" Content="X" Width="22" Height="22"
                                                FontSize="10" Cursor="Hand" Padding="0"
                                                Background="Transparent" BorderThickness="0" Foreground="#DC2626"
                                                Click="BtnRemoveAutoInclude_Click" Tag="{Binding ParentId}"
                                                ToolTip="Rimuovi" />
                                        <TextBlock Text="{Binding ParentName}" FontSize="12" Foreground="#374151"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock x:Name="txtNoAutoIncludes" Text="Nessun contenuto automatico."
                                   FontSize="12" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,12,0,12"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  RIEPILOGO ECONOMICO  -->
                <!--  ══════════════════════════════════════  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Text="Sconto sul TOTALE:" />
                                <TextBox x:Name="txtDiscountPct" Width="60" Height="30" FontSize="12" Text="0" TextAlignment="Right" />
                                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="%" />
                            </StackPanel>
                            <CheckBox x:Name="chkShowItemPrices" Margin="0,0,0,6" Content="Visualizza prezzi sulle pagine dei singoli articoli" FontSize="12" IsChecked="True" />
                            <CheckBox x:Name="chkShowSummary" Margin="0,0,0,6" Content="Attiva il riepilogo finale" FontSize="12" IsChecked="True" />
                            <CheckBox x:Name="chkShowSummaryPrices" Content="Visualizza prezzi dei singoli articoli sul riepilogo" FontSize="12" IsChecked="True" />
                            <CheckBox x:Name="chkHideQuantities" Margin="0,6,0,0" Content="Nascondi dettagli (costo, qtà, sconto) dal riepilogo" FontSize="12" IsChecked="False" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="TOTALE" />
                                <TextBlock x:Name="txtSubtotal" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#111827" />

                                <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="TOTALE IVA" />
                                <TextBlock x:Name="txtVatTotal" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#111827" />

                                <TextBlock Grid.Row="2" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="SCONTO" />
                                <TextBlock x:Name="txtDiscount" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#DC2626" />

                                <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" />

                                <TextBlock Grid.Row="4" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#111827" Text="TOTALE IMPONIBILE" />
                                <TextBlock x:Name="txtTotal" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#111827" />

                                <TextBlock Grid.Row="5" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Text="TOTALE IVA INCLUSA" />
                                <TextBlock x:Name="txtTotalWithVat" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#374151" />

                                <Border Grid.Row="6" Grid.ColumnSpan="2" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" />

                                <TextBlock Grid.Row="7" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#16A34A" Text="TOTALE COSTI AZIENDALI" />
                                <TextBlock x:Name="txtCostTotal" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#16A34A" />

                                <TextBlock Grid.Row="8" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#16A34A" Text="UTILE" />
                                <TextBlock x:Name="txtProfit" Grid.Row="8" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#16A34A" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════  -->
                <!--  NOTE PREVENTIVO  -->
                <!--  ══════════════════════════════════════  -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="16" Background="White" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Text="NOTE AD USO INTERNO" />
                            <TextBox x:Name="txtNotesInternal" Height="120" AcceptsReturn="True"
                                     Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="16" Background="White" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Text="NOTE SU PREVENTIVO" />
                            <TextBox x:Name="txtNotesQuote" Height="120" AcceptsReturn="True"
                                     Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
