<Window
    x:Class="ATEC.PM.Client.Views.Quotes.QuoteProductDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uc="clr-namespace:ATEC.PM.Client.UserControls"
    Title="Nuovo Prodotto"
    Width="1280"
    Height="900"
    MinWidth="900"
    MinHeight="700"
    WindowState="Maximized"
    Background="#F7F8FA"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <DockPanel>
        <!--  Footer: Auto-include + Pulsanti  -->
        <Border
            Padding="24,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <CheckBox
                    x:Name="chkAutoInclude"
                    VerticalAlignment="Center"
                    Content="Aggiungi automaticamente ai nuovi preventivi"
                    FontSize="13" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="100"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Style="{StaticResource FlatBtn}" />
                    <Button
                        Width="100"
                        Click="BtnSave_Click"
                        Content="Salva"
                        Style="{StaticResource PrimaryBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  Contenuto principale: Grid 3 righe  -->
        <Grid Margin="24,16,24,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" MaxHeight="300" />
            </Grid.RowDefinitions>

            <!--  ROW 0: Header fields  -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Nome prodotto *" Margin="0,0,0,4" />
                    <TextBox x:Name="txtName" Style="{StaticResource ModernTextBox}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Codice" Margin="0,0,0,4" />
                    <TextBox x:Name="txtCode" Style="{StaticResource ModernTextBox}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Text="Tipologia" Margin="0,0,0,4" />
                    <ComboBox x:Name="cmbItemType" Height="36" FontSize="13" SelectedIndex="0">
                        <ComboBoxItem Content="Prodotto" Tag="product" />
                        <ComboBoxItem Content="Contenuto" Tag="content" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!--  ROW 1: Editor HTML (prende tutto lo spazio)  -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                        Text="Descrizione" Margin="0,0,0,4" />
                    <Border BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="4">
                        <uc:HtmlEditor x:Name="htmlEditor" />
                    </Border>
                </DockPanel>
            </Grid>

            <!--  ROW 2: Varianti  -->
            <DockPanel Grid.Row="2">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock FontSize="12" FontWeight="Bold" Foreground="#1A1D26"
                               Text="VARIANTI DEL PRODOTTO / SERVIZIO A LISTINO"
                               VerticalAlignment="Center" />
                    <Button Margin="12,0,0,0" HorizontalAlignment="Left"
                            Background="#16A34A" Click="BtnAddVariant_Click"
                            Content="+ Aggiungi riga" Foreground="White"
                            Style="{StaticResource FlatBtn}" />
                </DockPanel>
                <Border Background="White" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="4">
                    <DataGrid
                        x:Name="dgVariants"
                        MinHeight="60"
                        MaxHeight="250"
                        AutoGenerateColumns="False"
                        Background="White"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        ColumnHeaderHeight="32"
                        FontSize="13"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#F3F4F6"
                        RowHeight="36"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="90" Binding="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Header="Codice" />
                            <DataGridTextColumn Width="*" MinWidth="150" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Header="Nome" />
                            <DataGridTextColumn Width="100" Binding="{Binding CostPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Header="Costo az. &#x20AC;" />
                            <DataGridTextColumn Width="100" Binding="{Binding SellPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Header="Prezzo cl. &#x20AC;" />
                            <DataGridTextColumn Width="70" Binding="{Binding DiscountPct, UpdateSourceTrigger=PropertyChanged}" Header="Sconto %" />
                            <DataGridTextColumn Width="60" Binding="{Binding VatPct, UpdateSourceTrigger=PropertyChanged}" Header="IVA %" />
                            <DataGridTextColumn Width="60" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Header="UdM" />
                            <DataGridTextColumn Width="55" Binding="{Binding DefaultQty, UpdateSourceTrigger=PropertyChanged}" Header="Qtà" />
                            <DataGridTemplateColumn Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                Click="BtnRemoveVariant_Click" Content="✕" Cursor="Hand"
                                                FontSize="12" Foreground="#DC2626" Tag="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
