<Window
    x:Class="ATEC.PM.Client.Views.Quotes.QuoteGroupDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nuovo Gruppo"
    Width="450"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner">

    <Border
        Margin="24"
        Padding="24"
        Background="White"
        BorderBrush="#E4E7EC"
        BorderThickness="1"
        CornerRadius="6">
        <StackPanel>
            <TextBlock
                Margin="0,0,0,4"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="Nome gruppo *" />
            <TextBox
                x:Name="txtName"
                Margin="0,0,0,16"
                Style="{StaticResource ModernTextBox}" />

            <TextBlock
                Margin="0,0,0,4"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="Descrizione" />
            <TextBox
                x:Name="txtDescription"
                Height="60"
                Margin="0,0,0,16"
                AcceptsReturn="True"
                Style="{StaticResource ModernTextBox}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />

            <TextBlock
                Margin="0,0,0,4"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="Ordinamento" />
            <TextBox
                x:Name="txtSortOrder"
                Margin="0,0,0,16"
                Style="{StaticResource ModernTextBox}"
                Text="0" />

            <StackPanel
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Style="{StaticResource FlatBtn}" />
                <Button
                    Width="100"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
