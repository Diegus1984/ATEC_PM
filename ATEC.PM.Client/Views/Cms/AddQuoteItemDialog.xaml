<Window
    x:Class="ATEC.PM.Client.Views.Quotes.AddQuoteItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi al Preventivo"
    Width="850"
    Height="550"
    Background="#F7F8FA"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <DockPanel>
        <!--  Toolbar  -->
        <Border
            Padding="16,8"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#6B7280"
                        Text="Gruppo:" />
                    <ComboBox
                        x:Name="cmbGroup"
                        Width="200"
                        Height="32"
                        DisplayMemberPath="Name"
                        FontSize="12"
                        SelectedValuePath="Id"
                        SelectionChanged="CmbGroup_Changed" />
                    <TextBlock
                        Margin="16,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#6B7280"
                        Text="Categoria:" />
                    <ComboBox
                        x:Name="cmbCategory"
                        Width="200"
                        Height="32"
                        DisplayMemberPath="Name"
                        FontSize="12"
                        SelectedValuePath="Id"
                        SelectionChanged="CmbCategory_Changed" />
                </StackPanel>
                <TextBox
                    x:Name="txtSearch"
                    Width="180"
                    Height="32"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    FontSize="12"
                    Style="{StaticResource ModernTextBox}"
                    TextChanged="TxtSearch_Changed" />
            </DockPanel>
        </Border>

        <!--  Footer  -->
        <Border
            Padding="16,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        x:Name="txtInfo"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="#6B7280"
                        Text="Doppio-click su un prodotto per aggiungerlo al preventivo" />
                    <TextBlock
                        x:Name="txtAdded"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#16A34A" />
                </StackPanel>
                <Button
                    Width="80"
                    HorizontalAlignment="Right"
                    Click="BtnClose_Click"
                    Content="Chiudi"
                    DockPanel.Dock="Right"
                    Style="{StaticResource FlatBtn}" />
            </DockPanel>
        </Border>

        <!--  Product grid  -->
        <DataGrid
            x:Name="dgProducts"
            AutoGenerateColumns="False"
            Background="White"
            BorderThickness="0"
            FontSize="13"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="#F3F4F6"
            IsReadOnly="True"
            MouseDoubleClick="DgProducts_DoubleClick"
            RowHeight="36"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Code}"
                    Header="Codice" />
                <DataGridTextColumn
                    Width="*"
                    MinWidth="200"
                    Binding="{Binding Name}"
                    Header="Nome" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding VariantName}"
                    Header="Variante" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding CostPrice, StringFormat=N2}"
                    Header="Costo €" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding SellPrice, StringFormat=N2}"
                    Header="Prezzo €" />
                <DataGridTextColumn
                    Width="55"
                    Binding="{Binding Unit}"
                    Header="UdM" />
                <DataGridTextColumn
                    Width="55"
                    Binding="{Binding DefaultQty, StringFormat=N0}"
                    Header="Qtà" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
