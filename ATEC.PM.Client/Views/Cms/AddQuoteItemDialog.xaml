<Window
    x:Class="ATEC.PM.Client.Views.Quotes.AddQuoteItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi al Preventivo" Width="850" Height="550"
    WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
    Background="#F7F8FA">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,8" Background="White"
                BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Gruppo:" FontSize="12" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="cmbGroup" Width="200" Height="32" FontSize="12"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="CmbGroup_Changed" />
                    <TextBlock Text="Categoria:" FontSize="12" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="16,0,6,0" />
                    <ComboBox x:Name="cmbCategory" Width="200" Height="32" FontSize="12"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="CmbCategory_Changed" />
                </StackPanel>
                <TextBox x:Name="txtSearch" DockPanel.Dock="Right" Width="180" Height="32"
                         FontSize="12" HorizontalAlignment="Right"
                         Style="{StaticResource ModernTextBox}"
                         TextChanged="TxtSearch_Changed" />
            </DockPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="16,10" Background="White"
                BorderBrush="#E4E7EC" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtInfo" FontSize="11" Foreground="#6B7280"
                               VerticalAlignment="Center"
                               Text="Doppio-click su un prodotto per aggiungerlo al preventivo" />
                    <TextBlock x:Name="txtAdded" FontSize="11" Foreground="#16A34A"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Content="Chiudi" Style="{StaticResource FlatBtn}"
                        Width="80" Click="BtnClose_Click" />
            </DockPanel>
        </Border>

        <!-- Product grid -->
        <DataGrid x:Name="dgProducts"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="DgProducts_DoubleClick"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                  BorderThickness="0" RowHeight="36" FontSize="13"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Codice" Binding="{Binding Code}" Width="100" />
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="200" />
                <DataGridTextColumn Header="Variante" Binding="{Binding VariantName}" Width="200" />
                <DataGridTextColumn Header="Costo €" Binding="{Binding CostPrice, StringFormat=N2}" Width="90" />
                <DataGridTextColumn Header="Prezzo €" Binding="{Binding SellPrice, StringFormat=N2}" Width="90" />
                <DataGridTextColumn Header="UdM" Binding="{Binding Unit}" Width="55" />
                <DataGridTextColumn Header="Qtà" Binding="{Binding DefaultQty, StringFormat=N0}" Width="55" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
