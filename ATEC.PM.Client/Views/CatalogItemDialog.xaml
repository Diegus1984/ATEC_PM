<Window
    x:Class="ATEC.PM.Client.Views.CatalogItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Articolo"
    Width="520"
    Height="620"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="90"
                    Height="34"
                    Background="#F3F4F6"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    Content="Annulla"
                    Cursor="Hand"
                    Foreground="#374151" />
                <Button
                    x:Name="btnSave"
                    Width="90"
                    Height="34"
                    Margin="8,0,0,0"
                    Background="#4F6EF7"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    Content="Salva"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </StackPanel>
        </Border>
        <ScrollViewer Padding="24,8,24,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="CODICE *" />
                        <TextBox x:Name="txtCode" Style="{StaticResource Inp}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="UDM" />
                        <TextBox
                            x:Name="txtUnit"
                            Style="{StaticResource Inp}"
                            Text="PZ" />
                    </StackPanel>
                </Grid>
                <TextBlock Style="{StaticResource Lbl}" Text="DESCRIZIONE" />
                <TextBox
                    x:Name="txtDescription"
                    Height="50"
                    Padding="8,6"
                    AcceptsReturn="True"
                    BorderBrush="#E4E7EC"
                    FontSize="13"
                    TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="CATEGORIA" />
                        <TextBox x:Name="txtCategory" Style="{StaticResource Inp}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="SOTTOCATEGORIA" />
                        <TextBox x:Name="txtSubcategory" Style="{StaticResource Inp}" />
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="PREZZO ACQUISTO" />
                        <TextBox
                            x:Name="txtUnitCost"
                            Style="{StaticResource Inp}"
                            Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="PREZZO LISTINO" />
                        <TextBox
                            x:Name="txtListPrice"
                            Style="{StaticResource Inp}"
                            Text="0" />
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="FORNITORE" />
                        <ComboBox
                            x:Name="cmbSupplier"
                            Height="34"
                            Padding="8,6"
                            BorderBrush="#E4E7EC"
                            DisplayMemberPath="Name"
                            FontSize="13"
                            SelectedValuePath="Id" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="COD. ART. FORNITORE" />
                        <TextBox x:Name="txtSupplierCode" Style="{StaticResource Inp}" />
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Lbl}" Text="PRODUTTORE" />
                        <TextBox x:Name="txtManufacturer" Style="{StaticResource Inp}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Lbl}" Text="CODICE A BARRE" />
                        <TextBox x:Name="txtBarcode" Style="{StaticResource Inp}" />
                    </StackPanel>
                </Grid>
                <TextBlock Style="{StaticResource Lbl}" Text="NOTE" />
                <TextBox
                    x:Name="txtNotes"
                    Height="50"
                    Padding="8,6"
                    AcceptsReturn="True"
                    BorderBrush="#E4E7EC"
                    FontSize="13"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="txtError"
                    Margin="0,12,0,0"
                    FontSize="12"
                    Foreground="#EF4444"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
