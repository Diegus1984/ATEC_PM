<Window x:Class="ATEC.PM.Client.Views.CatalogItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Articolo" Width="520" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F8FA">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/><Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="34"/><Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="BorderBrush" Value="#E4E7EC"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" Width="90" Height="34" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button x:Name="btnSave" Content="Salva" Width="90" Height="34" Background="#4F6EF7" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
        <ScrollViewer Padding="24,8,24,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CODICE *" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtCode" Style="{StaticResource Inp}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="UDM" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtUnit" Style="{StaticResource Inp}" Text="PZ"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="DESCRIZIONE" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="txtDescription" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" FontSize="13" BorderBrush="#E4E7EC"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CATEGORIA" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtCategory" Style="{StaticResource Inp}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SOTTOCATEGORIA" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtSubcategory" Style="{StaticResource Inp}"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PREZZO ACQUISTO" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtUnitCost" Style="{StaticResource Inp}" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PREZZO LISTINO" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtListPrice" Style="{StaticResource Inp}" Text="0"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="FORNITORE" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbSupplier" Height="34" Padding="8,6" FontSize="13" BorderBrush="#E4E7EC"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="COD. ART. FORNITORE" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtSupplierCode" Style="{StaticResource Inp}"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRODUTTORE" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtManufacturer" Style="{StaticResource Inp}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CODICE A BARRE" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtBarcode" Style="{StaticResource Inp}"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="NOTE" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="txtNotes" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" FontSize="13" BorderBrush="#E4E7EC"/>
                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
