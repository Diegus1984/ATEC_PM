<Page
    x:Class="ATEC.PM.Client.Views.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="800"
    Background="#F7F8FA">
    <DockPanel>
        <!--  TOOLBAR  -->
        <Border
            Padding="20,15"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        x:Name="btnBackupNow"
                        Background="#4F6EF7"
                        Click="BtnBackupNow_Click"
                        Content="⬇ Esegui Backup"
                        Foreground="White"
                        Style="{StaticResource FlatBtn}" />

                    <Separator
                        Width="1"
                        Margin="5,0"
                        Background="#E4E7EC" />

                    <Button
                        x:Name="btnRefresh"
                        Click="BtnRefresh_Click"
                        Content="Aggiorna"
                        Style="{StaticResource FlatBtn}" />
                </StackPanel>

                <TextBlock
                    x:Name="txtStatus"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#667085"
                    Text="" />
            </DockPanel>
        </Border>

        <!--  INFO BANNER  -->
        <Border
            Padding="20,10"
            Background="#FFF8E1"
            BorderBrush="#FFD54F"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <TextBlock
                FontSize="12"
                Foreground="#6D4C00"
                Text="⚠ Il ripristino di un backup sovrascrive TUTTI i dati attuali. Prima di ripristinare viene creato automaticamente un backup di sicurezza."
                TextWrapping="Wrap" />
        </Border>

        <!--  STATUS BAR  -->
        <Border
            Padding="20,10"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                x:Name="txtFooter"
                FontSize="12"
                Foreground="#667085"
                Text="Pronto" />
        </Border>

        <!--  DATAGRID  -->
        <DataGrid
            x:Name="dgBackups"
            Margin="20"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            HeadersVisibility="Column"
            IsReadOnly="True"
            SelectionMode="Single"
            Style="{StaticResource ModernDataGrid}">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="350"
                    Binding="{Binding FileName}"
                    Header="Nome File" />

                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding SizeMB}"
                    Header="Dimensione (MB)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="180"
                    Binding="{Binding Date}"
                    Header="Data" />

                <DataGridTemplateColumn Width="280" Header="Azioni">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Margin="0,0,8,0"
                                    Padding="10,5"
                                    Background="#12B76A"
                                    Click="BtnRestore_Click"
                                    Content="Ripristina"
                                    Foreground="White"
                                    Style="{StaticResource FlatBtn}"
                                    Tag="{Binding FileName}" />
                                <Button
                                    Margin="0,0,8,0"
                                    Padding="10,5"
                                    Background="#4F6EF7"
                                    Click="BtnDownload_Click"
                                    Content="Scarica"
                                    Foreground="White"
                                    Style="{StaticResource FlatBtn}"
                                    Tag="{Binding FileName}" />
                                <Button
                                    Padding="10,5"
                                    Background="#F04438"
                                    Click="BtnDelete_Click"
                                    Content="Elimina"
                                    Foreground="White"
                                    Style="{StaticResource FlatBtn}"
                                    Tag="{Binding FileName}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
