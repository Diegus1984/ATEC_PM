<Window
    x:Class="ATEC.PM.Client.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:auth="clr-namespace:ATEC.PM.Client.Helpers"
    Title="ATEC PM - Gestione Commesse"
    Width="1920"
    Height="1080"
    MinWidth="1024"
    MinHeight="600"
    Background="{StaticResource Gray50Brush}"
    FontFamily="Segoe UI"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  SIDEBAR  -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <DockPanel>

                <!--  LOGO  -->
                <StackPanel Margin="16,16,16,12" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="32"
                            Height="32"
                            Background="{StaticResource PrimaryBrush}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="A" />
                        </Border>
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="ATEC PM" />
                    </StackPanel>
                    <Border
                        Height="1"
                        Margin="0,12,0,0"
                        Background="{StaticResource SidebarDividerBrush}" />
                </StackPanel>

                <!--  USER INFO (bottom)  -->
                <Border
                    Padding="16,10"
                    BorderBrush="{StaticResource SidebarDividerBrush}"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="32"
                            Height="32"
                            Background="{StaticResource PrimaryBrush}">
                            <TextBlock
                                x:Name="txtInitials"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White" />
                        </Border>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                x:Name="txtUserName"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White" />
                            <TextBlock
                                x:Name="txtRole"
                                FontFamily="Segoe UI"
                                FontSize="11"
                                Foreground="{StaticResource Gray400Brush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  NAVIGATION  -->
                <ScrollViewer Margin="8,0" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style x:Key="NavExpander" TargetType="Expander">
                            <Setter Property="IsExpanded" Value="True" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Margin" Value="0,4,0,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Expander">
                                        <StackPanel>
                                            <ToggleButton
                                                x:Name="HeaderSite"
                                                Margin="4,0"
                                                Padding="8,6"
                                                HorizontalContentAlignment="Left"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border
                                                            x:Name="bd"
                                                            Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}">
                                                            <DockPanel>
                                                                <TextBlock
                                                                    x:Name="arrow"
                                                                    Width="14"
                                                                    DockPanel.Dock="Left"
                                                                    FontFamily="Segoe UI"
                                                                    FontSize="9"
                                                                    Foreground="{StaticResource Gray400Brush}"
                                                                    Text="&#x25BC;" />
                                                                <ContentPresenter VerticalAlignment="Center" />
                                                            </DockPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter TargetName="arrow" Property="Text" Value="&#x25B6;" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource Gray400Brush}"
                                                    Text="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}" />
                                            </ToggleButton>
                                            <ContentPresenter
                                                x:Name="ExpandSite"
                                                Margin="0,2,0,0"
                                                Visibility="Collapsed" />
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ScrollViewer.Resources>

                    <StackPanel>
                        <!--  PRINCIPALE  -->
                        <Expander Header="PRINCIPALE" Style="{StaticResource NavExpander}">
                            <StackPanel>
                                <Button
                                    Click="Nav_Click"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Dashboard">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Text="  Dashboard" />
                                        <Border
                                            x:Name="badgeNotif"
                                            Height="16"
                                            MinWidth="16"
                                            Padding="4,0"
                                            HorizontalAlignment="Right"
                                            Background="{StaticResource DangerBrush}"
                                            Visibility="Collapsed">
                                            <TextBlock
                                                x:Name="txtBadgeCount"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe UI"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="0" />
                                        </Border>
                                    </Grid>
                                </Button>
                                <Button
                                    auth:Auth.Feature="nav.commesse"
                                    Click="Nav_Click"
                                    Content="  Commesse"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Commesse" />
                                <!-- ADDORMENTATA: sostituita da PreventiviPage tipo IMPIANTO -->
                                <!--<Button
                                    auth:Auth.Feature="nav.offerte"
                                    Click="Nav_Click"
                                    Content="  Offerte"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Offerte" />-->
                                <Button
                                    auth:Auth.Feature="nav.cat_preventivi"
                                    Click="Nav_Click"
                                    Content="  Cat. Preventivi"
                                    Style="{StaticResource NavBtn}"
                                    Tag="CatalogoPreventivi" />
                                <Button
                                    auth:Auth.Feature="nav.preventivi"
                                    Click="Nav_Click"
                                    Content="  Preventivi"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Preventivi" />
                                <Button
                                    auth:Auth.Feature="nav.timesheet"
                                    Click="Nav_Click"
                                    Content="  Timesheet"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Timesheet" />
                            </StackPanel>
                        </Expander>

                        <!--  GESTIONE  -->
                        <Expander
                            auth:Auth.AutoHide="True"
                            Header="GESTIONE"
                            Style="{StaticResource NavExpander}">
                            <StackPanel>
                                <Button
                                    auth:Auth.Feature="nav.clienti"
                                    Click="Nav_Click"
                                    Content="  Clienti"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Clienti" />
                                <Button
                                    auth:Auth.Feature="nav.fornitori"
                                    Click="Nav_Click"
                                    Content="  Fornitori"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Fornitori" />
                                <Button
                                    auth:Auth.Feature="nav.catalogo"
                                    Click="Nav_Click"
                                    Content="  Catalogo Articoli"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Catalogo" />
                                <Button
                                    auth:Auth.Feature="nav.codex"
                                    Click="Nav_Click"
                                    Content="  Codex Articoli"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Codex" />
                                <Button
                                    auth:Auth.Feature="nav.codex_composizione"
                                    Click="Nav_Click"
                                    Content="  Composizione Codex"
                                    Style="{StaticResource NavBtn}"
                                    Tag="CodexComposizione" />
                            </StackPanel>
                        </Expander>

                        <!--  AMMINISTRAZIONE  -->
                        <Expander
                            auth:Auth.AutoHide="True"
                            Header="AMMINISTRAZIONE"
                            Style="{StaticResource NavExpander}">
                            <StackPanel>
                                <Button
                                    auth:Auth.Feature="nav.utenti"
                                    Click="Nav_Click"
                                    Content="  Utenti"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Utenti" />
                                <Button
                                    auth:Auth.Feature="nav.permessi"
                                    Click="Nav_Click"
                                    Content="  Permessi"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Permessi" />
                            </StackPanel>
                        </Expander>

                        <!--  GESTIONE AVANZATA  -->
                        <Expander
                            auth:Auth.AutoHide="True"
                            Header="GESTIONE AVANZATA"
                            IsExpanded="False"
                            Style="{StaticResource NavExpander}">
                            <StackPanel>
                                <Button
                                    auth:Auth.Feature="nav.config_sezioni"
                                    Click="Nav_Click"
                                    Content="  Config. Sezioni"
                                    Style="{StaticResource NavBtn}"
                                    Tag="ConfigurazioneSezioni" />
                                <Button
                                    auth:Auth.Feature="nav.ddp_destinazioni"
                                    Click="Nav_Click"
                                    Content="  Destinazioni DDP"
                                    Style="{StaticResource NavBtn}"
                                    Tag="DestinazioniDdp" />
                                <Button
                                    auth:Auth.Feature="nav.backup"
                                    Click="Nav_Click"
                                    Content="  Backup DB"
                                    Style="{StaticResource NavBtn}"
                                    Tag="Backup" />
                            </StackPanel>
                        </Expander>

                        <!--  SESSIONE  -->
                        <Expander
                            Header="SESSIONE"
                            IsExpanded="False"
                            Style="{StaticResource NavExpander}">
                            <StackPanel>
                                <Button
                                    Click="BtnLogout_Click"
                                    Content="  Logout"
                                    Style="{StaticResource NavBtn}" />
                                <Button
                                    Click="BtnExit_Click"
                                    Content="  Esci"
                                    Style="{StaticResource NavBtn}" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!--  MAIN CONTENT  -->
        <Border Grid.Column="1">
            <DockPanel>
                <Border
                    Padding="24,10"
                    Background="White"
                    BorderBrush="{StaticResource Gray300Brush}"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <TextBlock
                        x:Name="txtPageTitle"
                        FontFamily="Segoe UI"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Gray900Brush}"
                        Text="Dashboard" />
                </Border>
                <Frame
                    x:Name="PageContent"
                    Margin="0"
                    JournalOwnership="OwnsJournal"
                    NavigationUIVisibility="Hidden" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
