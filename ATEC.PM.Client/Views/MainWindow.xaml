<Window
    x:Class="ATEC.PM.Client.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ATEC PM - Gestione Commesse"
    Width="1280"
    Height="800"
    MinWidth="1024"
    MinHeight="600"
    Background="#F7F8FA"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  SIDEBAR  -->
        <Border Grid.Column="0" Background="#1A1D26">
            <DockPanel>
                <StackPanel Margin="16,20,16,24" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="32"
                            Height="32"
                            Background="#4F6EF7">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="A" />
                        </Border>
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="ATEC PM" />
                    </StackPanel>
                    <Border
                        Height="1"
                        Margin="0,16,0,0"
                        Background="#2A2D36" />
                </StackPanel>

                <Border
                    Padding="16,12"
                    BorderBrush="#2A2D36"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="34"
                            Height="34"
                            Background="#4F6EF7">
                            <TextBlock
                                x:Name="txtInitials"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                x:Name="txtUserName"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White" />
                            <TextBlock
                                x:Name="txtRole"
                                FontSize="11"
                                Foreground="#6B7280" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Margin="8,0">
                    <TextBlock
                        Margin="12,0,0,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#4A4D56"
                        Text="PRINCIPALE" />
                    <Button
                        Click="Nav_Click"
                        Content="  Dashboard"
                        Style="{StaticResource NavBtn}"
                        Tag="Dashboard" />
                    <Button
                        Click="Nav_Click"
                        Content="  Commesse"
                        Style="{StaticResource NavBtn}"
                        Tag="Commesse" />
                    <Button
                        Click="Nav_Click"
                        Content="  Timesheet"
                        Style="{StaticResource NavBtn}"
                        Tag="Timesheet" />
                    <Button
                        Click="Nav_Click"
                        Content="  Documenti"
                        Style="{StaticResource NavBtn}"
                        Tag="Documenti" />

                    <TextBlock
                        Margin="12,24,0,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#4A4D56"
                        Text="GESTIONE" />
                    <Button
                        Click="Nav_Click"
                        Content="  Dipendenti"
                        Style="{StaticResource NavBtn}"
                        Tag="Dipendenti" />
                    <Button
                        Click="Nav_Click"
                        Content="  Clienti"
                        Style="{StaticResource NavBtn}"
                        Tag="Clienti" />
                    <Button
                        Click="Nav_Click"
                        Content="  Fornitori"
                        Style="{StaticResource NavBtn}"
                        Tag="Fornitori" />
                    <Button
                        Click="Nav_Click"
                        Content="  Catalogo Articoli"
                        Style="{StaticResource NavBtn}"
                        Tag="Catalogo" />

                    <TextBlock
                        Margin="12,24,0,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#4A4D56"
                        Text="REPORT" />
                    <Button
                        Click="Nav_Click"
                        Content="  Report"
                        Style="{StaticResource NavBtn}"
                        Tag="Report" />
                    <Button
                        Click="Nav_Click"
                        Content="  Impostazioni"
                        Style="{StaticResource NavBtn}"
                        Tag="Impostazioni" />

                    <TextBlock
                        Margin="12,24,0,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#4A4D56"
                        Text="SESSIONE" />
                    <Button
                        Click="BtnLogout_Click"
                        Content="  Logout"
                        Style="{StaticResource NavBtn}" />
                    <Button
                        Click="BtnExit_Click"
                        Content="  Esci"
                        Style="{StaticResource NavBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  MAIN CONTENT  -->
        <Border Grid.Column="1">
            <DockPanel>
                <Border
                    Padding="24,12"
                    Background="White"
                    BorderBrush="#E4E7EC"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <TextBlock
                        x:Name="txtPageTitle"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#1A1D26"
                        Text="Dashboard" />
                </Border>
                <Frame
                    x:Name="PageContent"
                    Margin="5"
                    NavigationUIVisibility="Hidden" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
