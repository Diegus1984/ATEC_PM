<Window
    x:Class="ATEC.PM.Client.UserControls.AddAssignmentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Assegna Tecnico"
    Width="360"
    MinHeight="200"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <DockPanel>

        <!--  Footer  -->
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtError"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="#EF4444" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="80"
                        Height="32"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Cursor="Hand"
                        Foreground="#374151" />
                    <Button
                        Width="80"
                        Height="32"
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnAdd_Click"
                        Content="Aggiungi"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  Form  -->
        <StackPanel Margin="20,16">

            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="TECNICO *" />
            <ComboBox
                x:Name="cmbEmployee"
                Height="32"
                Margin="0,4,0,0"
                BorderBrush="#E4E7EC"
                DisplayMemberPath="Name"
                FontSize="12"
                SelectedValuePath="Id" />

            <TextBlock
                Margin="0,12,0,0"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#6B7280"
                Text="ORE PIANIFICATE *" />
            <TextBox
                x:Name="txtHours"
                Height="32"
                Margin="0,4,0,0"
                Padding="8,5"
                BorderBrush="#E4E7EC"
                FontSize="13"
                Text="0" />

        </StackPanel>
    </DockPanel>
</Window>
