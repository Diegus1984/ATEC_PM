<Window
    x:Class="ATEC.PM.Client.UserControls.AddPhasesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aggiungi Fasi"
    Width="450"
    Height="500"
    Background="#F7F8FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E4E7EC"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <TextBlock
                    x:Name="txtCount"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#6B7280" />
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Height="34"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnCancel_Click"
                        Content="Annulla"
                        Cursor="Hand"
                        Foreground="#374151" />
                    <Button
                        Width="110"
                        Height="34"
                        Margin="8,0,0,0"
                        Background="#4F6EF7"
                        BorderThickness="0"
                        Click="BtnConfirm_Click"
                        Content="Aggiungi"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <StackPanel Margin="16,12,16,0">
            <TextBlock
                Margin="0,0,0,10"
                FontSize="13"
                Text="Seleziona le fasi da aggiungere alla commessa:" />
            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="pnlTemplates" />
            </ScrollViewer>
        </StackPanel>
    </DockPanel>
</Window>
