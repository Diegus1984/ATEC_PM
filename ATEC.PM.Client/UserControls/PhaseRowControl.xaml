<UserControl
    x:Class="ATEC.PM.Client.UserControls.PhaseRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White" BorderBrush="#E4E7EC" BorderThickness="1" Margin="0,0,0,4">
        <StackPanel>
            
            <!-- ═══ RIGA PRINCIPALE ═══ -->
            <Grid MinHeight="44">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>

                <!-- Accent color bar -->
                <Border x:Name="brdAccent" Grid.Column="0" Background="#6B7280" />

                <!-- Nome + tecnici -->
                <StackPanel Grid.Column="1" Margin="12,6,8,6" VerticalAlignment="Center">
                    <TextBlock x:Name="txtName" FontSize="13" FontWeight="SemiBold" Foreground="#1A1D26" />
                    <TextBlock x:Name="txtTecnici" FontSize="10" Foreground="#9CA3AF"
                               TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
                </StackPanel>

                <!-- Ore budget -->
                <TextBox x:Name="txtBudgetHours" Grid.Column="2" Height="26" Width="70" FontSize="12"
                         Padding="4,2" BorderBrush="#E4E7EC" BorderThickness="1"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         LostFocus="TxtBudgetHours_LostFocus" />

                <!-- Stato -->
                <ComboBox x:Name="cmbStatus" Grid.Column="3" Height="26" Width="100" FontSize="11"
                          VerticalAlignment="Center" BorderBrush="#E4E7EC"
                          SelectionChanged="CmbStatus_Changed">
                    <ComboBoxItem Content="NOT_STARTED" />
                    <ComboBoxItem Content="IN_PROGRESS" />
                    <ComboBoxItem Content="COMPLETED" />
                    <ComboBoxItem Content="ON_HOLD" />
                </ComboBox>

                <!-- Avanzamento % -->
                <TextBlock x:Name="txtProgress" Grid.Column="4" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />

                <!-- Ore lavorate -->
                <TextBlock x:Name="txtWorked" Grid.Column="5" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#4F6EF7" />

                <!-- Azioni -->
                <StackPanel Grid.Column="6" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="btnExpand" Content="▼" Width="26" Height="26" FontSize="10"
                            Background="#F3F4F6" Foreground="#374151" BorderThickness="0"
                            Cursor="Hand" ToolTip="Dettagli" Click="BtnExpand_Click" />
                    <Button x:Name="btnDelete" Content="✕" Width="26" Height="26" FontSize="11"
                            Margin="4,0,0,0" Background="#EF44441A" Foreground="#EF4444"
                            BorderThickness="0" Cursor="Hand" ToolTip="Elimina fase"
                            Click="BtnDelete_Click" />
                </StackPanel>
            </Grid>

            <!-- ═══ EXPANDER (nascosto di default) ═══ -->
            <Border x:Name="brdExpander" Background="#F9FAFB" BorderBrush="#E4E7EC"
                    BorderThickness="0,1,0,0" Padding="16,10" Visibility="Collapsed">
                <StackPanel>

                    <!-- Costo budget -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="COSTO BUDGET (€)" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6B7280" VerticalAlignment="Center" Width="130" />
                        <TextBox x:Name="txtBudgetCost" Height="26" Width="100" FontSize="12"
                                 Padding="4,2" BorderBrush="#E4E7EC" BorderThickness="1"
                                 LostFocus="TxtBudgetCost_LostFocus" />
                    </DockPanel>

                    <!-- Tecnici assegnati - header -->
                    <TextBlock Text="TECNICI ASSEGNATI" FontSize="10" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="0,4,0,6" />

                    <!-- Riga aggiunta tecnico -->
                    <Grid x:Name="gridAddTecnico" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbEmployee" Grid.Column="0" Height="28" FontSize="12"
                                  BorderBrush="#E4E7EC" DisplayMemberPath="Name" SelectedValuePath="Id" />
                        <TextBox x:Name="txtPlannedHours" Grid.Column="2" Height="28" Width="70"
                                 FontSize="12" Padding="4,2" BorderBrush="#E4E7EC" BorderThickness="1"
                                 Text="0" ToolTip="Ore pianificate" />
                        <Button Grid.Column="4" Content="+" Width="28" Height="28" FontSize="14"
                                FontWeight="Bold" Background="#4F6EF7" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Click="BtnAddAssignment_Click" />
                    </Grid>

                    <!-- Lista tecnici assegnati -->
                    <StackPanel x:Name="pnlAssignments" />

                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
