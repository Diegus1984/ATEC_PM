<UserControl
    x:Class="ATEC.PM.Client.UserControls.PhaseRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Margin="0,0,0,4"
        Background="White"
        BorderBrush="#E4E7EC"
        BorderThickness="1">
        <StackPanel>

            <!--  ═══ RIGA PRINCIPALE ═══  -->
            <Grid MinHeight="44">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>

                <!--  Accent color bar  -->
                <Border
                    x:Name="brdAccent"
                    Grid.Column="0"
                    Background="#6B7280" />

                <!--  Nome + tecnici  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="12,6,8,6"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="txtName"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#1A1D26" />
                    <TextBlock
                        x:Name="txtTecnici"
                        FontSize="10"
                        Foreground="#9CA3AF"
                        TextTrimming="CharacterEllipsis"
                        Visibility="Collapsed" />
                </StackPanel>

                <!--  Ore budget  -->
                <TextBlock
                    x:Name="txtBudgetHours"
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#1A1D26" />

                <!--  Stato  -->
                <ComboBox
                    x:Name="cmbStatus"
                    Grid.Column="3"
                    Width="100"
                    Height="26"
                    VerticalAlignment="Center"
                    BorderBrush="#E4E7EC"
                    FontSize="11"
                    SelectionChanged="CmbStatus_Changed">
                    <ComboBoxItem Content="NOT_STARTED" />
                    <ComboBoxItem Content="IN_PROGRESS" />
                    <ComboBoxItem Content="COMPLETED" />
                    <ComboBoxItem Content="ON_HOLD" />
                </ComboBox>

                <!--  Avanzamento %  -->
                <TextBlock
                    x:Name="txtProgress"
                    Grid.Column="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12" />

                <!--  Ore lavorate  -->
                <TextBlock
                    x:Name="txtWorked"
                    Grid.Column="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#4F6EF7" />

                <!--  Azioni  -->
                <StackPanel
                    Grid.Column="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnExpand"
                        Width="26"
                        Height="26"
                        Background="#F3F4F6"
                        BorderThickness="0"
                        Click="BtnExpand_Click"
                        Content="▼"
                        Cursor="Hand"
                        FontSize="10"
                        Foreground="#374151"
                        ToolTip="Dettagli" />
                    <Button
                        x:Name="btnDelete"
                        Width="26"
                        Height="26"
                        Margin="4,0,0,0"
                        Background="#EF44441A"
                        BorderThickness="0"
                        Click="BtnDelete_Click"
                        Content="✕"
                        Cursor="Hand"
                        FontSize="11"
                        Foreground="#EF4444"
                        ToolTip="Elimina fase" />
                </StackPanel>
            </Grid>

            <!--  ═══ EXPANDER (nascosto di default) ═══  -->
            <Border
                x:Name="brdExpander"
                Padding="16,10"
                Background="#F9FAFB"
                BorderBrush="#E4E7EC"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
                <StackPanel>

                    <!--  Costo budget  -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock
                            Width="130"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="COSTO BUDGET (€)" />
                        <TextBox
                            x:Name="txtBudgetCost"
                            Width="100"
                            Height="26"
                            Padding="4,2"
                            BorderBrush="#E4E7EC"
                            BorderThickness="1"
                            FontSize="12"
                            LostFocus="TxtBudgetCost_LostFocus" />
                    </DockPanel>

                    <!--  Tecnici assegnati - header  -->
                    <TextBlock
                        Margin="0,4,0,6"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="TECNICI ASSEGNATI" />

                    <!--  Riga aggiunta tecnico  -->
                    <Grid x:Name="gridAddTecnico" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="cmbEmployee"
                            Grid.Column="0"
                            Height="28"
                            BorderBrush="#E4E7EC"
                            DisplayMemberPath="Name"
                            FontSize="12"
                            SelectedValuePath="Id" />
                        <TextBox
                            x:Name="txtPlannedHours"
                            Grid.Column="2"
                            Width="70"
                            Height="28"
                            Padding="4,2"
                            BorderBrush="#E4E7EC"
                            BorderThickness="1"
                            FontSize="12"
                            Text="0"
                            ToolTip="Ore pianificate" />
                        <Button
                            Grid.Column="4"
                            Width="28"
                            Height="28"
                            Background="#4F6EF7"
                            BorderThickness="0"
                            Click="BtnAddAssignment_Click"
                            Content="+"
                            Cursor="Hand"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White" />
                    </Grid>

                    <!--  Lista tecnici assegnati  -->
                    <StackPanel x:Name="pnlAssignments" />

                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
