		<PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
		<PackageReference Include="System.Data.OleDb" Version="8.0.1" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\ATEC.PM.Shared\ATEC.PM.Shared.csproj" />
	</ItemGroup>
</Project>
